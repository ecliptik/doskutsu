+// DOS-PORT (patch 0082, Phase 9 wave 17.4): probe killswitch once on
+// first call. Strict "0" match disables the prev-frame diff path; all
+// other values keep the optimization on (default ON).
+static bool _doskutsu_prev_frame_diff_is_disabled(int &cached)
+{
+  if (cached < 0)
+  {
+    const char *e = std::getenv("SDL_HINT_DOSKUTSU_PREVFRAME_DIFF");
+    cached = (e && e[0] == '0' && e[1] == 0) ? 1 : 0;
+    LOG_INFO("Renderer: prev-frame diff {} (set SDL_HINT_DOSKUTSU_PREVFRAME_DIFF=0 to disable)",
+             cached ? "DISABLED (killswitch)" : "ENABLED (default)");
+  }
+  return cached == 1;
+}
+
+// DOS-PORT (patch 0082, Phase 9 wave 17.4): per-scanline diff between
+// `prev` and `curr`. Returns the count of dirty rects written into
+// `out` (each rect is a full-width band — `(0, y, w, h)`). Coalesces
+// contiguous dirty rows into a single rect. If the rect count would
+// exceed `max_rects`, the trailing rect is widened to cover all remaining
+// rows and the function returns max_rects (preserves correctness — the
+// caller will treat the over-cap result as "near-full" and likely fall
+// back to full flush via the threshold check, which is fine).
+//
+// Pre-conditions: prev/curr same dimensions and format. Pitches may
+// differ (each surface uses its own pitch for row stride).
+//
+// Cost: 240 × SDL_memcmp(320 bytes) on the title-mode INDEX8 path.
+// Roughly 1-2 ms on PODP83. The win is paying ~2 ms scan to save up
+// to ~14 ms of flush time (3-5× return).
+static int _doskutsu_diff_against_prev(SDL_Surface *prev,
+                                        SDL_Surface *curr,
+                                        SDL_Rect *out,
+                                        int max_rects)
+{
+  if (!prev || !curr) return -1;
+  if (prev->w != curr->w || prev->h != curr->h) return -1;
+  if (prev->format != curr->format) return -1;
+  if (max_rects <= 0) return 0;
+
+  const int width  = curr->w;
+  const int height = curr->h;
+  const int row_bytes_curr = curr->pitch;
+  const int row_bytes_prev = prev->pitch;
+  // Compare only the first (w * bpp) bytes per row. Padding past that
+  // is platform-dependent and irrelevant to visible content.
+  const int compare_bytes =
+      (curr->format == SDL_PIXELFORMAT_INDEX8) ? width :
+      (curr->format == SDL_PIXELFORMAT_RGB565) ? width * 2 :
+      // Fallback: compare to the pitch min so we never read OOB.
+      (row_bytes_curr < row_bytes_prev ? row_bytes_curr : row_bytes_prev);
+
+  int n_out = 0;
+  int dirty_start = -1;
+
+  for (int y = 0; y < height; y++)
+  {
+    const Uint8 *p_row = (const Uint8 *)prev->pixels + y * row_bytes_prev;
+    const Uint8 *c_row = (const Uint8 *)curr->pixels + y * row_bytes_curr;
+    const bool dirty = (SDL_memcmp(p_row, c_row, compare_bytes) != 0);
+    if (dirty)
+    {
+      if (dirty_start < 0) dirty_start = y;
+    }
+    else if (dirty_start >= 0)
+    {
+      if (n_out < max_rects)
+      {
+        out[n_out].x = 0;
+        out[n_out].y = dirty_start;
+        out[n_out].w = width;
+        out[n_out].h = y - dirty_start;
+        ++n_out;
+      }
+      else
+      {
+        // Cap reached — extend the last emitted rect to cover this band.
+        // Lossy but conservative: more rows marked dirty than needed.
+        out[max_rects - 1].h = (y - out[max_rects - 1].y);
+      }
+      dirty_start = -1;
+    }
+  }
+  if (dirty_start >= 0)
+  {
+    if (n_out < max_rects)
+    {
+      out[n_out].x = 0;
+      out[n_out].y = dirty_start;
+      out[n_out].w = width;
+      out[n_out].h = height - dirty_start;
+      ++n_out;
+    }
+    else
+    {
+      out[max_rects - 1].h = (height - out[max_rects - 1].y);
+    }
+  }
+  return n_out;
+}
