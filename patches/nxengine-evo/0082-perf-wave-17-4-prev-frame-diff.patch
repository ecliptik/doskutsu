@@ -1764,6 +1883,51 @@ void Renderer::flip()
   _inter_flip_accum_ms_block += _inter_flip_ms;
   _inter_flip_accum_ms_global += _inter_flip_ms;
 
+  // DOS-PORT (patch 0082, Phase 9 wave 17.4): prev-frame diff. Replaces
+  // the drawcall-tracked _dirty_rects with the actual changed regions
+  // detected by per-scanline memcmp against the prior frame's window
+  // contents. The drawcall-tracked path (wave 15) coalesced everything
+  // into a screen-spanning bounding box every flip; the diff produces
+  // small full-width bands when scenes are mostly static (title menu,
+  // dialog overlays). Pairs with SDL/0033 which makes
+  // DOSVESA_UpdateWindowFramebuffer honor the small rect list.
+  //
+  // Order-of-operations note: drain queued slow-path renderer commands
+  // before the diff so the window surface reflects all engine drawcalls
+  // for this frame. Otherwise the queued slow-path output wouldn't show
+  // up in `_cached_window_surface->pixels` at memcmp time and we'd
+  // miss-mark rows clean that actually contain new pixels.
+  bool _prev_diff_engaged = false;
+  if (!_doskutsu_prev_frame_diff_is_disabled(_prev_frame_diff_disabled) &&
+      _prev_frame_surface && _cached_window_surface &&
+      _prev_frame_surface->w == _cached_window_surface->w &&
+      _prev_frame_surface->h == _cached_window_surface->h &&
+      _prev_frame_surface->format == _cached_window_surface->format &&
+      !_force_full_refresh && _dirty_first_n_frames_remaining == 0)
+  {
+    if (_renderer_queue_dirty)
+    {
+      SDL_FlushRenderer(_renderer);
+      _renderer_queue_dirty = false;
+    }
+    SDL_Rect diff_rects[DIRTY_RECTS_MAX];
+    int n_diff = _doskutsu_diff_against_prev(_prev_frame_surface,
+                                              _cached_window_surface,
+                                              diff_rects, DIRTY_RECTS_MAX);
+    if (n_diff >= 0)
+    {
+      // Override engine's drawcall-tracked rects with the ground truth
+      // from the diff. Better signal: the diff is deterministic given
+      // the frame contents, regardless of how the engine constructed
+      // them.
+      _dirty_rects.clear();
+      for (int i = 0; i < n_diff; i++) _dirty_rects.push_back(diff_rects[i]);
+      _prev_diff_engaged = true;
+      ++_prev_frame_diff_calls_block;
+      _prev_frame_diff_rects_sum_block += n_diff;
+    }
+  }
+
   // DOS-PORT (patch 0071, Phase 9 wave 15): present-time decision tree.
   // Compute total dirty pixel area; choose between SDL_UpdateWindow-
   // SurfaceRects (partial, fast) and SDL_RenderPresent (full, slow).
@@ -1779,12 +1943,26 @@ void Renderer::flip()
   //   - total dirty area > DIRTY_THRESHOLD_PIXELS (~50% screen)
   //   - dirty list empty (all drawcalls fell through unmarked, or
   //     there genuinely were none; full flush is cheap insurance)
+  //
+  // DOS-PORT (patch 0082, Phase 9 wave 17.4): when prev-frame diff
+  // produces an empty list, the screen IS unchanged from prior frame —
+  // we should SKIP the flush entirely. But SDL3 expects a present per
+  // frame to keep palette / cursor / vsync state correct, so we still
+  // call the partial path with an empty rect list (SDL3-DOS will iterate
+  // 0 rects = no-op flush). Sub-millisecond per call.
   bool ok = true;
 
   // Sum dirty pixel area now (used by both the decision and the
   // diagnostic block below).
   int dirty_pixels = 0;
   for (const SDL_Rect &r : _dirty_rects) dirty_pixels += r.w * r.h;
+  // DOS-PORT (patch 0082): accumulator for diff-engagement diagnostics.
+  if (_prev_diff_engaged)
+  {
+    const int denom = screenWidth * screenHeight;
+    _prev_frame_diff_dirty_pct_x10_sum_block +=
+        denom ? ((dirty_pixels * 1000) / denom) : 0;
+  }
 
   const bool first_n_force = (_dirty_first_n_frames_remaining > 0);
   const bool threshold_exceeded = (dirty_pixels > DIRTY_THRESHOLD_PIXELS);
@@ -1793,7 +1971,14 @@ void Renderer::flip()
       !_force_full_refresh &&
       !first_n_force &&
       !threshold_exceeded &&
-      !_dirty_rects.empty();
+      // DOS-PORT (patch 0082, wave 17.4): when prev-frame diff is engaged
+      // and produced an empty list, the screen is genuinely unchanged
+      // since last flush — let the partial path fire with an empty rect
+      // list so the SDL palette-update / cursor-composite logic still
+      // runs. Skipping the flush entirely is safe-er but loses palette
+      // sync; an empty-rect partial flush is essentially a no-op flush
+      // with palette plumbing intact.
+      (!_dirty_rects.empty() || _prev_diff_engaged);
 
   if (can_use_dirty_path)
   {
@@ -1840,6 +2025,47 @@ void Renderer::flip()
       SDL_SetSurfacePalette(_cached_window_surface, _master_palette);
   }
 
+  // DOS-PORT (patch 0082, Phase 9 wave 17.4): refresh prev-frame buffer
+  // for next flip's diff. Lazy-(re)alloc to match window dimensions/
+  // format. Only runs when the diff path is enabled — disabling via
+  // SDL_HINT_DOSKUTSU_PREVFRAME_DIFF=0 also skips the alloc + copy
+  // overhead, restoring the wave-17.3 baseline.
+  //
+  // Copy is BLT-equivalent (~76 KB at 320×240 INDEX8 = ~0.5 ms on
+  // PODP83). Done after the flush so prev reflects what's currently in
+  // VRAM (within the limits of partial-flush — partial flushes only
+  // overwrite changed regions of VRAM, but prev mirrors the engine's
+  // window surface which is the source of truth, not VRAM directly).
+  if (ok && !_doskutsu_prev_frame_diff_is_disabled(_prev_frame_diff_disabled) &&
+      _cached_window_surface)
+  {
+    if (!_prev_frame_surface ||
+        _prev_frame_surface->w != _cached_window_surface->w ||
+        _prev_frame_surface->h != _cached_window_surface->h ||
+        _prev_frame_surface->format != _cached_window_surface->format)
+    {
+      if (_prev_frame_surface)
+      {
+        SDL_DestroySurface(_prev_frame_surface);
+        _prev_frame_surface = nullptr;
+      }
+      _prev_frame_surface = SDL_CreateSurface(
+          _cached_window_surface->w,
+          _cached_window_surface->h,
+          _cached_window_surface->format);
+      if (_prev_frame_surface &&
+          _cached_window_surface->format == SDL_PIXELFORMAT_INDEX8 &&
+          _master_palette)
+      {
+        SDL_SetSurfacePalette(_prev_frame_surface, _master_palette);
+      }
+    }
+    if (_prev_frame_surface)
+    {
+      SDL_BlitSurface(_cached_window_surface, NULL, _prev_frame_surface, NULL);
+    }
+  }
