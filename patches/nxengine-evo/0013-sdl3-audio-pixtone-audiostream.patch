 1 file changed, 57 insertions(+), 51 deletions(-)

diff --git a/src/sound/Pixtone.cpp b/src/sound/Pixtone.cpp
index 215e676..ab954d6 100644
--- a/src/sound/Pixtone.cpp
+++ b/src/sound/Pixtone.cpp
@@ -369,33 +369,34 @@ int Pixtone::playResampled(int32_t chan, int32_t slot, int32_t loop, uint32_t pe
 
     if (idx == -1)
     {
-      SDL_AudioCVT cvt;
+      SDL_AudioSpec src_spec = { SDL_AUDIO_S16, 2, SAMPLE_RATE };
+      SDL_AudioSpec dst_spec = { SDL_AUDIO_S16, 2, (int)resampled_rate };
 
-      if (SDL_BuildAudioCVT(&cvt, AUDIO_S16, 2, SAMPLE_RATE, AUDIO_S16, 2, resampled_rate) == -1)
+      SDL_AudioStream *stream = SDL_CreateAudioStream(&src_spec, &dst_spec);
+      if (!stream)
       {
-        LOG_ERROR("SDL_BuildAudioCVT: {}", SDL_GetError());
+        LOG_ERROR("SDL_CreateAudioStream: {}", SDL_GetError());
       }
-      cvt.len = _sound_fx[slot].chunk->alen;
-      cvt.buf = (Uint8 *)SDL_malloc(cvt.len * cvt.len_mult);
-      SDL_memcpy(cvt.buf, _sound_fx[slot].chunk->abuf, _sound_fx[slot].chunk->alen);
 
-      if (SDL_ConvertAudio(&cvt) == -1)
+      if (!SDL_PutAudioStreamData(stream, _sound_fx[slot].chunk->abuf, _sound_fx[slot].chunk->alen))
       {
-        LOG_ERROR("SDL_ConvertAudio: {}", SDL_GetError());
+        LOG_ERROR("SDL_PutAudioStreamData: {}", SDL_GetError());
       }
-
-/*      if (_sound_fx[slot].resampled != NULL)
+      if (!SDL_FlushAudioStream(stream))
       {
-        SDL_free(_sound_fx[slot].resampled->abuf);
-        SDL_free(_sound_fx[slot].resampled);
-        _sound_fx[slot].resampled = NULL;
-      }*/
+        LOG_ERROR("SDL_FlushAudioStream: {}", SDL_GetError());
+      }
 
-      Uint8 *sound_buf = (Uint8 *)SDL_malloc(cvt.len_cvt);
-      SDL_memcpy(sound_buf, (Uint8 *)cvt.buf, cvt.len_cvt);
-      SDL_free(cvt.buf);
+      int converted_len = SDL_GetAudioStreamAvailable(stream);
+      Uint8 *sound_buf  = (Uint8 *)SDL_malloc(converted_len);
+      int got = SDL_GetAudioStreamData(stream, sound_buf, converted_len);
+      if (got != converted_len)
+      {
+        LOG_ERROR("SDL_GetAudioStreamData: short read {}/{}: {}", got, converted_len, SDL_GetError());
+      }
+      SDL_DestroyAudioStream(stream);
 
-      _sound_fx[slot].resampled[rslot] = Mix_QuickLoad_RAW(sound_buf, cvt.len_cvt);
+      _sound_fx[slot].resampled[rslot] = Mix_QuickLoad_RAW(sound_buf, converted_len);
       _sound_fx[slot].resampled_rate[rslot] = resampled_rate;
       idx = rslot;
     }
@@ -442,35 +443,34 @@ int Pixtone::prepareResampled(int32_t slot, uint32_t percent)
 
     if (idx == -1) // not found
     {
-      SDL_AudioCVT cvt;
+      SDL_AudioSpec src_spec = { SDL_AUDIO_S16, 2, SAMPLE_RATE };
+      SDL_AudioSpec dst_spec = { SDL_AUDIO_S16, 2, (int)resampled_rate };
 
-      if (SDL_BuildAudioCVT(&cvt, AUDIO_S16, 2, SAMPLE_RATE, AUDIO_S16, 2, resampled_rate) == -1)
+      SDL_AudioStream *stream = SDL_CreateAudioStream(&src_spec, &dst_spec);
+      if (!stream)
       {
-        LOG_ERROR("SDL_BuildAudioCVT: {}", SDL_GetError());
+        LOG_ERROR("SDL_CreateAudioStream: {}", SDL_GetError());
       }
-      cvt.len = _sound_fx[slot].chunk->alen;
-      cvt.buf = (Uint8 *)SDL_malloc(cvt.len * cvt.len_mult);
-      SDL_memcpy(cvt.buf, _sound_fx[slot].chunk->abuf, _sound_fx[slot].chunk->alen);
 
-      if (SDL_ConvertAudio(&cvt) == -1)
+      if (!SDL_PutAudioStreamData(stream, _sound_fx[slot].chunk->abuf, _sound_fx[slot].chunk->alen))
       {
-        LOG_ERROR("SDL_ConvertAudio: {}", SDL_GetError());
+        LOG_ERROR("SDL_PutAudioStreamData: {}", SDL_GetError());
       }
-
-/*
-      if (_sound_fx[slot].resampled != NULL)
+      if (!SDL_FlushAudioStream(stream))
       {
-        SDL_free(_sound_fx[slot].resampled->abuf);
-        SDL_free(_sound_fx[slot].resampled);
-        _sound_fx[slot].resampled = NULL;
+        LOG_ERROR("SDL_FlushAudioStream: {}", SDL_GetError());
       }
-*/
 
-      Uint8 *sound_buf = (Uint8 *)SDL_malloc(cvt.len_cvt);
-      SDL_memcpy(sound_buf, (Uint8 *)cvt.buf, cvt.len_cvt);
-      SDL_free(cvt.buf);
+      int converted_len = SDL_GetAudioStreamAvailable(stream);
+      Uint8 *sound_buf  = (Uint8 *)SDL_malloc(converted_len);
+      int got = SDL_GetAudioStreamData(stream, sound_buf, converted_len);
+      if (got != converted_len)
+      {
+        LOG_ERROR("SDL_GetAudioStreamData: short read {}/{}: {}", got, converted_len, SDL_GetError());
+      }
+      SDL_DestroyAudioStream(stream);
 
-      _sound_fx[slot].resampled[rslot] = Mix_QuickLoad_RAW(sound_buf, cvt.len_cvt);
+      _sound_fx[slot].resampled[rslot] = Mix_QuickLoad_RAW(sound_buf, converted_len);
       _sound_fx[slot].resampled_rate[rslot] = resampled_rate;
     }
   }
@@ -505,28 +505,34 @@ void Pixtone::pxtSoundDone(int channel)
 void Pixtone::_prepareToPlay(stPXSound *snd, int32_t slot)
 {
   // convert the buffer from 8-bit mono signed to 16-bit stereo signed
-  SDL_AudioCVT cvt;
+  SDL_AudioSpec src_spec = { SDL_AUDIO_S8,  1, 22050 };
+  SDL_AudioSpec dst_spec = { SDL_AUDIO_S16, 2, SAMPLE_RATE };
 
-  if (SDL_BuildAudioCVT(&cvt, AUDIO_S8, 1, 22050, AUDIO_S16, 2, SAMPLE_RATE) == -1)
+  SDL_AudioStream *stream = SDL_CreateAudioStream(&src_spec, &dst_spec);
+  if (!stream)
   {
-    LOG_ERROR("SDL_BuildAudioCVT: {}", SDL_GetError());
+    LOG_ERROR("SDL_CreateAudioStream: {}", SDL_GetError());
   }
 
-  cvt.len = snd->final_size;
-
-  cvt.buf = (Uint8 *)SDL_malloc(cvt.len * cvt.len_mult);
-  memcpy(cvt.buf, snd->final_buffer, snd->final_size);
-
-  if (SDL_ConvertAudio(&cvt) == -1)
+  if (!SDL_PutAudioStreamData(stream, snd->final_buffer, snd->final_size))
+  {
+    LOG_ERROR("SDL_PutAudioStreamData: {}", SDL_GetError());
+  }
+  if (!SDL_FlushAudioStream(stream))
   {
-    LOG_ERROR("SDL_ConvertAudio: {}", SDL_GetError());
+    LOG_ERROR("SDL_FlushAudioStream: {}", SDL_GetError());
   }
 
-  Uint8 *sound_buf = (Uint8 *)SDL_malloc(cvt.len_cvt);
-  SDL_memcpy(sound_buf, (Uint8 *)cvt.buf, cvt.len_cvt);
-  SDL_free(cvt.buf);
+  int converted_len = SDL_GetAudioStreamAvailable(stream);
+  Uint8 *sound_buf  = (Uint8 *)SDL_malloc(converted_len);
+  int got = SDL_GetAudioStreamData(stream, sound_buf, converted_len);
+  if (got != converted_len)
+  {
+    LOG_ERROR("SDL_GetAudioStreamData: short read {}/{}: {}", got, converted_len, SDL_GetError());
+  }
+  SDL_DestroyAudioStream(stream);
 
-  _sound_fx[slot].chunk = Mix_QuickLoad_RAW(sound_buf, cvt.len_cvt);
+  _sound_fx[slot].chunk = Mix_QuickLoad_RAW(sound_buf, converted_len);
 }
 
 } // namespace Sound
