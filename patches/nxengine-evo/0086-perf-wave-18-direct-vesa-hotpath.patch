+// DOS-PORT (patch 0086, Phase 9 wave 18): direct-VESA hot path. Bypasses
+// SDL_RenderPresent + SDL_UpdateWindowSurface and writes the engine's
+// window surface directly into VRAM via SDL/0034's helper API. Single-
+// call PresentFull integration: the helper picks LFB-memcpy / banked-
+// dosmemput / multi-bank flush automatically based on the snapshot
+// flags. Today's path is single-bank banked on g2k (Cirrus + UNIVBE
+// 6.70, banked-mode default since SDL/0019 auto-disables LFB on Cirrus)
+// or LFB-memcpy when SDL_HINT_DOSKUTSU_FORCE_LFB=1 is also set.
+//
+// Engaged from flip() under two preconditions:
+//   1. SDL_HINT_DOSKUTSU_DIRECT_VESA=1 (strict-1 match; default OFF)
+//   2. _force_full_refresh and _dirty_first_n_frames_remaining clear
+//      (init / scene-reset cases route through SDL_RenderPresent)
+//
+// R2 (window-surface re-allocation drift) is covered by SDL/0034 v2's
+// generation counter — populate_fb_state_for_direct_fb success bumps
+// the counter on both window-create AND lazy-reinit, so a generation
+// bump signals BOTH "fb_state changed" AND "window->surface->pixels
+// may have moved." Re-snapshotting on bump (below) is the canonical
+// mitigation; no separate SDL_RenderPresent heartbeat is required.
+// See vendor/SDL/include/SDL3/SDL_dosvesa_directaccess.h § Mode-change
+// semantics.
+//
+// Returns false on:
+//   - invalid window surface
+//   - SDL/0034 snapshot reports fast path not engaged (fall back to
+//     SDL_UpdateWindowSurface)
+//   - mode-change race (snapshot gen != cached gen and re-snapshot
+//     fails — should not happen post-init but defensively gated)
+//   - surface dims/pitch != VBE mode dims/pitch (catches forced
+//     widescreen / scaling configs we don't expect on the DOS port)
+//   - pitches_match=false (forward-compat: padded surfaces would need
+//     a per-row loop instead of one-shot PresentFull)
+//
+// On false return the caller (flip) falls through to the pre-existing
+// SDL_RenderPresent / SDL_UpdateWindowSurfaceRects path. No visual
+// regression even if the direct path never engages.
+//
+// Predicted: +2-5 fps title vs wave 17.6 baseline (25.6 fps real HW).
+// Framed as a hypothesis to measure, not a goal to defend
+// (perf_predictions_unreliable.md). Possible outcomes:
+//   +5 fps -> follow-up patch promotes to default-ON
+//   +0 fps -> SDL layer wasn't the bottleneck; close wave 18, pivot
+//             to wave 19 (Cirrus hwblit) with confidence
+//   visual artifacts -> revert; risks R1/R2/R3 manifested
+bool Renderer::_direct_vesa_present()
+{
+#ifdef NXE_DOS
+  if (!_cached_window_surface || !_cached_window_surface->pixels)
+    return false;
+
+  // SDL/0034 generation counter detects mode-set / lazy-reinit. Re-
+  // snapshot when bumped (or on the very first direct-vesa call —
+  // _direct_vesa_state.valid is false-initialized).
+  const Uint32 gen_now = SDL_DOSVesaDirectGetGeneration();
+  if (!_direct_vesa_state.valid || gen_now != _direct_vesa_generation)
+  {
+    if (!SDL_DOSVesaDirectGetState(&_direct_vesa_state))
+    {
+      // Fast path not engaged (hint not set, no usable VBE access path,
+      // mode not yet set, etc). Caller falls back to SDL_RenderPresent.
+      _direct_vesa_state.valid = false;
+      return false;
+    }
+    _direct_vesa_generation = gen_now;
+    LOG_INFO("direct-vesa: snapshot @gen={} use_dosmemput={} banked_multibank={} "
+             "pitches_match={} vram_w={} vram_h={} vram_pitch={} bpp={} fb_size={} "
+             "vram_phys=0x{:08x} vram_ptr=0x{:08x}",
+             (unsigned long)gen_now,
+             (int)_direct_vesa_state.use_dosmemput,
+             (int)_direct_vesa_state.banked_multibank,
+             (int)_direct_vesa_state.pitches_match,
+             _direct_vesa_state.vram_w, _direct_vesa_state.vram_h,
+             _direct_vesa_state.vram_pitch, _direct_vesa_state.bpp,
+             (unsigned long)_direct_vesa_state.fb_size,
+             (unsigned long)_direct_vesa_state.vram_phys,
+             (unsigned long)(uintptr_t)_direct_vesa_state.vram_ptr);
+    // Force palette re-program post-snapshot — the new mode's DAC may
+    // not match our master palette state; reset the cached version so
+    // the version-comparison below trips on the next call.
+    _direct_vesa_palette_version = 0;
+  }
+
+  // Drain SW-renderer queue so all engine drawcalls land in
+  // _cached_window_surface->pixels (which is what we read from below).
+  // The SW renderer's destination IS the window surface, so flush is
+  // sufficient — RenderPresent's "page-flip" semantics are what we're
+  // intentionally bypassing. Per sdl-engine task #1 audit R1.
+  if (_renderer_queue_dirty)
+  {
+    SDL_FlushRenderer(_renderer);
+    _renderer_queue_dirty = false;
+  }
+
+  // Sanity: window surface dims must match the VBE mode. NXEngine-evo
+  // resolution-change code clamps to 320x240 fullscreen on DOS (per
+  // CLAUDE.md "NXEngine-evo specifics") so this should never trip in
+  // practice — but if it does, the mismatch would dosmemput the wrong
+  // size buffer and corrupt VRAM. Fall through to SDL_RenderPresent
+  // and force a re-snapshot.
+  if (_cached_window_surface->w != _direct_vesa_state.vram_w
+      || _cached_window_surface->h != _direct_vesa_state.vram_h
+      || _cached_window_surface->pitch != _direct_vesa_state.vram_pitch)
+  {
+    LOG_ERROR("direct-vesa: surface vs VBE mismatch (surface={}x{} pitch={}; "
+              "vbe={}x{} pitch={}); falling back to SDL_RenderPresent + "
+              "forcing snapshot refresh next attempt",
+              _cached_window_surface->w, _cached_window_surface->h,
+              _cached_window_surface->pitch,
+              _direct_vesa_state.vram_w, _direct_vesa_state.vram_h,
+              _direct_vesa_state.vram_pitch);
+    _direct_vesa_state.valid = false;
+    return false;
+  }
+
+  if (!_direct_vesa_state.pitches_match)
+  {
+    // Forward-compat guard: a padded surface would need per-row dosmemput
+    // (n_rows × surface->pitch != fb_size). PresentFull's contract is
+    // "pitch matches"; today's DOS path is always 320×1=320 pitch but a
+    // future widescreen / non-power-of-two path would need this. Fall
+    // through quietly; the SDL_UpdateWindowSurface path handles padded
+    // pitch correctly via per-row dispatch.
+    return false;
+  }
+
+  // Sync VGA DAC if our master palette version drifted. Cheap (~25 us
+  // on PODP83 per SDL/0034 header) — only fires when a palette edit
+  // (cmod, fade, scene transition) bumped the version.
+  if (_indexed_mode && _master_palette
+      && _master_palette->version != _direct_vesa_palette_version)
+  {
+    SDL_DOSVesaDirectProgramPalette(_master_palette);
+    _direct_vesa_palette_version = _master_palette->version;
+  }
+
+  // Single-call full-frame present. PresentFull internally dispatches:
+  //   - LFB path (use_dosmemput=false)         -> SDL_memcpy(vram_ptr, pixels, fb_size)
+  //   - banked single-bank (banked_multibank=false) -> dosmemput(pixels, fb_size, vram_phys)
+  //   - banked multi-bank (banked_multibank=true)   -> SDL_DOSVesaDirectBankedFlush()
+  if (!SDL_DOSVesaDirectPresentFull(&_direct_vesa_state,
+                                     _cached_window_surface->pixels))
+    return false;
+
+  return true;
+#else
+  // Non-DOS builds never engage this path (env helper returns disabled).
+  // Defensive return so the symbol still compiles for ports that include
+  // this TU via the upstream build (Linux / Win desktop / etc).
+  return false;
+#endif
+}
+
 void Renderer::flip()
 {
 //  LOG_INFO("===FLIPPING===\n");
@@ -2054,7 +2274,60 @@ void Renderer::flip()
       // with palette plumbing intact.
       (!_dirty_rects.empty() || _prev_diff_engaged);
 
-  if (can_use_dirty_path)
+  // DOS-PORT (patch 0086, Phase 9 wave 18): direct-VESA hot path
+  // attempt. Sits BEFORE the dirty-path / full-present decision tree.
+  // When env-gated ON and conservative preconditions hold, calls
+  // _direct_vesa_present() (dosmemput / memcpy via SDL/0034 helper)
+  // and SKIPS both SDL_UpdateWindowSurfaceRects and SDL_RenderPresent.
+  //
+  // Conservative preconditions:
+  //   - first_n_force clear: backbuffer is meaningful (not init garbage)
+  //   - _force_full_refresh clear: caller explicitly wanted a full SDL
+  //     present (flushAll, scene reset). Respect it.
+  //
+  // R2 (window-surface re-allocation drift between flips) is covered by
+  // SDL/0034 v2's generation counter — populate_fb_state_for_direct_fb
+  // bumps it on window-create AND lazy-reinit, so a bump signals BOTH
+  // "fb_state changed" AND "window->surface->pixels may have moved."
+  // _direct_vesa_present() re-snapshots on bump; no separate
+  // SDL_RenderPresent heartbeat is required.
+  //
+  // Diagnostic counters bumped per-attempt (success / fail) so the
+  // per-100-flip phase-timing block reports attribution.
+  const bool _dv_attempt =
+      _abl_direct_vesa() && !first_n_force && !_force_full_refresh;
+  bool _direct_vesa_done = false;
+  if (_dv_attempt)
+  {
+    Uint64 _dv_t0 = SDL_GetTicksNS();
+    bool _dv_ok = _direct_vesa_present();
+    Uint64 _dv_dt = SDL_GetTicksNS() - _dv_t0;
+    if (_dv_ok)
+    {
+      _direct_vesa_done = true;
+      ok = true;
+      ++_direct_vesa_presents_block;
+      _direct_vesa_present_accum_ns_block += _dv_dt;
+    }
+    else
+    {
+      ++_direct_vesa_present_failed_block;
+      // Fall through to SDL_RenderPresent path below.
+      // _direct_vesa_present already invalidated its snapshot if needed.
+    }
+  }
+
+  if (_direct_vesa_done)
+  {
+    // Direct-VESA wrote the frame; SDL3 present path skipped entirely.
+    // _force_full_refresh and _dirty_first_n_frames_remaining were
+    // already false/0 (gating preconditions for _dv_attempt) — no
+    // state-machine bookkeeping to do here. Block-level tally counters
+    // (_dr_full_flush_taken_block / _dr_dirty_path_taken_block) stay
+    // untouched so the dirty-rect diagnostic block reports the SDL
+    // paths separately from direct-vesa attribution.
+  }
+  else if (can_use_dirty_path)
   {
     // Partial-update path. Drain any queued slow-path commands first
     // so they reach the window surface; the SW renderer's data->
