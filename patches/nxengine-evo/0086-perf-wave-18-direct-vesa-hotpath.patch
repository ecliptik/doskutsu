@@ -285,6 +293,33 @@ class Renderer
     int _prev_frame_diff_bbox_pct_x10_sum_block = 0;
     int _prev_frame_diff_bbox_threshold_exceeded_block = 0;
 
+    // DOS-PORT (patch 0086, Phase 9 wave 18): direct-VESA hot path state.
+    // Cached snapshot of SDL3-DOS's `fb_state` (vram_ptr / vram_phys /
+    // banked-mode metadata), refreshed when SDL/0034's generation counter
+    // bumps. Per SDL/0034 v2 § Mode-change semantics the generation
+    // counter is bumped on:
+    //   - DOSVESA_InvalidateCachedFramebuffer (mode change)
+    //   - populate_fb_state_for_direct_fb success (window-create + lazy-
+    //     reinit, which also covers SDL3 window->surface re-allocation)
