+// Coalescing strategy (cheap, in-place; no allocation):
+//   1. clip to 320×240 logical viewport, drop empties
+//   2. scan existing rects: if new is contained in any, drop new
+//   3. scan again: if new overlaps any (axis-aligned intersect),
+//      union into that existing rect (covers the common case of
+//      a sprite straddling its previous-frame footprint)
+//   4. else push as a new entry
+//   5. if list is full (DIRTY_RECTS_MAX), collapse the entire list
+//      into a single bounding box. We're capacity-bound, not
+//      precision-bound at that point — 16 small rects vs 1 big one
+//      is a wash because the threshold check at flip() trips on
+//      total area regardless.
+//
+// This runs on every blit primitive in the hot path. The work is
+// trivially bounded (≤ DIRTY_RECTS_MAX iterations of cheap int
+// compares) so the per-call overhead is negligible (single-digit
+// nanoseconds). No allocation after the initial reserve in initVideo.
 void Renderer::_record_dirty_rect(int dst_x, int dst_y, int dst_w, int dst_h)
 {
   if (!_dirty_rect_enabled) return;
+  if (_force_full_refresh) return;  // already going full flush — skip work
   if (dst_w <= 0 || dst_h <= 0) return;
-  // Clip to 320x240 logical viewport. Out-of-bounds rects from
-  // off-screen sprites become empty and are dropped.
+
+  // 1. clip to 320×240 logical viewport
   if (dst_x < 0) { dst_w += dst_x; dst_x = 0; }
   if (dst_y < 0) { dst_h += dst_y; dst_y = 0; }
   if (dst_x + dst_w > screenWidth)  dst_w = screenWidth  - dst_x;
   if (dst_y + dst_h > screenHeight) dst_h = screenHeight - dst_y;
   if (dst_w <= 0 || dst_h <= 0) return;
-  // Cheap coalesce: if this rect is identical to the previous one we
-  // pushed, skip the duplicate. Real coalescing is left to the SDL
-  // side (SDL_UpdateWindowSurfaceRects iterates the list anyway).
-  if (!_dirty_rects.empty())
+
+  const int new_x2 = dst_x + dst_w;
+  const int new_y2 = dst_y + dst_h;
+
+  // 2. drop if contained in any existing rect
+  for (const SDL_Rect &r : _dirty_rects)
+  {
+    if (dst_x >= r.x && dst_y >= r.y &&
+        new_x2 <= r.x + r.w && new_y2 <= r.y + r.h)
+    {
+      return;
+    }
+  }
+
+  // 3. union into first overlapping rect
+  for (SDL_Rect &r : _dirty_rects)
   {
-    const SDL_Rect &prev = _dirty_rects.back();
-    if (prev.x == dst_x && prev.y == dst_y && prev.w == dst_w && prev.h == dst_h)
+    const int rx2 = r.x + r.w;
+    const int ry2 = r.y + r.h;
+    // axis-aligned overlap test
+    if (dst_x < rx2 && new_x2 > r.x && dst_y < ry2 && new_y2 > r.y)
+    {
+      const int ux = (dst_x < r.x) ? dst_x : r.x;
+      const int uy = (dst_y < r.y) ? dst_y : r.y;
+      const int ux2 = (new_x2 > rx2) ? new_x2 : rx2;
+      const int uy2 = (new_y2 > ry2) ? new_y2 : ry2;
+      r.x = ux;
+      r.y = uy;
+      r.w = ux2 - ux;
+      r.h = uy2 - uy;
       return;
+    }
+  }
+
+  // 4. cap reached — collapse + push
+  if ((int)_dirty_rects.size() >= DIRTY_RECTS_MAX)
+  {
+    int ux = dst_x, uy = dst_y, ux2 = new_x2, uy2 = new_y2;
+    for (const SDL_Rect &r : _dirty_rects)
+    {
+      if (r.x < ux) ux = r.x;
+      if (r.y < uy) uy = r.y;
+      if (r.x + r.w > ux2) ux2 = r.x + r.w;
+      if (r.y + r.h > uy2) uy2 = r.y + r.h;
+    }
+    _dirty_rects.clear();
+    SDL_Rect collapsed{ux, uy, ux2 - ux, uy2 - uy};
+    _dirty_rects.push_back(collapsed);
+    return;
   }
+
+  // 5. brand-new rect, no overlap, capacity available
   SDL_Rect r{dst_x, dst_y, dst_w, dst_h};
   _dirty_rects.push_back(r);
 }
