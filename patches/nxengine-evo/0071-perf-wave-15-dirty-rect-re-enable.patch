+      !_force_full_refresh &&
+      !first_n_force &&
+      !threshold_exceeded &&
+      !_dirty_rects.empty();
+
+  if (can_use_dirty_path)
   {
     // Partial-update path. Drain any queued slow-path commands first
     // so they reach the window surface; the SW renderer's data->
@@ -1433,20 +1416,23 @@ void Renderer::flip()
       SDL_FlushRenderer(_renderer);
       _renderer_queue_dirty = false;
     }
-    if (!_dirty_rects.empty())
-    {
-      ok = SDL_UpdateWindowSurfaceRects(_window, _dirty_rects.data(),
-                                        (int)_dirty_rects.size());
-    }
-    used_dirty_path = true;
+    ok = SDL_UpdateWindowSurfaceRects(_window, _dirty_rects.data(),
+                                      (int)_dirty_rects.size());
+    ++_dr_dirty_path_taken_block;
   }
   else
   {
     ok = SDL_RenderPresent(_renderer);
     _renderer_queue_dirty = false;
-    // We just paid for a full-screen flush; consume the force-full
-    // request. Subsequent frames re-enter the dirty-path arm.
+    // Consume the force-full and decrement the first-N-frames guard.
     _force_full_refresh = false;
+    if (_dirty_first_n_frames_remaining > 0)
+    {
+      --_dirty_first_n_frames_remaining;
+      ++_dr_first_n_bypass_block;
+    }
+    if (threshold_exceeded) ++_dr_threshold_exceeded_block;
+    ++_dr_full_flush_taken_block;
