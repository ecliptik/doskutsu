---
 src/main.cpp | 41 +++++++++++++++++++++++++++++++++++++++--
 1 file changed, 39 insertions(+), 2 deletions(-)

diff --git a/src/main.cpp b/src/main.cpp
index 10c17dd..e4392b0 100644
--- a/src/main.cpp
+++ b/src/main.cpp
@@ -497,7 +497,32 @@ int main(int argc, char *argv[])
 #endif
 
   // SDL3: SDL_Init returns bool (true on success); old `< 0` check would always be false.
-  if (!SDL_Init(SDL_INIT_VIDEO | SDL_INIT_AUDIO))
+  // DOS-PORT (patch 0089, Phase 9 wave 20 W20A2): audio-off ablation
+  // killswitch. Set SDL_HINT_DOSKUTSU_AUDIO_OFF=1 (strict-1 match) to
+  // omit SDL_INIT_AUDIO from the SDL_Init flags, AND skip
+  // SoundManager::init() below. This is DEEPER than the pre-existing
+  // DOSKUTSU_NO_AUDIO=1 (which only skipped SoundManager::init() but
+  // still inited the SDL audio subsystem and hooked the SB16 IRQ).
+  // Hypothesis test: does flip_inner late-block growth correlate with
+  // audio IRQ wall-clock, or with something else? AUDIO_OFF removes
+  // audio from the timing equation entirely so the W20A2 iter can
+  // confirm or refute the audio-IRQ hypothesis (per
+  // memory/wave_20_misc_slice_in_flip_body.md).
+  Uint32 _sdl_init_flags = SDL_INIT_VIDEO | SDL_INIT_AUDIO;
+  bool _audio_off = false;
+  {
+    const char *e = std::getenv("SDL_HINT_DOSKUTSU_AUDIO_OFF");
+    _audio_off = e && e[0] == '1' && e[1] == 0;
+  }
+  if (_audio_off)
+  {
+    _sdl_init_flags &= ~SDL_INIT_AUDIO;
+    LOG_INFO("SDL_HINT_DOSKUTSU_AUDIO_OFF=1 — skipping SDL_INIT_AUDIO "
+             "(W20A2 audio-off ablation; SB16 IRQ never hooked, audio "
+             "subsystem not initialized; SoundManager::init() will also "
+             "be skipped below)");
+  }
+  if (!SDL_Init(_sdl_init_flags))
   {
     LOG_CRITICAL("ack, sdl_init failed: {}.", SDL_GetError());
     return 1;
@@ -539,7 +564,19 @@ int main(int argc, char *argv[])
   // title screen with this set, audio init is confirmed as the wall and the
   // SB DSP probe needs a real fix. Not for shipping — leaving this in place
   // means no audio.
-  if (std::getenv("DOSKUTSU_NO_AUDIO"))
+  // DOS-PORT (patch 0089, Phase 9 wave 20 W20A2): AUDIO_OFF check is
+  // OR'd with the pre-existing DOSKUTSU_NO_AUDIO so either env var
+  // skips SoundManager::init(). The two have different SDL-init
+  // semantics though — DOSKUTSU_NO_AUDIO leaves SDL_INIT_AUDIO active
+  // (and the SB16 IRQ hooked); SDL_HINT_DOSKUTSU_AUDIO_OFF removed
+  // SDL_INIT_AUDIO above. For W20A2's hypothesis test, the deeper
+  // AUDIO_OFF skip is required.
+  if (_audio_off)
+  {
+    LOG_INFO("SDL_HINT_DOSKUTSU_AUDIO_OFF=1 — bypassing SoundManager::init() "
+             "(deeper than DOSKUTSU_NO_AUDIO; SDL_INIT_AUDIO already omitted)");
+  }
+  else if (std::getenv("DOSKUTSU_NO_AUDIO"))
   {
     LOG_INFO("DOSKUTSU_NO_AUDIO set; bypassing SoundManager::init() for diagnostics");
   }
