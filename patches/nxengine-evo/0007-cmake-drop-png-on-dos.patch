From de30bcc5e523782581df2fabe5005ba9f829ac62 Mon Sep 17 00:00:00 2001
From: DOSKUTSU NXEngine Port <services.claude@accounts.ecliptik.com>
Date: Sat, 25 Apr 2026 11:07:14 -0700
Subject: [PATCH] [DOSKUTSU] cmake+renderer: drop libpng dep on DOS (screenshot
 save disabled)

---
 CMakeLists.txt            | 19 ++++++++++++++++++-
 src/graphics/Renderer.cpp | 15 ++++++++++++++-
 2 files changed, 32 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index f9df7d2..6d7ef41 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -56,7 +56,17 @@ find_package(SDL2 REQUIRED)
 ENDIF()
 find_package(SDL2_mixer REQUIRED)
 find_package(SDL2_image REQUIRED)
-find_package(PNG REQUIRED)
+# PNG dropped on DJGPP / DOS: src/graphics/pngfuncs.cpp uses raw libpng for
+# screenshot save (Renderer::saveScreenshot, F9 binding). The doskutsu DOS
+# sysroot doesn't ship libpng/zlib, and on the target hardware the in-game
+# screenshot feature is near-zero-value (real-HW players have no DOS-stdlib
+# screenshot use case; DOSBox-X testing captures host-side via scrot).
+# Vita / Switch / Linux / macOS / Windows-native still get the feature.
+if(CMAKE_SYSTEM_NAME STREQUAL "MSDOS" OR CMAKE_CXX_COMPILER MATCHES "msdosdjgpp")
+    message(STATUS "DJGPP/DOS build: skipping libpng (screenshot save disabled)")
+else()
+    find_package(PNG REQUIRED)
+endif()
 # JPEG dropped: Cave Story ships no .jpg assets (verified in #27 audit) and
 # SDL2_image/SDL3_image is built without JPEG support in the doskutsu pipeline.
 # Removing the find_package call avoids a hard dependency on libjpeg in the
@@ -76,6 +86,13 @@ file(GLOB CM_SOURCES "src/common/[a-zA-Z]*.cpp")
 file(GLOB UT_SOURCES "src/Utils/[a-zA-Z]*.cpp")
 file(GLOB EG_SOURCES "src/endgame/[a-zA-Z]*.cpp")
 file(GLOB GR_SOURCES "src/graphics/[a-zA-Z]*.cpp")
+# pngfuncs.cpp uses raw libpng (#include <png.h>) and is unbuildable on the
+# DJGPP cross-toolchain without libpng/zlib in the sysroot. Drop it from the
+# DOS source list; saveScreenshot is correspondingly stubbed in Renderer.cpp
+# under the same NXE_DOS guard.
+if(CMAKE_SYSTEM_NAME STREQUAL "MSDOS" OR CMAKE_CXX_COMPILER MATCHES "msdosdjgpp")
+    list(REMOVE_ITEM GR_SOURCES "${nx_SOURCE_DIR}/src/graphics/pngfuncs.cpp")
+endif()
 file(GLOB IN_SOURCES "src/intro/[a-zA-Z]*.cpp")
 file(GLOB PA_SOURCES "src/pause/[a-zA-Z]*.cpp")
 file(GLOB SL_SOURCES "src/siflib/[a-zA-Z]*.cpp")
diff --git a/src/graphics/Renderer.cpp b/src/graphics/Renderer.cpp
index d621e90..c997e85 100644
--- a/src/graphics/Renderer.cpp
+++ b/src/graphics/Renderer.cpp
@@ -10,7 +10,9 @@
 #include "../version.h"
 #include "Renderer.h"
 #include "nx_icon.h"
-#include "pngfuncs.h"
+#ifndef NXE_DOS
+#  include "pngfuncs.h"
+#endif
 #include "../Utils/Logger.h"
 
 #include <SDL.h>
@@ -556,6 +558,16 @@ void Renderer::clipScaled(SDL_Rect &srcrect, SDL_Rect &dstrect)
 
 void Renderer::saveScreenshot()
 {
+#ifdef NXE_DOS
+  // Screenshot save is disabled on the DJGPP / DOS build: the underlying
+  // pngfuncs.cpp implementation pulls in libpng/zlib, which aren't in the
+  // doskutsu sysroot. Real-HW DOS players have no canonical in-game
+  // screenshot use case, and DOSBox-X testing can capture host-side via
+  // scrot. The F9 keybind still fires this function so the user gets a
+  // log line rather than silent ignore.
+  LOG_WARN("saveScreenshot: not supported on DOS build (libpng unavailable)");
+  return;
+#else
   auto filename = []()
   {
     int iter = 0;
@@ -613,6 +625,7 @@ void Renderer::saveScreenshot()
   SDL_FreeSurface(surface);
   LOG_INFO("Saved {}", filename);
   return;
+#endif // NXE_DOS
 }
 
 void Renderer::drawSpotLight(int x, int y, Object* o, int r, int g, int b, int upscale)
