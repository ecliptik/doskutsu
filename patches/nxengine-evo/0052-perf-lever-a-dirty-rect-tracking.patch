+// DOS-PORT (patch 0052, Phase 9 wave 9 Lever A): hot-path skip check.
+// Returns true when the same-index drawcall in the previous frame had
+// the same hash and no earlier call in this frame has diverged. The
+// caller takes that as a license to skip the actual blit; the back-
+// buffer pixels in the destination region are already correct from
+// last frame.
+//
+// _current_frame_calls grows monotonically so its current size doubles
+// as the call_index. We always push a fingerprint, regardless of the
+// match outcome, so swap-on-flip keeps frame N's history precisely
+// aligned with frame N+1's lookups.
+bool Renderer::_check_skip_drawcall(std::uint64_t hash,
+                                    int dst_x, int dst_y, int dst_w, int dst_h)
+{
+  const int call_index = (int)_current_frame_calls.size();
+  DrawcallFingerprint fp;
+  fp.hash = hash;
+  fp.dst_x = dst_x;
+  fp.dst_y = dst_y;
+  fp.dst_w = dst_w;
+  fp.dst_h = dst_h;
+  _current_frame_calls.push_back(fp);
+
+  // Master kill switch — env var SDL_HINT_DOSKUTSU_DIRTY_RECTS=0 turns
+  // the optimization off. Decided once at init() time, cached on the
+  // instance.
+  if (!_dirty_rect_enabled) return false;
+  if (_force_full_refresh) return false;
+  if (_first_diverging_call >= 0) return false;
+  if (call_index >= (int)_last_frame_calls.size())
+  {
+    // Drawcall count grew vs last frame — call has no peer to compare
+    // against. Mark divergence here.
+    _first_diverging_call = call_index;
+    return false;
+  }
+  if (_last_frame_calls[(size_t)call_index].hash != hash)
+  {
+    _first_diverging_call = call_index;
+    return false;
+  }
+  // Match. Skip the blit.
+  return true;
+}
+
+void Renderer::_record_dirty_rect(int dst_x, int dst_y, int dst_w, int dst_h)
+{
+  if (!_dirty_rect_enabled) return;
+  if (dst_w <= 0 || dst_h <= 0) return;
+  // Clip to 320x240 logical viewport. Out-of-bounds rects from
+  // off-screen sprites become empty and are dropped.
+  if (dst_x < 0) { dst_w += dst_x; dst_x = 0; }
+  if (dst_y < 0) { dst_h += dst_y; dst_y = 0; }
+  if (dst_x + dst_w > screenWidth)  dst_w = screenWidth  - dst_x;
+  if (dst_y + dst_h > screenHeight) dst_h = screenHeight - dst_y;
+  if (dst_w <= 0 || dst_h <= 0) return;
+  // Cheap coalesce: if this rect is identical to the previous one we
+  // pushed, skip the duplicate. Real coalescing is left to the SDL
+  // side (SDL_UpdateWindowSurfaceRects iterates the list anyway).
+  if (!_dirty_rects.empty())
+  {
+    const SDL_Rect &prev = _dirty_rects.back();
+    if (prev.x == dst_x && prev.y == dst_y && prev.w == dst_w && prev.h == dst_h)
+      return;
+  }
+  SDL_Rect r{dst_x, dst_y, dst_w, dst_h};
+  _dirty_rects.push_back(r);
+}
