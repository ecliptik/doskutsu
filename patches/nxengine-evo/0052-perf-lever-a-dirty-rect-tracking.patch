+// DOS-PORT (patch 0052, Phase 9 wave 9 Lever A): drawcall-fingerprint
+// helpers. The hash function is FNV-1a 64-bit on a fixed-shape header
+// of (op_type, surface_id, srcx, srcy, srcw, srch, dstx, dsty, dstw,
+// dsth, alpha, extra) packed into 12 uint64s. Op-specific extra slot
+// carries the line endpoints / fill color / mirror axis so distinct
+// op types with the same coords don't collide.
+//
+// FNV-1a constants are the standard 64-bit set.
+constexpr std::uint64_t FNV_1A_OFFSET = 0xcbf29ce484222325ull;
+constexpr std::uint64_t FNV_1A_PRIME  = 0x100000001b3ull;
+
+inline std::uint64_t _fnv_step(std::uint64_t h, std::uint64_t v)
+{
+  // Fold v's 8 bytes one at a time. Stable across endianness.
+  for (int i = 0; i < 8; ++i)
+  {
+    h ^= (v & 0xFFu);
+    h *= FNV_1A_PRIME;
+    v >>= 8;
+  }
+  return h;
+}
+
+// Op-type tags. Each goes into the hash so a 16x16 drawSurface and a
+// 16x16 drawSurfaceMirrored at the same coords don't collide.
+enum DrawcallOp : std::uint64_t {
+  OP_DRAW_SURFACE          = 0x01,
+  OP_DRAW_SURFACE_MIRRORED = 0x02,
+  OP_BLIT_PATTERN_ACROSS   = 0x03,
+  OP_DRAW_LINE             = 0x04,
+  OP_DRAW_RECT             = 0x05,
+  OP_FILL_RECT             = 0x06,
+  OP_TINT_SCREEN           = 0x07,
+  OP_DRAW_PIXEL            = 0x08,
+  OP_DRAW_SPOTLIGHT        = 0x09,
+  OP_CLEAR_SCREEN          = 0x0A,
+};
+
+// Compose the per-drawcall hash. Slot order is fixed; absent fields
+// fold zero so we can hash all op types through one entry point.
+inline std::uint64_t _hash_drawcall(std::uint64_t op,
+                                    std::uintptr_t surface_id,
+                                    int srcx, int srcy, int srcw, int srch,
+                                    int dstx, int dsty, int dstw, int dsth,
+                                    std::uint32_t alpha,
+                                    std::uint64_t extra)
+{
+  std::uint64_t h = FNV_1A_OFFSET;
+  h = _fnv_step(h, op);
+  h = _fnv_step(h, (std::uint64_t)surface_id);
+  h = _fnv_step(h, (std::uint64_t)(std::uint32_t)srcx);
+  h = _fnv_step(h, (std::uint64_t)(std::uint32_t)srcy);
+  h = _fnv_step(h, (std::uint64_t)(std::uint32_t)srcw);
+  h = _fnv_step(h, (std::uint64_t)(std::uint32_t)srch);
+  h = _fnv_step(h, (std::uint64_t)(std::uint32_t)dstx);
+  h = _fnv_step(h, (std::uint64_t)(std::uint32_t)dsty);
+  h = _fnv_step(h, (std::uint64_t)(std::uint32_t)dstw);
+  h = _fnv_step(h, (std::uint64_t)(std::uint32_t)dsth);
+  h = _fnv_step(h, (std::uint64_t)alpha);
+  h = _fnv_step(h, extra);
+  return h;
+}
+
+// Per-drawcall log throttle for the first-frame DEBUG.LOG diagnostics.
+// Mostly useful when chasing skip-rate regressions.
+int _dr_dbg_first_n_logged = 0;
