+// DOS-PORT (patch 0059, Phase 9 wave 12.5 Lever B): alpha-blend RGB565
+// blit primitive — the alpha<255 sibling of _blit_rgb565. Per architect
+// design memo §4: per-pixel `(src*alpha + dst*(255-alpha)) >> 8` (the
+// `>> 8` divisor approximates `/255` with a 0.4% rounding error,
+// invisible at 5/6/5 quantization).
+//
+// ~22 integer ops/pixel — about 2x the no-blend path. For typical
+// alpha-mod sites (menu fade-in, ~80x80 dialog box = 6400 px) this is
+// ~1.7 ms per call on PODP. Full-screen tintScreen-equivalents are
+// ~20 ms (handled separately in 12.6).
+//
+// Same dst-clip pattern as `_blit_rgb565`. Two inner-loop branches on
+// `has_colorkey`:
+//   - has_colorkey=false: blend every pixel
+//   - has_colorkey=true: skip colorkey pixels, blend the rest
+static inline bool _blit_rgb565_alpha(SDL_Surface *dst, SDL_Surface *src,
+                                      SDL_Rect srcrect, SDL_Rect dstrect,
+                                      Uint16 colorkey, bool has_colorkey,
+                                      Uint8 alpha)
+{
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sx = srcrect.x;
+  int sy = srcrect.y;
+  int rows = srcrect.h;
+  int cols = srcrect.w;
+
+  if (dst_x < 0) { cols += dst_x; sx -= dst_x; dst_x = 0; }
+  if (dst_y < 0) { rows += dst_y; sy -= dst_y; dst_y = 0; }
+  if (dst_x + cols > dst->w) cols = dst->w - dst_x;
+  if (dst_y + rows > dst->h) rows = dst->h - dst_y;
+
+  if (rows <= 0 || cols <= 0) return true;
+
+  const int src_pitch_pixels = src->pitch / 2;
+  const int dst_pitch_pixels = dst->pitch / 2;
+
+  const Uint16 *sp = (const Uint16 *)src->pixels + sy * src_pitch_pixels + sx;
+  Uint16 *dp = (Uint16 *)dst->pixels + dst_y * dst_pitch_pixels + dst_x;
+
+  const int inv = 255 - (int)alpha;
+
+  for (int row = 0; row < rows; ++row)
+  {
+    for (int col = 0; col < cols; ++col)
+    {
+      const Uint16 spx = sp[col];
+      if (has_colorkey && spx == colorkey) continue;
+
+      // Unpack src 5/6/5 → 8/8/8 (replicate top bits for cheap fidelity).
+      const int sr5 = (spx >> 11) & 0x1F;
+      const int sg6 = (spx >>  5) & 0x3F;
+      const int sb5 =  spx        & 0x1F;
+      const int sr8 = (sr5 << 3) | (sr5 >> 2);
+      const int sg8 = (sg6 << 2) | (sg6 >> 4);
+      const int sb8 = (sb5 << 3) | (sb5 >> 2);
+
+      const Uint16 dpx = dp[col];
+      const int dr5 = (dpx >> 11) & 0x1F;
+      const int dg6 = (dpx >>  5) & 0x3F;
+      const int db5 =  dpx        & 0x1F;
+      const int dr8 = (dr5 << 3) | (dr5 >> 2);
+      const int dg8 = (dg6 << 2) | (dg6 >> 4);
+      const int db8 = (db5 << 3) | (db5 >> 2);
+
+      const int or8 = (sr8 * (int)alpha + dr8 * inv) >> 8;
+      const int og8 = (sg8 * (int)alpha + dg8 * inv) >> 8;
+      const int ob8 = (sb8 * (int)alpha + db8 * inv) >> 8;
+
+      dp[col] = (Uint16)(((or8 >> 3) << 11) | ((og8 >> 2) << 5) | (ob8 >> 3));
+    }
+    sp += src_pitch_pixels;
+    dp += dst_pitch_pixels;
+  }
+
+  return true;
+}
+
+// DOS-PORT (patch 0059, Phase 9 wave 12.5 Lever B): alpha-blend fast-path
+// wrapper. Mirror of `_try_fast_blit` but gates on alpha < 255 (the
+// alpha=255 case stays in `_try_fast_blit`).
+static inline bool _try_fast_blit_alpha(SDL_Renderer *renderer,
+                                        SDL_Surface *win_surface,
+                                        bool &renderer_queue_dirty,
+                                        Surface *src,
+                                        const SDL_Rect &srcrect, const SDL_Rect &dstrect)
+{
+  if (src->alpha == 255) return false;  // 255 path lives in _try_fast_blit
+
+  SDL_Surface *src_surface = src->surface16bpp();
+  if (!src_surface) return false;
+
+  if (!win_surface) return false;
+  if (win_surface->format != SDL_PIXELFORMAT_RGB565) return false;
+  if (win_surface->w != 320 || win_surface->h != 240) return false;
+
+  if (renderer_queue_dirty)
+  {
+    SDL_FlushRenderer(renderer);
+    renderer_queue_dirty = false;
+  }
+
+  return _blit_rgb565_alpha(win_surface, src_surface, srcrect, dstrect,
+                            src->colorkey16(), src->hasColorkey(),
+                            (Uint8)src->alpha);
+}
+
+// DOS-PORT (patch 0059, Phase 9 wave 12.5 Lever B): color-mod RGB565 blit
+// primitive — black branch (mod_r=mod_g=mod_b=0). Every non-colorkey
+// source pixel is written as 0x0000 (RGB565 black). Hot path for Font
+// shadow rendering. Cheaper than the general branch — no multiply, no
+// 5/6/5 ↔ 8/8/8 expansion needed since the output is constant.
+static inline bool _blit_rgb565_color_mod_black(SDL_Surface *dst, SDL_Surface *src,
+                                                SDL_Rect srcrect, SDL_Rect dstrect,
+                                                Uint16 colorkey, bool has_colorkey)
+{
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sx = srcrect.x;
+  int sy = srcrect.y;
+  int rows = srcrect.h;
+  int cols = srcrect.w;
+
+  if (dst_x < 0) { cols += dst_x; sx -= dst_x; dst_x = 0; }
+  if (dst_y < 0) { rows += dst_y; sy -= dst_y; dst_y = 0; }
+  if (dst_x + cols > dst->w) cols = dst->w - dst_x;
+  if (dst_y + rows > dst->h) rows = dst->h - dst_y;
+  if (rows <= 0 || cols <= 0) return true;
+
+  const int src_pitch_pixels = src->pitch / 2;
+  const int dst_pitch_pixels = dst->pitch / 2;
+  const Uint16 *sp = (const Uint16 *)src->pixels + sy * src_pitch_pixels + sx;
+  Uint16 *dp = (Uint16 *)dst->pixels + dst_y * dst_pitch_pixels + dst_x;
+
+  for (int row = 0; row < rows; ++row)
+  {
+    for (int col = 0; col < cols; ++col)
+    {
+      const Uint16 spx = sp[col];
+      if (has_colorkey && spx == colorkey) continue;
+      dp[col] = 0;
+    }
+    sp += src_pitch_pixels;
+    dp += dst_pitch_pixels;
+  }
+  return true;
+}
+
+// DOS-PORT (patch 0059, Phase 9 wave 12.5 Lever B): color-mod RGB565 blit
+// primitive — general branch. Per architect design memo §3: per-pixel
+// per-channel multiply with 5/6/5 ↔ 8/8/8 expansion. ~14 integer ops
+// per pixel. ~35 µs per 13×16 glyph on PODP, ~1 ms total for ~30
+// glyphs/frame on dialog-heavy scenes.
+static inline bool _blit_rgb565_color_mod_general(SDL_Surface *dst, SDL_Surface *src,
+                                                  SDL_Rect srcrect, SDL_Rect dstrect,
+                                                  Uint16 colorkey, bool has_colorkey,
+                                                  Uint8 mod_r, Uint8 mod_g, Uint8 mod_b)
+{
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sx = srcrect.x;
+  int sy = srcrect.y;
+  int rows = srcrect.h;
+  int cols = srcrect.w;
+
+  if (dst_x < 0) { cols += dst_x; sx -= dst_x; dst_x = 0; }
+  if (dst_y < 0) { rows += dst_y; sy -= dst_y; dst_y = 0; }
+  if (dst_x + cols > dst->w) cols = dst->w - dst_x;
+  if (dst_y + rows > dst->h) rows = dst->h - dst_y;
+  if (rows <= 0 || cols <= 0) return true;
+
+  const int src_pitch_pixels = src->pitch / 2;
+  const int dst_pitch_pixels = dst->pitch / 2;
+  const Uint16 *sp = (const Uint16 *)src->pixels + sy * src_pitch_pixels + sx;
+  Uint16 *dp = (Uint16 *)dst->pixels + dst_y * dst_pitch_pixels + dst_x;
+
+  for (int row = 0; row < rows; ++row)
+  {
+    for (int col = 0; col < cols; ++col)
+    {
+      const Uint16 spx = sp[col];
+      if (has_colorkey && spx == colorkey) continue;
+
+      const int sr5 = (spx >> 11) & 0x1F;
+      const int sg6 = (spx >>  5) & 0x3F;
+      const int sb5 =  spx        & 0x1F;
+      const int sr8 = (sr5 << 3) | (sr5 >> 2);
+      const int sg8 = (sg6 << 2) | (sg6 >> 4);
+      const int sb8 = (sb5 << 3) | (sb5 >> 2);
+
+      const int rr8 = (sr8 * (int)mod_r) >> 8;
+      const int rg8 = (sg8 * (int)mod_g) >> 8;
+      const int rb8 = (sb8 * (int)mod_b) >> 8;
+
+      dp[col] = (Uint16)(((rr8 >> 3) << 11) | ((rg8 >> 2) << 5) | (rb8 >> 3));
+    }
+    sp += src_pitch_pixels;
+    dp += dst_pitch_pixels;
+  }
+  return true;
+}
+
 // blit the specified portion of the surface to the screen
 void Renderer::drawSurface(Surface *src, int dstx, int dsty, int srcx, int srcy, int wd, int ht)
 {
@@ -1679,6 +1932,34 @@ void Renderer::drawSurface(Surface *src, int dstx, int dsty, int srcx, int srcy,
   ++_fastpath_skipped_block;
   ++_fastpath_skipped_global;
 
+  // DOS-PORT (patch 0059, Phase 9 wave 12.5 Lever B): alpha<255 fast
+  // path. The opaque-fast-path missed; if the only reason is alpha<255
+  // (other gates would still pass), take the hand-rolled alpha-blend
+  // path. This covers the majority of menu/dialog drawcalls per the
+  // 12.3-D slow-path reason histogram which showed alpha-mod dominates
+  // menu inter-flip cost. Falls through on Mach64 / format mismatch /
+  // null src to the existing SDL_RenderTexture path.
+  if (_try_fast_blit_alpha(_renderer, _cached_window_surface,
+                           _renderer_queue_dirty,
+                           src, srcrect, dstrect))
+  {
+    ++_fastpath_alpha_taken_block;
+    ++_fastpath_alpha_taken_global;
+    _bump_drawcall();
+    _record_dirty_rect(dstrect.x, dstrect.y, dstrect.w, dstrect.h);
+    return;
+  }
+  // Skipped counter only bumps when alpha<255 (otherwise the alpha
+  // wrapper returned false on its first gate; not interesting). This
+  // makes alpha_taken+alpha_skipped == count of alpha<255 calls that
+  // went through drawSurface — directly comparable to slow-path's
+  // alpha bucket.
