+// DOS-PORT (patch 0059, Phase 9 wave 12.5 Lever B): adopt an already-loaded
+// SDL_Surface, applying the same RGB565+colorkey treatment as loadImage.
+// Used by Font::load to convert IMG_Load PNG output into a Surface that
+// the hand-rolled Lever B blit primitives can consume.
+bool Surface::loadFromSDLSurface(SDL_Surface *src, bool flatten_alpha_to_colorkey)
+{
+  cleanup();
+  if (!src)
+  {
+    LOG_ERROR("Surface::loadFromSDLSurface: src is NULL");
+    return false;
+  }
+
+  _width  = src->w * Renderer::getInstance()->scale;
+  _height = src->h * Renderer::getInstance()->scale;
+
+  SDL_Surface *image_scaled = SDL_ZoomSurface(src, Renderer::getInstance()->scale);
+  if (!image_scaled)
+  {
+    LOG_ERROR("Surface::loadFromSDLSurface: SDL_ZoomSurface failed: {}", SDL_GetError());
+    return false;
+  }
+
+  // If the source has alpha and the caller asked for flatten-to-colorkey,
+  // walk the pixels and remap alpha=0 to magenta. Then set the surface
+  // colorkey to magenta so SDL_ConvertSurface preserves it through the
+  // RGB565 conversion. We normalize to RGBA32 first so the per-pixel
+  // walk has a consistent layout.
+  if (flatten_alpha_to_colorkey)
+  {
+    SDL_Surface *rgba = SDL_ConvertSurface(image_scaled, SDL_PIXELFORMAT_RGBA32);
+    SDL_DestroySurface(image_scaled);
+    if (!rgba)
+    {
+      LOG_ERROR("Surface::loadFromSDLSurface: SDL_ConvertSurface to RGBA32 failed: {}", SDL_GetError());
+      return false;
+    }
+    Uint8 *p = (Uint8 *)rgba->pixels;
+    const int row_pixels = rgba->pitch / 4;
+    for (int y = 0; y < rgba->h; ++y)
+    {
+      Uint8 *row = p + y * rgba->pitch;
+      for (int x = 0; x < row_pixels; ++x)
+      {
+        if (row[x * 4 + 3] == 0)
+        {
+          row[x * 4 + 0] = 0xFF;  // R
+          row[x * 4 + 1] = 0x00;  // G
+          row[x * 4 + 2] = 0xFF;  // B
+        }
+      }
+    }
+    SDL_SetSurfaceColorKey(rgba, true, SDL_MapSurfaceRGB(rgba, 0xFF, 0x00, 0xFF));
+    image_scaled = rgba;
+  }
+
+  SDL_Surface *image_rgb565 = SDL_ConvertSurface(image_scaled, SDL_PIXELFORMAT_RGB565);
+  SDL_DestroySurface(image_scaled);
+
+  if (!image_rgb565)
+  {
+    LOG_ERROR("Surface::loadFromSDLSurface: SDL_ConvertSurface to RGB565 failed: {}", SDL_GetError());
+    return false;
+  }
+
+  // Re-assert the colorkey on the RGB565 surface — same belt-and-braces
+  // pattern as loadImage. Magenta in RGB565 = 0xF81F.
+  if (flatten_alpha_to_colorkey)
+  {
+    SDL_SetSurfaceColorKey(image_rgb565, true, SDL_MapSurfaceRGB(image_rgb565, 0xFF, 0x00, 0xFF));
+  }
+
+  _texture = SDL_CreateTextureFromSurface(Renderer::getInstance()->renderer(), image_rgb565);
+  if (!_texture)
+  {
+    LOG_ERROR("Surface::loadFromSDLSurface: SDL_CreateTextureFromSurface failed: {}", SDL_GetError());
+    SDL_DestroySurface(image_rgb565);
+    return false;
+  }
+
+  _surface_rgb565 = image_rgb565;
+  Uint32 ck = 0;
+  if (SDL_GetSurfaceColorKey(image_rgb565, &ck))
+  {
+    _has_colorkey = true;
+    _colorkey16 = (Uint16)(ck & 0xFFFFu);
+  }
+  else
+  {
+    _has_colorkey = false;
+    _colorkey16 = 0;
+  }
+  return true;
+}
