---
 src/sound/Organya.cpp | 57 +++++++++++++++++++++++++++++++++++++++++--
 1 file changed, 55 insertions(+), 2 deletions(-)

diff --git a/src/sound/Organya.cpp b/src/sound/Organya.cpp
index 3f18110..bca66f9 100644
--- a/src/sound/Organya.cpp
+++ b/src/sound/Organya.cpp
@@ -424,7 +424,35 @@ void Organya::_musicCallback(void *udata, uint8_t *stream, uint32_t len)
     return;
   int16_t *str = reinterpret_cast<int16_t *>(stream);
 
+  // DOS-PORT (patch 0094, Phase 9 wave 21 Lever G fix). Bug surfaced
+  // post-W21A real-HW measurement: Tier-2 (AUDIO_CHANNELS=1) audio
+  // played slow + distorted because Song::Synth() ALWAYS produces
+  // stereo-interleaved samples (samples[p*2+0]=L, samples[p*2+1]=R at
+  // lines ~325-326) regardless of the SDL audio device's channel
+  // count. The pre-0094 callback below copied samples[] linearly into
+  // the output stream — for a mono-configured device, this stuffs
+  // L,R,L,R,... into a stream the device interprets as MONO FRAMES, so
+  // playback steps through the synth buffer at HALF the intended rate
+  // (each "frame" of intended stereo = 2 mono frames at the consumer)
+  // → music plays at half speed + sub-Nyquist aliasing distortion.
+  //
+  // Fix: mono branch averages the synth's interleaved L/R pair into a
+  // single mono sample per output frame, advancing the read index by 2
+  // synth entries per output. Stereo branch (Tier-1) preserves the
+  // pre-0094 linear-copy behavior bit-identical.
+  //
+  // The synth itself stays internally-stereo because the per-tone L/R
+  // panning math at lines ~325-326 (`samples[p*2+0] += sample * left`
+  // / `samples[p*2+1] += sample * right`) depends on producing two
+  // independent channels. Mono-downmix at the callback boundary is
+  // the minimum-correctness fix; it loses the stereo separation but
+  // recovers proper playback rate. The fps win from W21A's measurement
+  // (-26.6 ms/flip vs predicted -3 to -22) was inflated by the
+  // half-speed playback artifact (synth's Synth() refilled half as
+  // often per real second). Post-0094 fps gain will fall into the
+  // predicted range — still significant, just not the buggy figure.
   uint32_t idx = song.last_pos;
+  const bool mono_output = (::AUDIO_CHANNELS == 1);
   for (uint32_t i = 0; i < len / 2; i++)
   {
     if (idx >= song.samples.size())
@@ -433,7 +461,33 @@ void Organya::_musicCallback(void *udata, uint8_t *stream, uint32_t len)
       idx = 0;
     }
     // extended range
-    int32_t sample = song.samples[idx] * 32767.0 * volume * (double)(settings->music_volume / 100.);
+    double synth_sample;
+    if (mono_output)
+    {
+      // Tier-2 path: average the synth's interleaved L/R pair into one
+      // mono sample. Each output frame consumes 2 synth entries.
+      // Defensive bounds check on idx+1 — Synth() always produces an
+      // even number of samples (samples_per_beat * 2 at line ~202) so
+      // idx+1 < song.samples.size() is guaranteed when idx is even,
+      // but the size() check above only guards idx < size; if idx
+      // somehow wrapped to an odd number we'd OOB. Belt-and-braces:
+      // re-check before reading the second channel.
+      const float L = song.samples[idx];
+      const float R = (idx + 1 < song.samples.size())
+                        ? song.samples[idx + 1]
+                        : song.samples[idx]; // pathological fallback
+      synth_sample = (L + R) * 0.5;
+      idx += 2;
+    }
+    else
+    {
+      // Tier-1 path: linear copy (pre-0094 behavior). Each output
+      // sample is one synth entry; SDL device interprets pairs as
+      // L/R interleaved frames at 2-channel config.
+      synth_sample = song.samples[idx];
+      idx++;
+    }
+    int32_t sample = synth_sample * 32767.0 * volume * (double)(settings->music_volume / 100.);
     // clip to int16
     if (sample > 32767)
     {
@@ -445,7 +499,6 @@ void Organya::_musicCallback(void *udata, uint8_t *stream, uint32_t len)
     }
 
     str[i] = (int16_t)sample;
-    idx++;
   }
 
   song.last_pos = idx;
