 src/sound/Pixtone.cpp      | 40 ++++++++++++++++++++++++++++++++++++++
 src/sound/Pixtone.h        | 10 ++++++++++
 src/sound/SoundManager.cpp | 13 ++++++-------
 3 files changed, 56 insertions(+), 7 deletions(-)

diff --git a/src/sound/Pixtone.cpp b/src/sound/Pixtone.cpp
index 4e2645a..25b1b46 100644
--- a/src/sound/Pixtone.cpp
+++ b/src/sound/Pixtone.cpp
@@ -383,6 +383,19 @@ int Pixtone::play(int32_t chan, int32_t slot, int32_t loop)
     // DOS-PORT: same track-pool dispatch as playResampled(). chan == -1
     // means "first free track"; chan >= 0 means "use this pool slot,
     // interrupting if busy".
+    //
+    // DOS-PORT: synchronous-callback dependency. MIX_StopTrack on a
+    // currently-playing track may dispatch the per-track stopped-callback
+    // (mySfxCallback → pxtSoundDone) inline before returning, which
+    // resets _sound_fx[old_slot].channel = -1. The subsequent
+    // _sound_fx[slot].channel = chan and _slots[chan] = slot writes
+    // below run AFTER that callback — so the bookkeeping is sequential
+    // and correct on SDL3-DOS's cooperative scheduler. Multi-threaded
+    // SDL3 hosts (Linux/macOS/Windows) would dispatch the callback on
+    // a different thread, theoretically racing this function's writes;
+    // in practice the race is benign (old slot reset to -1 is correct
+    // anyway) but the logic relies on synchronous dispatch for clarity.
+    // See docs/SDL3-MIGRATION.md § 3 for the no-threads invariant.
     if (chan < 0) chan = _findFreeTrack();
     if (chan >= 0)
     {
@@ -407,6 +420,33 @@ int Pixtone::play(int32_t chan, int32_t slot, int32_t loop)
   }
 }
 
+void Pixtone::setVolume(int volume_0_100)
+{
+  // DOS-PORT: SDL2_mixer's Mix_Volume(-1, int_0_128) was a global
+  // "all channels" gain setter. SDL3_mixer's MIX_SetTrackGain is per-
+  // track, so we iterate the pre-allocated pool. Conversion preserves
+  // upstream's effective gain exactly:
+  //
+  //   upstream: Mix_Volume(-1, (int)(128.0/100.0 * sfx_volume_0_100))
+  //             effective gain = (128/100 * vol) / 128 = vol / 100
+  //   ours:     MIX_SetTrackGain(track, vol / 100.0f)
+  //             effective gain = vol / 100
+  //
+  // Same audible level pre and post migration. Audio capture A/B at
+  // the Phase 7 gate stays interpretable.
+  //
+  // Note: NULL pool entries are skipped — Pixtone::init() may have
+  // failed to allocate some tracks (logged at init time but not fatal),
+  // and we don't want a NULL-deref here. _findFreeTrack() does the
+  // same null-check; consistent.
+  const float gain = (float)volume_0_100 / 100.0f;
+  for (int i = 0; i < PIXTONE_TRACK_POOL_SIZE; ++i)
+  {
+    if (_track_pool[i])
+      MIX_SetTrackGain(_track_pool[i], gain);
+  }
+}
+
 int Pixtone::_findFreeTrack()
 {
   // Scan pool for a track that isn't currently playing. Mirrors
diff --git a/src/sound/Pixtone.h b/src/sound/Pixtone.h
index 7731a2a..76a9474 100644
--- a/src/sound/Pixtone.h
+++ b/src/sound/Pixtone.h
@@ -97,6 +97,16 @@ public:
   int prepareResampled(int32_t slot, uint32_t percent);
   void stop(int32_t slot);
 
+  // DOS-PORT: SDL3_mixer's per-track gain API replaces SDL2_mixer's
+  // global Mix_Volume(-1, int_0..128). setVolume iterates the pre-
+  // allocated track pool calling MIX_SetTrackGain. Volume is in 0..100
+  // (matching SoundManager::updateSfxVolume's settings->sfx_volume
+  // input range); converted to SDL3 float gain via volume/100.0f.
+  // The full 0..100 maps to 0..1.0 gain (full SDL3 range), matching
+  // upstream's Mix_Volume(-1, 128/100 * sfx_volume) which fully mapped
+  // 0..100 to 0..128 (full SDL2 range).
+  void setVolume(int volume_0_100);
+
   void pxtSoundDone(int channel);
 
 protected:
diff --git a/src/sound/SoundManager.cpp b/src/sound/SoundManager.cpp
index 43110d6..e120c42 100644
--- a/src/sound/SoundManager.cpp
+++ b/src/sound/SoundManager.cpp
@@ -367,13 +367,12 @@ void SoundManager::resume()
 void SoundManager::updateSfxVolume()
 {
   // DOS-PORT: SDL3_mixer's volume API is per-track or per-tag (group),
-  // not a global "all channels" setter. SDL2's Mix_Volume(-1, int_0_128)
-  // becomes Pixtone iterating its track pool calling
-  // MIX_SetTrackGain(track, float_0_1) — wired in patch 0014. For now
-  // (foundation-only milestone), this is a no-op so audio still plays
-  // at full volume; SFX volume slider is non-functional until 0014.
-  // TODO(0014): Pixtone::getInstance()->setVolume(settings->sfx_volume);
-  (void)settings;
+  // not a global "all channels" setter. Pixtone::setVolume iterates
+  // the 64-track pool calling MIX_SetTrackGain. Conversion to SDL3's
+  // 0..1.0 gain happens inside Pixtone — see Pixtone.cpp comment for
+  // the volume-scale-preservation math. The original 0017 patch
+  // shipped this as a no-op TODO; 0014a wires it through.
+  Pixtone::getInstance()->setVolume(settings->sfx_volume);
 }
 
 void SoundManager::updateMusicVolume()
