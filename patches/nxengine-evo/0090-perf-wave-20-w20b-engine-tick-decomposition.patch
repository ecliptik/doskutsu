+  // Reset per-tick dt locals before bracketing so leftover-from-prior-
+  // tick doesn't pollute the residual computation. Each timer destructor
+  // overwrites its bucket; if a bucket's call doesn't fire this tick
+  // (e.g. tsc_interp on paused branch), the local stays at 0 and the
+  // residual subtraction sees 0 for that bucket.
+  NXE::Diag::g_eng_clear_screen_dt_this_tick   = 0;
+  NXE::Diag::g_eng_tsc_interp_dt_this_tick     = 0;
+  NXE::Diag::g_eng_mode_tick_dt_this_tick      = 0;
+  NXE::Diag::g_eng_debug_overlay_dt_this_tick  = 0;
+  // Capture engine-tick start; used for residual computation at the
+  // very end of this function. Duplicates EngineTickTimer's t0 but
+  // EngineTickTimer's destructor fires at scope-exit — we need the
+  // value here to read once more BEFORE that destructor runs.
+  const Uint64 _engine_tick_t0 = SDL_GetTicksNS();
+
+  {
+    NXE::Diag::ClearScreenTimer _cst;
+    Renderer::getInstance()->clearScreen(BLACK);
+  }
   debug_clear();
 
   if (game.paused)
   {
+    NXE::Diag::ModeTickTimer _mtt;
     tickfunctions[game.paused].OnTick();
   }
   else
   {
     // run scripts
-    tsc->RunScripts();
+    {
+      NXE::Diag::TscInterpTimer _tit;
+      tsc->RunScripts();
+    }
 
     if (justpushed(ESCKEY)
         && (game.mode == GM_NORMAL || game.mode == GM_INVENTORY || game.mode == GM_MAP_SYSTEM || game.mode == GM_ISLAND
@@ -244,11 +275,38 @@ void Game::tick(void)
       game.pause(GP_PAUSED);
     }
     // call the tick function for the current game mode
-    tickfunctions[game.mode].OnTick();
+    {
+      NXE::Diag::ModeTickTimer _mtt;
+      tickfunctions[game.mode].OnTick();
+    }
   }
 
-  DrawDebug();
-  console.Draw();
+  {
+    NXE::Diag::DebugOverlayTimer _dot;
+    DrawDebug();
+    console.Draw();
+  }
+
+  // patch 0090 (wave 20 W20B): compute engine-tick residual. Read total
+  // dt by sampling SDL_GetTicksNS once more here (cheap; same call site
+  // pattern as W20A's _flip_inner_dt_ns). Subtract per-tick dt locals
+  // populated by the 4 sub-bucket timers above. Residual reflects
+  // un-bracketed time inside Game::tick body — debug_clear, the
+  // esc-pause check, branch overhead, and any uncaught small calls.
+  // Signed math + clamp at 0 in case measurement noise produces a
+  // tiny negative.
+  if (NXE::Diag::engine_tick_fine_instr_active()
+      && NXE::Diag::g_eng_residual_idx < NXE::Diag::g_eng_tick_block_size)
+  {
+    const Uint64 _engine_tick_dt = SDL_GetTicksNS() - _engine_tick_t0;
+    Sint64 _res = (Sint64)_engine_tick_dt
+                - (Sint64)NXE::Diag::g_eng_clear_screen_dt_this_tick
+                - (Sint64)NXE::Diag::g_eng_tsc_interp_dt_this_tick
+                - (Sint64)NXE::Diag::g_eng_mode_tick_dt_this_tick
+                - (Sint64)NXE::Diag::g_eng_debug_overlay_dt_this_tick;
+    if (_res < 0) _res = 0;
+    NXE::Diag::g_eng_residual_samples[NXE::Diag::g_eng_residual_idx++] = (Uint64)_res;
+  }
 }
 
