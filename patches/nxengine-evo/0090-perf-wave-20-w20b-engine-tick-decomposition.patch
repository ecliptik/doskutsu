 // drawSurface NULL-texture diagnostic (Phase 7 black-screen bug, task #14).
 // Track which Surface objects produce NULL textures so we log each origin
 // once + a periodic running count, instead of hundreds of identical lines
@@ -1078,6 +1126,81 @@ void _maybe_flush_phase_timing_audit()
   // brackets. Sample-array contents are overwritten on next firing.
   _flip_phase_idx_pp = 0;
   _flip_phase_idx_gg = 0;
+  // patch 0090 (wave 20 W20B): engine-tick decomposition emit + reset.
+  // Gated on FINE_INSTR (separate from FLIP_INSTR per flush-instr's
+  // contract). 4 sub-bracket stat lines + 1 derived residual line.
+  // Output prefix `engine-tick-stat` distinct from W20A's `flip-stat`
+  // and the parked W20B-flip-body's `flip-fine-stat` so grep tooling
+  // can separate the three layers without ambiguity.
+  if (_abl_fine_instr() && NXE::Diag::g_eng_residual_idx > 0)
+  {
+    using NXE::Diag::g_eng_clear_screen_samples;
+    using NXE::Diag::g_eng_tsc_interp_samples;
+    using NXE::Diag::g_eng_mode_tick_samples;
+    using NXE::Diag::g_eng_debug_overlay_samples;
+    using NXE::Diag::g_eng_residual_samples;
