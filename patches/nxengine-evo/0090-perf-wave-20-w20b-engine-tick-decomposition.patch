+// DOS-PORT (patch 0090, Phase 9 wave 20 W20B engine-tick decomposition):
+// 4 sub-bracket RAII timers + residual derivation. Decomposes the
+// 17.8 ms (audio-off) / 21.1 ms (audio-on) engine_tick budget into
+// named sub-buckets so we can identify what work lives in there
+// independently of audio IRQ cost (the ~3.3 ms audio-IRQ-in-tick
+// component is captured by the audio-off vs audio-on delta on the
+// existing engine_tick_total measurement).
+//
+// Gated on the wave-20 W20B SDL_HINT_DOSKUTSU_FINE_INSTR=1 env var.
+// `engine_tick_fine_instr_active()` is a forward-declared accessor
+// (definition in Renderer.cpp where the env-helper cluster lives).
+// Cached static-const-bool semantics so -O2 hoists the per-tick guards.
+//
+// Sub-buckets (sibling, non-overlapping inside Game::tick scope):
+//   ClearScreenTimer   - Renderer::clearScreen(BLACK) at game.cpp:228
+//   TscInterpTimer     - tsc->RunScripts() at game.cpp:238 (only fires
+//                        when !game.paused; n=actual_count)
+//   ModeTickTimer      - tickfunctions[].OnTick() at game.cpp:233/247
+//                        (one-or-other branch always fires; n=100)
+//   DebugOverlayTimer  - DrawDebug() + console.Draw() lumped at
+//                        game.cpp:250-251
+//
+// Residual = engine_tick_total - sum(sub-buckets), clamped at 0,
+// computed at end-of-Game::tick by reading SDL_GetTicksNS() once more.
+// Self-validating: small residual (<1 ms median) means brackets are
+// exhaustive; large residual means there's still an unfound chunk in
+// Game::tick body (likely the small calls debug_clear / esc-pause check
+// / branch overhead, or — surprise — something we didn't anticipate).
+//
+// Storage: 4 sample arrays + idxes + per-tick dt locals + 1 residual
+// array + idx, all extern-declared here, defined in Renderer.cpp where
+// the per-100-flip audit-flush lives.
+//
+// Forward-declare the env helper. Definition lives in Renderer.cpp's
+// ablation-flag cluster (alongside _abl_flip_instr / _abl_fine_instr /
+// _abl_direct_vesa). Capturing as a free function lets this header
+// stay decoupled from the Renderer class.
+bool engine_tick_fine_instr_active();
+
+// Sample-array storage (extern; defined in Renderer.cpp). Sized at 100
+// to match the existing _flip_phase_block_size cadence.
+constexpr int g_eng_tick_block_size = 100;
+extern std::uint64_t g_eng_clear_screen_samples[g_eng_tick_block_size];
+extern std::uint64_t g_eng_tsc_interp_samples[g_eng_tick_block_size];
+extern std::uint64_t g_eng_mode_tick_samples[g_eng_tick_block_size];
+extern std::uint64_t g_eng_debug_overlay_samples[g_eng_tick_block_size];
+extern std::uint64_t g_eng_residual_samples[g_eng_tick_block_size];
+extern int g_eng_clear_screen_idx;
+extern int g_eng_tsc_interp_idx;
+extern int g_eng_mode_tick_idx;
+extern int g_eng_debug_overlay_idx;
+extern int g_eng_residual_idx;
+
+// Per-tick dt locals — written by each timer's destructor, consumed by
+// the residual computation at end-of-Game::tick. Reset by caller at
+// Game::tick entry (so leftover-from-prior-tick doesn't pollute).
+extern std::uint64_t g_eng_clear_screen_dt_this_tick;
+extern std::uint64_t g_eng_tsc_interp_dt_this_tick;
+extern std::uint64_t g_eng_mode_tick_dt_this_tick;
+extern std::uint64_t g_eng_debug_overlay_dt_this_tick;
+
+// Sub-bucket RAII timers. Destructor pattern: capture dt, write to
+// per-tick local, push to sample array (with bounds-check + env gate).
+// Cost when env unset: 1 SDL_GetTicksNS at construction (always) +
+// 1 at destruction + 1 branch-on-cached-bool. Mirrors existing
+// EngineTickTimer pattern; -O2 should fold the env-off path tightly.
+struct ClearScreenTimer
+{
+  std::uint64_t t0;
+  ClearScreenTimer() : t0(SDL_GetTicksNS()) {}
+  ~ClearScreenTimer()
+  {
+    if (!engine_tick_fine_instr_active()) return;
+    const std::uint64_t dt = SDL_GetTicksNS() - t0;
+    g_eng_clear_screen_dt_this_tick = dt;
+    if (g_eng_clear_screen_idx < g_eng_tick_block_size)
+      g_eng_clear_screen_samples[g_eng_clear_screen_idx++] = dt;
+  }
+};
+
+struct TscInterpTimer
+{
+  std::uint64_t t0;
+  TscInterpTimer() : t0(SDL_GetTicksNS()) {}
+  ~TscInterpTimer()
+  {
+    if (!engine_tick_fine_instr_active()) return;
+    const std::uint64_t dt = SDL_GetTicksNS() - t0;
+    g_eng_tsc_interp_dt_this_tick = dt;
+    if (g_eng_tsc_interp_idx < g_eng_tick_block_size)
+      g_eng_tsc_interp_samples[g_eng_tsc_interp_idx++] = dt;
+  }
+};
+
+struct ModeTickTimer
+{
+  std::uint64_t t0;
+  ModeTickTimer() : t0(SDL_GetTicksNS()) {}
+  ~ModeTickTimer()
+  {
+    if (!engine_tick_fine_instr_active()) return;
+    const std::uint64_t dt = SDL_GetTicksNS() - t0;
+    g_eng_mode_tick_dt_this_tick = dt;
+    if (g_eng_mode_tick_idx < g_eng_tick_block_size)
+      g_eng_mode_tick_samples[g_eng_mode_tick_idx++] = dt;
+  }
+};
+
+struct DebugOverlayTimer
+{
+  std::uint64_t t0;
+  DebugOverlayTimer() : t0(SDL_GetTicksNS()) {}
+  ~DebugOverlayTimer()
+  {
+    if (!engine_tick_fine_instr_active()) return;
+    const std::uint64_t dt = SDL_GetTicksNS() - t0;
+    g_eng_debug_overlay_dt_this_tick = dt;
+    if (g_eng_debug_overlay_idx < g_eng_tick_block_size)
+      g_eng_debug_overlay_samples[g_eng_debug_overlay_idx++] = dt;
+  }
+};
+
 }  // namespace Diag
 }  // namespace NXE
 
