+// DOSKUTSU patch 0048 (Phase 9 wave 6 Lever 2 Approach B) — hand-rolled
+// 16×16 RGB565 colorkey blit fast path. Bypasses SDL_RenderTexture's
+// per-call validation/queue/dispatch overhead (~0.95 ms per call on
+// real Cirrus per the wave-5 cirrus5 capture).
+//
+// Returns true on success (caller skips slow path), false if conditions
+// don't match (caller falls through to the SDL_RenderTexture path).
+//
+// Conditions for the fast path:
+//   - src->surface16bpp() != NULL (Surface has the cached RGB565 surface)
+//   - src->alpha == 255 (no per-pixel alpha modulation needed; alpha-mod
+//     drawcalls fall through so the renderer's alpha-mod plumbing
+//     handles them correctly)
+//   - srcrect.w == 16 AND srcrect.h == 16 (the dominant case per wave-5
+//     drawcall logs — ~95% of drawSurface calls are 16×16 tile blits)
+//   - dstrect.w == srcrect.w AND dstrect.h == srcrect.h (no scaling)
+//   - window surface format == SDL_PIXELFORMAT_RGB565 (the active mode
+//     after patches 0041 + 0045; matches the Surface's RGB565 format)
+//   - window surface dimensions == 320×240 logical (no logical-
+//     presentation letterboxing — true on Cirrus + PIN_WINDOW_TO_NATIVE,
+//     false on Mach64 / 640×480; Mach64 falls through to slow path which
+//     remains the only correct option until we bypass logical-
+//     presentation entirely)
+//
+// Ordering correctness with the SW renderer's queue:
+//
+//   The SW renderer (SDL_render_sw.c §60-80) writes to data->surface,
+//   which is set to the window surface returned by SDL_GetWindowSurface.
+//   So `window->surface` == `renderer's data->surface`, and any
+//   slow-path drawcall queued by SDL_RenderTexture eventually lands on
+//   the same surface this fast path writes to.
+//
+//   To preserve z-order = call-order, the fast path calls
+//   SDL_FlushRenderer FIRST. This drains any queued slow-path commands
+//   to window->surface before we overlay our direct write. When the
+//   queue is empty (the common case after a sequence of fast-path calls),
+//   FlushRenderCommands early-returns at SDL_render.c §343 — essentially
+//   free.
+//
+//   The reverse case (fast-path call followed by slow-path call) is
+//   automatically correct: slow-path runs through SDL_RenderTexture
+//   which queues a command, executed later when SDL_FlushRenderer is
+//   called or SDL_RenderPresent fires. Either way the slow-path output
+//   composites on top of fast-path output exactly as it would if both
+//   went through the renderer.
+static inline bool _try_fast_blit_16x16(SDL_Renderer *renderer, SDL_Window *window,
+                                        Surface *src, int srcx, int srcy,
+                                        const SDL_Rect &srcrect, const SDL_Rect &dstrect)
+{
+  // Cheap precondition gates first.
+  if (src->alpha != 255)
+    return false;
+  if (srcrect.w != 16 || srcrect.h != 16)
+    return false;
+  if (dstrect.w != srcrect.w || dstrect.h != srcrect.h)
+    return false;
+
+  SDL_Surface *src_surface = src->surface16bpp();
+  if (!src_surface)
+    return false;
+
+  SDL_Surface *win_surface = SDL_GetWindowSurface(window);
+  if (!win_surface)
+    return false;
+
+  // Format gate: the source surface is always RGB565 (built by patch
+  // 0047), so the only thing to check is the destination format.
+  if (win_surface->format != SDL_PIXELFORMAT_RGB565)
+    return false;
+
+  // Logical-presentation gate: with letterboxing, dst coords need
+  // scaling/translating from 320x240 logical to the window surface
+  // dimensions. The simple "if window is 320x240 the math is identity"
+  // check covers the Cirrus + PIN_WINDOW_TO_NATIVE path. Mach64 with
+  // 640x480 window falls through here.
+  if (win_surface->w != 320 || win_surface->h != 240)
+    return false;
+
+  // Compute clipped dst extents. dst may legitimately be slightly off-
+  // screen for sprites near the edges (player/enemies at the boundaries
+  // of the playfield). Clip to win bounds before the inner loop.
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sx = srcrect.x;
+  int sy = srcrect.y;
+  int rows = 16;
+  int cols = 16;
+
+  if (dst_x < 0)
+  {
+    cols += dst_x; // dst_x is negative; cols shrinks by |dst_x|
+    sx -= dst_x;   // advance into source
+    dst_x = 0;
+  }
+  if (dst_y < 0)
+  {
+    rows += dst_y;
+    sy -= dst_y;
+    dst_y = 0;
+  }
+  if (dst_x + cols > win_surface->w)
+    cols = win_surface->w - dst_x;
+  if (dst_y + rows > win_surface->h)
+    rows = win_surface->h - dst_y;
+
+  if (rows <= 0 || cols <= 0)
+  {
+    // Wholly off-screen — succeed with no work. The SDL_RenderTexture
+    // path would have done the same.
+    return true;
+  }
+
+  // Drain any queued slow-path commands so our overlay lands AFTER
+  // them. Empty-queue path is essentially free (early-return at
+  // FlushRenderCommands SDL_render.c §343).
+  SDL_FlushRenderer(renderer);
+
+  // Pixel pitch in 16-bit elements.
+  const int src_pitch_pixels = src_surface->pitch / 2;
+  const int win_pitch_pixels = win_surface->pitch / 2;
+
+  const Uint16 *sp = (const Uint16 *)src_surface->pixels + sy * src_pitch_pixels + sx;
+  Uint16 *dp = (Uint16 *)win_surface->pixels + dst_y * win_pitch_pixels + dst_x;
+
+  if (src->hasColorkey())
+  {
+    const Uint16 ck = src->colorkey16();
+    for (int row = 0; row < rows; ++row)
+    {
+      for (int col = 0; col < cols; ++col)
+      {
+        const Uint16 px = sp[col];
+        if (px != ck) dp[col] = px;
+      }
+      sp += src_pitch_pixels;
+      dp += win_pitch_pixels;
+    }
+  }
+  else
+  {
+    // No colorkey: a straight memcpy per row beats the inner branch.
+    const size_t bytes = (size_t)cols * 2;
+    for (int row = 0; row < rows; ++row)
+    {
+      SDL_memcpy(dp, sp, bytes);
+      sp += src_pitch_pixels;
+      dp += win_pitch_pixels;
+    }
+  }
+
+  return true;
+}
+
