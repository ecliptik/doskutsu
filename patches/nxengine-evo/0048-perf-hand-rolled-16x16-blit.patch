+  // Uint32) when no colorkey is set on the surface, which forces the
+  // fast-path inner loop to take the simpler "no skip" memcpy.
+  SDL_Surface *surface16bpp();
+  Uint16 colorkey16();
+  bool hasColorkey();
+
 private:
