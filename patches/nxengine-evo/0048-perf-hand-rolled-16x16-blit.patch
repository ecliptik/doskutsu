-  SDL_DestroySurface(image_rgb565);
-
   if (!_texture)
   {
     LOG_ERROR("Surface::LoadImage: SDL_CreateTextureFromSurface failed: {}", SDL_GetError());
+    SDL_DestroySurface(image_rgb565);
     return false;
   }
 
+  // DOSKUTSU patch 0048 (Phase 9 wave 6 Lever 2 Approach B) — retain
+  // the RGB565 surface so the hand-rolled fast-path blit in
+  // Renderer::drawSurface can read from it directly. Patch 0047
+  // (Approach C) destroyed this surface immediately after the texture
+  // was created; Approach B needs it kept for the lifetime of the
+  // Surface. Cost: ~2x the BMP size in CPU-side RAM (already accepted
+  // by Approach C — the texture's internal copy was already that size,
+  // we just keep a second pointer to it equivalent so we don't have
+  // to reach into SDL3 internals via texture->internal).
+  //
+  // Pre-extract the colorkey to a 16-bit word for the hot loop. SDL3's
+  // SDL_GetSurfaceColorKey returns the format-aware key as a Uint32;
+  // since the surface format is RGB565, the key fits in the low 16 bits.
+  // Storing the resolved value here avoids SDL_GetSurfaceColorKey calls
+  // on the inner-loop critical path.
+  _surface_rgb565 = image_rgb565;
+  Uint32 ck = 0;
+  if (SDL_GetSurfaceColorKey(image_rgb565, &ck))
+  {
+    _has_colorkey = true;
+    _colorkey16 = (Uint16)(ck & 0xFFFFu);
+  }
+  else
+  {
+    _has_colorkey = false;
+    _colorkey16 = 0;
+  }
+
   return true;
 }
 
@@ -141,6 +168,22 @@ SDL_Texture* Surface::texture()
   return _texture;
 }
 
+// DOSKUTSU patch 0048 (Phase 9 wave 6 Lever 2 Approach B) — accessors.
+SDL_Surface *Surface::surface16bpp()
+{
+  return _surface_rgb565;
+}
+
+Uint16 Surface::colorkey16()
+{
+  return _colorkey16;
+}
+
+bool Surface::hasColorkey()
+{
+  return _has_colorkey;
+}
+
 void Surface::cleanup()
 {
   if (_texture)
@@ -148,6 +191,16 @@ void Surface::cleanup()
     SDL_DestroyTexture(_texture);
     _texture = nullptr;
   }
+  // DOSKUTSU patch 0048: free the retained RGB565 surface alongside the
+  // texture. The pair is always-both-or-neither so the fast-path
+  // surface16bpp() != NULL check is sufficient.
+  if (_surface_rgb565)
+  {
+    SDL_DestroySurface(_surface_rgb565);
+    _surface_rgb565 = nullptr;
+  }
+  _has_colorkey = false;
+  _colorkey16 = 0;
 }
 
