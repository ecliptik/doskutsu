diff --git a/src/graphics/Renderer.cpp b/src/graphics/Renderer.cpp
index 61c97c8..5d47d01 100644
--- a/src/graphics/Renderer.cpp
+++ b/src/graphics/Renderer.cpp
@@ -89,16 +89,33 @@ inline bool _abl_no_input_poll_env()
   return v;
 }
 
-// DOS-PORT (patch 0086, Phase 9 wave 18): direct-VESA hot path opt-in.
-// Strict "1" match per the wave-16+ default-OFF / strict-"1" convention
-// (matches SDL_HINT_DOSKUTSU_FORCE_LFB / DISPLAY_START_FIX / LFB_SENTINEL /
-// PREVFRAME_DIFF). Default OFF; experimental opt-in for the wave 18
-// real-HW measurement iter. Predicted +2-5 fps title (per
-// PHASE9-WAVE-17-18-PLAN § 4) — framed as a hypothesis to measure, not
-// a goal to defend (per perf_predictions_unreliable.md).
+// DOS-PORT (patch 0086, Phase 9 wave 18; polarity flipped patch 0088,
+// wave 20): direct-VESA hot path. Wave 18 shipped this default-OFF as an
+// experimental opt-in. Wave-18 real-HW measurement (W18A.LOG / W18B.LOG)
+// confirmed the path engaged 100/100 attempted presents with 0 failures
+// AND delivered a small but consistent +0.27-0.65 fps title win
+// (banked / LFB respectively) over the wave-17.6 baseline of 25.6 fps.
+// Per memory/wave_18_sdl_overhead_closed.md the SDL-layer hypothesis is
+// closed at ~1.1 ms/flip dispatch — small but free. Wave 20 patch 0088
+// promotes the path to DEFAULT-ON with `SDL_HINT_DOSKUTSU_DIRECT_VESA=0`
+// as the killswitch. Mirror of wave-17.6's polarity flip (patch 0085)
+// where PREVFRAME_DIFF went default-ON->default-OFF after a regression
+// surfaced; the killswitch convention lets a single env var revert to
+// the bisect-able prior behaviour without a rebuild.
+//
+// Strict-match convention: only the literal string "0" disables. Any
+// other value (including unset, empty, "1", "yes", garbage) leaves the
+// hot path engaged. This is the inverse of the wave-16+ strict-"1"
+// convention used for opt-in flags — patch 0088 documents the pattern.
 inline bool _abl_direct_vesa()
 {
-  static const bool v = _strict_truthy_env("SDL_HINT_DOSKUTSU_DIRECT_VESA");
+  static const bool v = []() {
+    const char *e = std::getenv("SDL_HINT_DOSKUTSU_DIRECT_VESA");
+    // killswitch: only literal "0" disables. Default ON; set =0 to revert
+    // to the wave-17.6-baseline SDL_RenderPresent / SDL_UpdateWindowSurface
+    // path if a regression surfaces on a fingerprint we haven't tested.
+    return !(e && e[0] == '0' && e[1] == 0);
+  }();
   return v;
 }
 
@@ -1310,19 +1327,22 @@ bool Renderer::initVideo()
            _abl_cache_winsurf() ? 1 : 0,
            _abl_no_input_poll_env() ? 1 : 0,
            _abl_direct_vesa() ? 1 : 0);
+  // patch 0088 (wave 20): polarity flipped. Default ON, killswitch =0.
   if (_abl_direct_vesa())
   {
-    LOG_INFO("Renderer::initVideo: direct-VESA hot path ENABLED via "
-             "SDL_HINT_DOSKUTSU_DIRECT_VESA=1 (experimental opt-in; "
-             "default OFF since wave 18; bypasses SDL_RenderPresent / "
-             "SDL_UpdateWindowSurface and writes via SDL/0034's "
-             "PresentFull helper; R2 mitigation handled by SDL/0034 "
-             "generation counter — no per-N-flip heartbeat needed)");
+    LOG_INFO("Renderer::initVideo: direct-VESA hot path ENABLED "
+             "(default since wave 20 patch 0088; bypasses "
+             "SDL_RenderPresent / SDL_UpdateWindowSurface and writes via "
+             "SDL/0034's PresentFull helper; R2 mitigation handled by "
+             "SDL/0034 generation counter — no per-N-flip heartbeat "
+             "needed; set SDL_HINT_DOSKUTSU_DIRECT_VESA=0 to revert)");
   }
   else
   {
-    LOG_INFO("Renderer::initVideo: direct-VESA hot path DISABLED "
-             "(default; set SDL_HINT_DOSKUTSU_DIRECT_VESA=1 to opt in)");
+    LOG_INFO("Renderer::initVideo: direct-VESA hot path DISABLED via "
+             "SDL_HINT_DOSKUTSU_DIRECT_VESA=0 killswitch (reverts to "
+             "wave-17.6-baseline SDL_RenderPresent / "
+             "SDL_UpdateWindowSurface path)");
   }
   // DOS-PORT (patch 0087, Phase 9 wave 20 Lever A): record FLIP_INSTR
   // state in DEBUG.LOG so each iter's configuration is greppable
