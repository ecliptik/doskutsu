Three runtime env-var ablation flags to test the two prime MISC suspects
identified by the 2026-04-27 3-reviewer pass plus a control. See
docs/PHASE9-NEXT-WAVES-PLAN.md §6 for the decision tree.

  DOSKUTSU_NO_DC_TIMING=1   skip per-drawcall SDL_GetTicks{,NS} reads
                            (R1 hypothesis: 1200-2200 PIT-port reads
                            per frame — diagnostic measuring itself)

  DOSKUTSU_CACHE_WINSURF=1  skip per-flip SDL_GetWindowSurface refresh
                            after RenderPresent in flip() and flushAll()
                            (R3 hypothesis: re-query runs fb_state
                            populate inside SDL3-DOS)

  DOSKUTSU_NO_INPUT_POLL=1  stub input_poll() body — game uncontrollable;
                            control variable for SDL_PollEvent /
                            DOS_Yield ping-pong cost (R3 secondary)

All three default off. Renderer::initVideo logs which flags were active
on this run so DEBUG.LOG records the iter context.

Risk: CACHE_WINSURF may segfault if SDL3 actually invalidates the
surface pointer post-RenderPresent. Acceptable for one ablation iter
on real HW; not for shipping. Per-drawcall timer ablation freezes the
phase-timing accumulators at zero — the phase-timing block report will
show dc_total_ms=0 which is misleading; the real signal is inter_flip_ms.

Builds clean at i586 -O2 -fno-rtti. DOSBox-X smoke pending.
---
 src/graphics/Renderer.cpp | 78 ++++++++++++++++++++++++++++++++++-----
 src/input.cpp             | 14 +++++++
 2 files changed, 83 insertions(+), 9 deletions(-)

diff --git a/src/graphics/Renderer.cpp b/src/graphics/Renderer.cpp
index 0e90c88..02e171e 100644
--- a/src/graphics/Renderer.cpp
+++ b/src/graphics/Renderer.cpp
@@ -53,6 +53,40 @@ namespace Graphics
 
 namespace
 {
+// DOS-PORT (patch 0063, Phase 9 wave 13.2): surgical instrumentation
+// ablation flags. Tests two prime MISC suspects from the 2026-04-27
+// 3-reviewer pass — see docs/PHASE9-NEXT-WAVES-PLAN.md §6.
+//   DOSKUTSU_NO_DC_TIMING=1 — skip per-drawcall SDL_GetTicks{,NS} reads
+//                             (R1 hypothesis: PIT-port reads dominate)
+//   DOSKUTSU_CACHE_WINSURF=1 — skip per-flip SDL_GetWindowSurface refresh
+//                              (R3 hypothesis: fb_state populate is misc)
+//   DOSKUTSU_NO_INPUT_POLL=1 — stub input_poll() body
+//                              (R3 secondary hypothesis; defined in input.cpp;
+//                               this accessor is for the init-log emission)
+// Lazy-initialized via getenv on first call; constant for the run. Strict
+// "1"-only match (per dirty-rect convention at line ~990) so accidental
+// `SET FOO=0` doesn't enable the flag.
+inline bool _strict_truthy_env(const char *name)
+{
+  const char *e = std::getenv(name);
+  return e && e[0] == '1' && e[1] == 0;
+}
+inline bool _abl_no_dc_timing()
+{
+  static const bool v = _strict_truthy_env("DOSKUTSU_NO_DC_TIMING");
+  return v;
+}
+inline bool _abl_cache_winsurf()
+{
+  static const bool v = _strict_truthy_env("DOSKUTSU_CACHE_WINSURF");
+  return v;
+}
+inline bool _abl_no_input_poll_env()
+{
+  static const bool v = _strict_truthy_env("DOSKUTSU_NO_INPUT_POLL");
+  return v;
+}
+
 // drawSurface NULL-texture diagnostic (Phase 7 black-screen bug, task #14).
 // Track which Surface objects produce NULL textures so we log each origin
 // once + a periodic running count, instead of hundreds of identical lines
@@ -136,9 +170,10 @@ inline bool _timed_render_texture(SDL_Renderer *r, SDL_Texture *t,
                                   int src_w, int src_h, int dst_w, int dst_h,
                                   int dst_x, int dst_y)
 {
-  Uint64 _t0 = SDL_GetTicks();
+  // patch 0063 ablation: gate timing reads on env flag.
+  Uint64 _t0 = _abl_no_dc_timing() ? 0 : SDL_GetTicks();
   bool ok = SDL_RenderTexture(r, t, src, dst);
-  Uint64 _ms = SDL_GetTicks() - _t0;
+  Uint64 _ms = _abl_no_dc_timing() ? 0 : (SDL_GetTicks() - _t0);
 
   ++idx_counter;
   _dc_total_ms_block += _ms;
@@ -163,9 +198,10 @@ inline bool _timed_render_texture_rotated(SDL_Renderer *r, SDL_Texture *t,
                                           int src_w, int src_h, int dst_w, int dst_h,
                                           int dst_x, int dst_y)
 {
-  Uint64 _t0 = SDL_GetTicks();
+  // patch 0063 ablation: gate timing reads on env flag.
+  Uint64 _t0 = _abl_no_dc_timing() ? 0 : SDL_GetTicks();
   bool ok = SDL_RenderTextureRotated(r, t, src, dst, angle, center, flip);
-  Uint64 _ms = SDL_GetTicks() - _t0;
+  Uint64 _ms = _abl_no_dc_timing() ? 0 : (SDL_GetTicks() - _t0);
 
   ++idx_counter;
   _dc_total_ms_block += _ms;
@@ -592,9 +628,13 @@ Uint64 _inter_flip_accum_ms_global = 0;
 struct _DrawcallTimer
 {
   Uint64 _t0;
-  _DrawcallTimer() : _t0(SDL_GetTicksNS()) {}
+  // patch 0063 ablation: skip ns-resolution timing when DOSKUTSU_NO_DC_TIMING
+  // is set. Constructor reads zero, destructor early-returns — accumulators
+  // freeze at whatever value they had pre-flag (typically 0 if set at boot).
+  _DrawcallTimer() : _t0(_abl_no_dc_timing() ? 0 : SDL_GetTicksNS()) {}
   ~_DrawcallTimer()
   {
+    if (_abl_no_dc_timing()) return;
     const Uint64 dt = SDL_GetTicksNS() - _t0;
     _drawcall_accum_ns_block += dt;
     _drawcall_accum_ns_global += dt;
@@ -638,15 +678,21 @@ void _maybe_flush_phase_timing_audit()
       ? (long long)((_drawcall_accum_ns_block * 10ull)
                     / ((Uint64)_drawcall_count_block * 1000ull))
       : 0;
+  // patch 0063: append ablation-flag suffix so each block line self-describes
+  // — under NO_DC_TIMING=1 the dc_total_ms / dc_avg fields will read zero
+  // because the accumulators are gated; this suffix tells a future log-grepper
+  // why without forcing them back to the patch.
   LOG_INFO("phase timing block {}: drawcalls={} dc_total_ms={} "
            "flip_inner_total_ms={} inter_flip_total_ms={} "
            "(per-flip avg x10: dc_ms={} fi_ms={} if_ms={} derived audio+engine_ms={}; "
-           "per-drawcall avg us_x10={})",
+           "per-drawcall avg us_x10={}) [ablation: NO_DC_TIMING={} CACHE_WINSURF={}]",
            _dc_block_idx, _drawcall_count_block,
            (long long)dc_total_ms, (long long)flip_inner_total_ms,
            (long long)inter_flip_total_ms,
            dc_avg_ms_x10, fi_avg_ms_x10, if_avg_ms_x10,
-           audio_engine_ms_x10, dc_avg_us_x10);
+           audio_engine_ms_x10, dc_avg_us_x10,
+           _abl_no_dc_timing() ? 1 : 0,
+           _abl_cache_winsurf() ? 1 : 0);
   _drawcall_accum_ns_block = 0;
   _drawcall_count_block = 0;
   _flip_inner_accum_ns_block = 0;
@@ -975,6 +1021,13 @@ bool Renderer::initVideo()
                "(set SDL_HINT_DOSKUTSU_DIRTY_RECTS=1 to enable, experimental)");
     }
   }
+  // DOS-PORT (patch 0063, Phase 9 wave 13.2): log ablation-flag state
+  // so DEBUG.LOG records which surgical-instrumentation ablations were
+  // active for this iter. See docs/PHASE9-NEXT-WAVES-PLAN.md §6.
+  LOG_INFO("Renderer::initVideo: ablation flags: NO_DC_TIMING={} CACHE_WINSURF={} NO_INPUT_POLL={}",
+           _abl_no_dc_timing() ? 1 : 0,
+           _abl_cache_winsurf() ? 1 : 0,
+           _abl_no_input_poll_env() ? 1 : 0);
   // First frame must be a full refresh — we have no last-frame
   // history to compare against and the backbuffer state is whatever
   // SDL3 initialized it to.
@@ -993,7 +1046,11 @@ bool Renderer::flushAll()
   // DOS-PORT (patch 0050): present implicitly flushed the renderer
   // queue and may have invalidated the SW-renderer's window-surface
   // pointer. Refresh, mirroring flip().
-  _cached_window_surface = SDL_GetWindowSurface(_window);
+  // patch 0063 ablation: gate the refresh on DOSKUTSU_CACHE_WINSURF.
+  // Risk if pointer goes stale: _try_fast_blit segfaults. Acceptable
+  // for a one-iter ablation; not for shipping.
+  if (!_abl_cache_winsurf())
+    _cached_window_surface = SDL_GetWindowSurface(_window);
   // DOS-PORT (patch 0051): SDL_RenderPresent flushed the queue.
   _renderer_queue_dirty = false;
   // DOS-PORT (patch 0052, Phase 9 wave 9 Lever A): flushAll() bypasses
@@ -1307,7 +1364,10 @@ void Renderer::flip()
   // surface post-present. SDL_RenderPresent (SW renderer) may swap or
   // invalidate the underlying window surface — re-querying once per
   // flip is the safe invalidation hook.
-  _cached_window_surface = SDL_GetWindowSurface(_window);
+  // patch 0063 ablation: gate on DOSKUTSU_CACHE_WINSURF (R3 hypothesis
+  // — re-query may be running fb_state populate inside SDL3-DOS).
+  if (!_abl_cache_winsurf())
+    _cached_window_surface = SDL_GetWindowSurface(_window);
   if (!ok)
   {
     ++_flip_failed;
diff --git a/src/input.cpp b/src/input.cpp
index e6e352a..228ec5c 100644
--- a/src/input.cpp
+++ b/src/input.cpp
@@ -9,6 +9,7 @@
 #include "sound/SoundManager.h"
 
 #include <array>
