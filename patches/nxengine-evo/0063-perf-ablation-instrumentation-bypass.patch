 in_action mappings[INPUT_COUNT];
 
@@ -257,6 +258,19 @@ static int IsNonConsoleKey(int key)
 
 void input_poll(void)
 {
+  // DOS-PORT (patch 0063, Phase 9 wave 13.2): ablation flag — skip the
+  // event-pump entirely. R3 hypothesis: SDL_PollEvent + DOS_Yield
+  // ping-pong with the audio cooperative thread is a misc cost. Game
+  // becomes uncontrollable when set; control variable for §6 decision
+  // tree. Strict "1"-only match (matches Renderer.cpp helpers) so
+  // `SET DOSKUTSU_NO_INPUT_POLL=0` does NOT enable. See
+  // docs/PHASE9-NEXT-WAVES-PLAN.md.
+  static const bool _abl_no_input_poll = []() {
+    const char *e = std::getenv("DOSKUTSU_NO_INPUT_POLL");
+    return e && e[0] == '1' && e[1] == 0;
+  }();
+  if (_abl_no_input_poll) return;
+
   SDL_Event evt;
   int32_t key;
   int ino; //, key;
