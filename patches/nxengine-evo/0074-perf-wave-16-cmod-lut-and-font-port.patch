+// DOS-PORT (patch 0074, Phase 9 wave 16 Lever 3): INDEX8 sibling of
+// _blit_rgb565_color_mod_black. Black-mod (mod_r=mod_g=mod_b=0) writes
+// master index 0 (reserved black per format spec §1.2) for every
+// non-colorkey source pixel. Hot path for Font shadow rendering.
+//
+// Cheaper than the general branch: no LUT lookup needed since the
+// output is constant. ~3 ops/pixel (load src, compare, store 0).
+static inline bool _blit_indexed_color_mod_black(SDL_Surface *dst, SDL_Surface *src,
+                                                 SDL_Rect srcrect, SDL_Rect dstrect,
+                                                 Uint8 colorkey, bool has_colorkey,
+                                                 Uint8 master_black_idx)
+{
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sx = srcrect.x;
+  int sy = srcrect.y;
+  int rows = srcrect.h;
+  int cols = srcrect.w;
+
+  if (dst_x < 0) { cols += dst_x; sx -= dst_x; dst_x = 0; }
+  if (dst_y < 0) { rows += dst_y; sy -= dst_y; dst_y = 0; }
+  if (dst_x + cols > dst->w) cols = dst->w - dst_x;
+  if (dst_y + rows > dst->h) rows = dst->h - dst_y;
+  if (rows <= 0 || cols <= 0) return true;
+
+  const int src_pitch = src->pitch;
+  const int dst_pitch = dst->pitch;
+  const Uint8 *sp = (const Uint8 *)src->pixels + sy * src_pitch + sx;
+  Uint8 *dp = (Uint8 *)dst->pixels + dst_y * dst_pitch + dst_x;
+
+  for (int row = 0; row < rows; ++row)
+  {
+    for (int col = 0; col < cols; ++col)
+    {
+      const Uint8 spx = sp[col];
+      if (has_colorkey && spx == colorkey) continue;
+      dp[col] = master_black_idx;
+    }
+    sp += src_pitch;
+    dp += dst_pitch;
+  }
+  return true;
+}
+
+// DOS-PORT (patch 0074, Phase 9 wave 16 Lever 3): INDEX8 sibling of
+// _blit_rgb565_color_mod_general — the BIG PERF WIN. Replaces the
+// per-pixel 14-22 op channel multiply with a per-pixel 1-byte LUT
+// lookup. The LUT (`cmod_lut`) is precomputed by Renderer::_cmod_lut_for
+// once per unique (mod_r, mod_g, mod_b) tuple and cached on the
+// Renderer; Cave Story uses 1-3 distinct tuples so cache pressure is
+// negligible.
+//
+// Inner loop is just `dp[col] = cmod_lut[sp[col]]` plus optional
+// colorkey skip. Faster than _blit_indexed (no colorkey skip in the
+// no-colorkey branch) but the cmod path always uses colorkey for
+// fonts.
+static inline bool _blit_indexed_color_mod(SDL_Surface *dst, SDL_Surface *src,
+                                           SDL_Rect srcrect, SDL_Rect dstrect,
+                                           Uint8 colorkey, bool has_colorkey,
+                                           const Uint8 *cmod_lut)
+{
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sx = srcrect.x;
+  int sy = srcrect.y;
+  int rows = srcrect.h;
+  int cols = srcrect.w;
+
+  if (dst_x < 0) { cols += dst_x; sx -= dst_x; dst_x = 0; }
+  if (dst_y < 0) { rows += dst_y; sy -= dst_y; dst_y = 0; }
+  if (dst_x + cols > dst->w) cols = dst->w - dst_x;
+  if (dst_y + rows > dst->h) rows = dst->h - dst_y;
+  if (rows <= 0 || cols <= 0) return true;
+
+  const int src_pitch = src->pitch;
+  const int dst_pitch = dst->pitch;
+  const Uint8 *sp = (const Uint8 *)src->pixels + sy * src_pitch + sx;
+  Uint8 *dp = (Uint8 *)dst->pixels + dst_y * dst_pitch + dst_x;
+
+  if (has_colorkey)
+  {
+    for (int row = 0; row < rows; ++row)
+    {
+      for (int col = 0; col < cols; ++col)
+      {
+        const Uint8 spx = sp[col];
+        if (spx == colorkey) continue;
+        dp[col] = cmod_lut[spx];
+      }
+      sp += src_pitch;
+      dp += dst_pitch;
+    }
+  }
+  else
+  {
+    for (int row = 0; row < rows; ++row)
+    {
+      for (int col = 0; col < cols; ++col)
+      {
+        dp[col] = cmod_lut[sp[col]];
+      }
+      sp += src_pitch;
+      dp += dst_pitch;
+    }
+  }
+  return true;
+}
+
+// DOS-PORT (patch 0074, Phase 9 wave 16 Lever 3): cmod LUT factory.
+// Returns a stable reference to the LUT for `(r, g, b)`, building it
+// on first call. The LUT cell at index i is the master-palette index
+// closest to `(master[i].r * r >> 8, master[i].g * g >> 8,
+// master[i].b * b >> 8)` per the cmod-multiplicative formula.
+//
+// Build cost is 256 × 256 × ~10 ops ≈ 600K cycles ≈ 7.5ms on PODP83
+// per spec §2.3. Once per unique tuple, then free forever; total LUT
+// memory is ~256 bytes × small-N ≈ tiny. The cache is keyed by Uint32
+// pack of the tuple.
+const std::array<Uint8, 256>& Renderer::_cmod_lut_for(Uint8 r, Uint8 g, Uint8 b)
+{
+  const Uint32 key = ((Uint32)r << 16) | ((Uint32)g << 8) | (Uint32)b;
+  auto it = _cmod_lut_cache.find(key);
+  if (it != _cmod_lut_cache.end()) return it->second;
+
+  // Pre-insert default-constructed slot, then fill — avoids a second
+  // hash on the return-by-reference.
+  auto inserted = _cmod_lut_cache.emplace(key, std::array<Uint8, 256>{});
+  std::array<Uint8, 256> &lut = inserted.first->second;
+
+  const SDL_Color *colors = _master_palette ? _master_palette->colors : nullptr;
+  if (!colors)
+  {
+    // Defensive: if cmod is requested without a master palette loaded,
+    // build the identity LUT so the inner loop produces *something*
+    // recognizable instead of garbage. _indexed_mode should have been
+    // cleared in initVideo if the palette is missing, so this branch
+    // is a belt-and-braces guard.
+    for (int i = 0; i < 256; ++i) lut[i] = (Uint8)i;
+    return lut;
+  }
+
+  for (int i = 0; i < 256; ++i)
+  {
+    const int rr = (colors[i].r * (int)r) >> 8;
+    const int gg = (colors[i].g * (int)g) >> 8;
+    const int bb = (colors[i].b * (int)b) >> 8;
+    // Special cases (per format spec §3.4 colorkey-stable rules) so
+    // the LUT can never re-map a non-colorkey pixel into the colorkey
+    // slot or vice versa.
+    if (rr == 0 && gg == 0 && bb == 0)
+    {
+      lut[i] = 0;
+      continue;
+    }
+    if (rr == 0xFF && gg == 0x00 && bb == 0xFF)
+    {
+      lut[i] = 255;
+      continue;
+    }
+    Uint8 best_idx = 0;
+    int best_dist = INT_MAX;
+    for (int j = 0; j < 256; ++j)
+    {
+      const int dr = rr - (int)colors[j].r;
+      const int dg = gg - (int)colors[j].g;
+      const int db = bb - (int)colors[j].b;
+      const int d = 299 * dr * dr + 587 * dg * dg + 114 * db * db;
+      if (d < best_dist) { best_dist = d; best_idx = (Uint8)j; }
+    }
+    lut[i] = best_idx;
+  }
+  return lut;
+}
+
