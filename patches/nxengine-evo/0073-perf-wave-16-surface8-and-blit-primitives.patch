+// DOS-PORT (patch 0073, Phase 9 wave 16 Lever 3): master palette loader.
+// Reads exactly 768 bytes from `data/master.pal` (256 × RGB triples per
+// /tmp/wave-16-1-palette-format.md §1.1) and populates _master_palette
+// as an SDL_Palette with alpha=255. Returns true on success; logs and
+// returns false on any IO / size mismatch (caller falls back to RGB565).
+bool Renderer::_load_master_palette(const char *path)
+{
+  // CLAUDE.md DJGPP rule: always fopen("rb") for binary reads.
+  FILE *f = fopen(path, "rb");
+  if (!f)
+  {
+    LOG_ERROR("Renderer::_load_master_palette: fopen('{}') failed", path);
+    return false;
+  }
+  unsigned char buf[768];
+  size_t n = fread(buf, 1, sizeof(buf), f);
+  fclose(f);
+  if (n != sizeof(buf))
+  {
+    LOG_ERROR("Renderer::_load_master_palette: short read ({} of 768 bytes)", (int)n);
+    return false;
+  }
+  SDL_Palette *p = SDL_CreatePalette(256);
+  if (!p)
+  {
+    LOG_ERROR("Renderer::_load_master_palette: SDL_CreatePalette failed: {}", SDL_GetError());
+    return false;
+  }
+  SDL_Color colors[256];
+  for (int i = 0; i < 256; ++i)
+  {
+    colors[i].r = buf[i * 3 + 0];
+    colors[i].g = buf[i * 3 + 1];
+    colors[i].b = buf[i * 3 + 2];
+    colors[i].a = 255;
+  }
+  if (!SDL_SetPaletteColors(p, colors, 0, 256))
+  {
+    LOG_ERROR("Renderer::_load_master_palette: SDL_SetPaletteColors failed: {}", SDL_GetError());
+    SDL_DestroyPalette(p);
+    return false;
+  }
+  // Quick smoke per format spec §7: verify reserved slots.
+  if (!(colors[0].r == 0 && colors[0].g == 0 && colors[0].b == 0))
+  {
+    LOG_WARN("Renderer::_load_master_palette: index 0 is ({},{},{}) — expected (0,0,0)",
+             colors[0].r, colors[0].g, colors[0].b);
+  }
+  if (!(colors[255].r == 0xFF && colors[255].g == 0x00 && colors[255].b == 0xFF))
+  {
+    LOG_WARN("Renderer::_load_master_palette: index 255 is ({},{},{}) — expected (255,0,255)",
+             colors[255].r, colors[255].g, colors[255].b);
+  }
+  _master_palette = p;
   return true;
 }
 
+// DOS-PORT (patch 0073, Phase 9 wave 16 Lever 3): per-asset palmap loader.
+// Parses the on-disk format defined in /tmp/wave-16-1-palette-format.md
+// §2 (12-byte header + variable-length per-entry frames). Each entry's
+// remap[] is zero-padded to 256 bytes in the std::array slot — only the
+// first src_palette_size bytes are meaningful, but the lookup at draw
+// time always indexes by source-pixel-byte (which is 0-255), so the
+// extra zeros are harmless and avoid a separate "size" field per entry.
+bool Renderer::_load_master_palmap(const char *path)
+{
+  FILE *f = fopen(path, "rb");
+  if (!f)
+  {
+    LOG_ERROR("Renderer::_load_master_palmap: fopen('{}') failed", path);
+    return false;
+  }
+  Uint32 magic = 0, version = 0, num_entries = 0;
+  if (fread(&magic, 4, 1, f) != 1 ||
+      fread(&version, 4, 1, f) != 1 ||
+      fread(&num_entries, 4, 1, f) != 1)
+  {
+    LOG_ERROR("Renderer::_load_master_palmap: header read failed");
+    fclose(f);
+    return false;
+  }
+  // Magic spelled "PMAP" = 0x504D4150 little-endian per format spec §2.1.
+  if (magic != 0x504D4150u)
+  {
+    LOG_ERROR("Renderer::_load_master_palmap: bad magic 0x{:08x} — expected 0x504D4150 ('PMAP')",
+              (unsigned)magic);
+    fclose(f);
+    return false;
+  }
+  if (version != 1u)
+  {
+    LOG_ERROR("Renderer::_load_master_palmap: unsupported version {} — expected 1",
+              (unsigned)version);
+    fclose(f);
+    return false;
+  }
+  // Sanity guard: 16-bit path_len → max realistic entries ≈ tens of
+  // thousands; reject if num_entries is absurd.
+  if (num_entries > 100000u)
+  {
+    LOG_ERROR("Renderer::_load_master_palmap: num_entries={} unreasonable — refusing", (unsigned)num_entries);
+    fclose(f);
+    return false;
+  }
+  _palmap_cache.reserve((size_t)num_entries);
+  for (Uint32 i = 0; i < num_entries; ++i)
+  {
+    Uint16 path_len = 0;
+    if (fread(&path_len, 2, 1, f) != 1) goto truncated;
+    {
+      std::string asset_path(path_len, '\0');
+      if (path_len && fread(&asset_path[0], 1, path_len, f) != path_len) goto truncated;
+      Uint8 src_size = 0;
+      if (fread(&src_size, 1, 1, f) != 1) goto truncated;
+      if (src_size == 0)
+      {
+        // Truecolor source — no remap table. Skip; caller takes slow path.
+        continue;
+      }
+      if (src_size != 2 && src_size != 16 && (int)src_size != 256)
+      {
+        LOG_WARN("Renderer::_load_master_palmap: entry '{}' has odd src_size={} — skipping",
+                 asset_path, (int)src_size);
+        // Still need to advance past the bytes the writer emitted.
+        if (src_size > 0) fseek(f, (long)src_size, SEEK_CUR);
+        continue;
+      }
+      std::array<Uint8, 256> lut{};
+      if (fread(lut.data(), 1, src_size, f) != src_size) goto truncated;
+      _palmap_cache.emplace(std::move(asset_path), lut);
+    }
+  }
+  fclose(f);
+  return true;
+truncated:
+  LOG_ERROR("Renderer::_load_master_palmap: truncated read after {} entries (of {})",
+            (int)_palmap_cache.size(), (unsigned)num_entries);
+  fclose(f);
+  return false;
+}
