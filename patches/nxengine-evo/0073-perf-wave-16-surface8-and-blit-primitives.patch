+// DOS-PORT (patch 0073, Phase 9 wave 16 Lever 3): INDEX8 blit primitive.
+// Byte-per-pixel sibling of _blit_rgb565. Same dst-clip pattern, but 1
+// byte per pixel instead of 2. Per format spec /tmp/wave-16-1-palette-
+// format.md §3.4 the colorkey byte for sprites is master index 0
+// (black) and for fonts is 255 (magenta), already pre-extracted at
+// Surface load time.
+//
+// No 5/6/5 packing/unpacking: source and dest pixel bytes are master-
+// palette indices, identical layout. The colorkey-skip loop is the
+// slightly slower variant; the no-colorkey path uses SDL_memcpy per
+// row (faster than the RGB565 path because no byte-doubling).
+static inline bool _blit_indexed(SDL_Surface *dst, SDL_Surface *src,
+                                 SDL_Rect srcrect, SDL_Rect dstrect,
+                                 Uint8 colorkey, bool has_colorkey)
+{
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sx = srcrect.x;
+  int sy = srcrect.y;
+  int rows = srcrect.h;
+  int cols = srcrect.w;
+
+  if (dst_x < 0) { cols += dst_x; sx -= dst_x; dst_x = 0; }
+  if (dst_y < 0) { rows += dst_y; sy -= dst_y; dst_y = 0; }
+  if (dst_x + cols > dst->w) cols = dst->w - dst_x;
+  if (dst_y + rows > dst->h) rows = dst->h - dst_y;
+  if (rows <= 0 || cols <= 0) return true;
+
+  const int src_pitch = src->pitch;
+  const int dst_pitch = dst->pitch;
+  const Uint8 *sp = (const Uint8 *)src->pixels + sy * src_pitch + sx;
+  Uint8 *dp = (Uint8 *)dst->pixels + dst_y * dst_pitch + dst_x;
+
+  if (has_colorkey)
+  {
+    for (int row = 0; row < rows; ++row)
+    {
+      for (int col = 0; col < cols; ++col)
+      {
+        const Uint8 px = sp[col];
+        if (px != colorkey) dp[col] = px;
+      }
+      sp += src_pitch;
+      dp += dst_pitch;
+    }
+  }
+  else
+  {
+    const size_t bytes = (size_t)cols;
+    for (int row = 0; row < rows; ++row)
+    {
+      SDL_memcpy(dp, sp, bytes);
+      sp += src_pitch;
+      dp += dst_pitch;
+    }
+  }
+  return true;
+}
+
+// DOS-PORT (patch 0073, Phase 9 wave 16 Lever 3): INDEX8 mirrored blit
+// primitive. Column-reverse 1-byte sibling of _blit_rgb565_mirrored.
+// Same clip semantics: dst_x<0 drops rightmost source columns, dst_x+
+// cols>dst->w drops leftmost source columns. No memcpy fast path —
+// column reversal requires per-pixel writes.
+static inline bool _blit_indexed_mirrored(SDL_Surface *dst, SDL_Surface *src,
+                                          SDL_Rect srcrect, SDL_Rect dstrect,
+                                          Uint8 colorkey, bool has_colorkey)
+{
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sy = srcrect.y;
+  int rows = srcrect.h;
+  int cols = srcrect.w;
+  int src_first_col = srcrect.w - 1;
+
+  if (dst_x < 0) { src_first_col += dst_x; cols += dst_x; dst_x = 0; }
+  if (dst_y < 0) { rows += dst_y; sy -= dst_y; dst_y = 0; }
+  if (dst_x + cols > dst->w) cols = dst->w - dst_x;
+  if (dst_y + rows > dst->h) rows = dst->h - dst_y;
+  if (rows <= 0 || cols <= 0) return true;
+
+  const int src_pitch = src->pitch;
+  const int dst_pitch = dst->pitch;
+  const Uint8 *sp = (const Uint8 *)src->pixels + sy * src_pitch + srcrect.x;
+  Uint8 *dp = (Uint8 *)dst->pixels + dst_y * dst_pitch + dst_x;
+
+  if (has_colorkey)
+  {
+    for (int row = 0; row < rows; ++row)
+    {
+      for (int col = 0; col < cols; ++col)
+      {
+        const Uint8 px = sp[src_first_col - col];
+        if (px != colorkey) dp[col] = px;
+      }
+      sp += src_pitch;
+      dp += dst_pitch;
+    }
+  }
+  else
+  {
+    for (int row = 0; row < rows; ++row)
+    {
+      for (int col = 0; col < cols; ++col)
+      {
+        dp[col] = sp[src_first_col - col];
+      }
+      sp += src_pitch;
+      dp += dst_pitch;
+    }
+  }
+  return true;
+}
+
