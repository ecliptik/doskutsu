+// DOS-PORT (patch 0073, Phase 9 wave 16 Lever 3): INDEX8 sibling — finds
+// the master-palette index closest to the requested (r,g,b). Used by
+// the hand-rolled clearScreen / fillRect / drawRect / drawLine paths
+// when the window surface is INDEX8 (wave-16 indexed mode).
+//
+// Cached: Cave Story's debug-overlay colors are a tiny fixed set
+// (BLACK, dark-blue background, debug green, etc.), so a small static
+// std::unordered_map saves the 256-entry walk on every call. The map
+// grows once per unique (r,g,b) tuple ever used, then settles.
+//
+// Falls back to index 0 (master black) if no palette is loaded — this
+// path should never fire in indexed mode (the renderer would have
+// flipped _indexed_mode=false), but a defensive fallback keeps the
+// hot loop free of NULL-deref risk.
+static inline Uint8 _packed_index_for(uint8_t r, uint8_t g, uint8_t b)
+{
+  static std::unordered_map<Uint32, Uint8> _packed_index_cache;
+  const Uint32 key = ((Uint32)r << 16) | ((Uint32)g << 8) | (Uint32)b;
+  auto it = _packed_index_cache.find(key);
+  if (it != _packed_index_cache.end()) return it->second;
