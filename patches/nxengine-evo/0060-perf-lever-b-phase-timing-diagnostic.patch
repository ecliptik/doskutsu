 // helpers. The hash function is FNV-1a 64-bit on a fixed-shape header
 // of (op_type, surface_id, srcx, srcy, srcw, srch, dstx, dsty, dstw,
@@ -1071,6 +1164,12 @@ void Renderer::flip()
   // resolution at the slow pace and stays bounded if/when fps recovers.
   Uint64 _t0 = SDL_GetTicks();
 
+  // DOS-PORT (patch 0060, Phase 9 wave 12.5-D): nanosecond start for
+  // flip-inner timing. SDL_GetTicks above is ms-resolution and used by
+  // the existing _present_ms / _inter_flip_ms diagnostics; this finer
+  // ns sample drives the per-100-flip phase-timing audit.
+  Uint64 _flip_inner_t0_ns = SDL_GetTicksNS();
+
   // DOS-PORT (patch 0057, Phase 9 wave 12.3-D): inter-flip wall clock.
   // (this_flip_t0 - _last_flip_t0) measures the WHOLE-FRAME budget
   // (logic + drawcalls + flip), not just the present cost. On real HW
@@ -1079,6 +1178,11 @@ void Renderer::flip()
   // it before we get there. First flip emits 0 (no prior frame).
   Uint64 _inter_flip_ms = (_last_flip_t0 == 0) ? 0 : (_t0 - _last_flip_t0);
   _last_flip_t0 = _t0;
+  // DOS-PORT (patch 0060, Phase 9 wave 12.5-D): inter-flip accumulator
+  // for the per-100-flip phase-timing audit. First flip's _inter_flip_ms
+  // is 0 — accumulating it is harmless.
+  _inter_flip_accum_ms_block += _inter_flip_ms;
+  _inter_flip_accum_ms_global += _inter_flip_ms;
 
   // DOS-PORT (patch 0052, Phase 9 wave 9 Lever A): when dirty-rect
   // tracking is enabled and we have a partial dirty list, flush any
@@ -1167,6 +1271,17 @@ void Renderer::flip()
   // DOS-PORT (patch 0059, Phase 9 wave 12.5 Lever B): alpha-blend +
   // color-mod audit (shares the same cadence).
   _maybe_flush_color_alpha_audit();
+  // DOS-PORT (patch 0060, Phase 9 wave 12.5-D): close the flip-inner
+  // window and accumulate. Place AFTER all other audit flushes so the
+  // flip-inner duration includes the audit-flush cost itself (small,
+  // but accounting-honest). The audit-flush *for* phase timing fires
+  // afterwards, naturally including this flip's own inner duration.
+  {
+    const Uint64 _flip_inner_dt_ns = SDL_GetTicksNS() - _flip_inner_t0_ns;
+    _flip_inner_accum_ns_block += _flip_inner_dt_ns;
+    _flip_inner_accum_ns_global += _flip_inner_dt_ns;
+  }
+  _maybe_flush_phase_timing_audit();
 
   // DOS-PORT (patch 0052, Phase 9 wave 9 Lever A): per-frame
   // bookkeeping. Tally the skip stats, swap last-frame ↔ current-
@@ -1860,6 +1975,7 @@ static inline bool _blit_rgb565_color_mod_general(SDL_Surface *dst, SDL_Surface
 // blit the specified portion of the surface to the screen
