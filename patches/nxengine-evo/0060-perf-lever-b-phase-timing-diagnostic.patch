   assert(_renderer);
   // Diagnostic NULL-checks (task #14 / patch 0030). assert() is a no-op in
   // Release where NDEBUG is defined; without these explicit checks NULL
@@ -2029,6 +2145,7 @@ void Renderer::drawSurface(Surface *src, int dstx, int dsty, int srcx, int srcy,
 // blit the specified portion of the surface to the screen
 void Renderer::drawSurfaceMirrored(Surface *src, int dstx, int dsty, int srcx, int srcy, int wd, int ht)
 {
+  _DrawcallTimer _dct;  // patch 0060 — phase timing accumulator
   assert(_renderer);
   if (!src || !src->texture())
   {
@@ -2144,6 +2261,7 @@ void Renderer::drawSurfaceColorMod(Surface *src, const SDL_Rect &srcrect,
                                    const SDL_Rect &dstrect,
                                    uint8_t mod_r, uint8_t mod_g, uint8_t mod_b)
 {
+  _DrawcallTimer _dct;  // patch 0060 — phase timing accumulator
   assert(_renderer);
   if (!src || !src->texture())
