   _color_mod_fallback_block = 0;
 }
 
+// DOS-PORT (patch 0060, Phase 9 wave 12.5-D Lever B diagnostics): phase
+// timing accumulators. Captures three time slices per 100-flip block so
+// we can decompose an inter-flip period into its components on real HW:
+//
+//   drawcall_total = sum of all 10 public drawcall methods' durations
+//   flip_inner_total = sum of all flip() inner-block durations
+//   inter_flip_total = sum of (this_flip_t0 - prev_flip_t0) measurements
+//   audio+engine = inter_flip - flip_inner - drawcall  (derived)
+//
+// All wall-clock via SDL_GetTicksNS for microsecond resolution. Nanos
+// summed in Uint64 (rolls over after 584 years; we're fine). Audit log
+// converts to ms with one-decimal precision via x10 scaling.
+//
+// Cost: ~2 SDL_GetTicksNS calls per drawcall. On menu (5500 dc/flip),
+// that's ~11000 SDL_GetTicksNS calls per flip — measurable but bounded.
+// If overhead distorts measurements unacceptably, instrument can be
+// stripped post-investigation.
+Uint64 _drawcall_accum_ns_block = 0;
+Uint64 _drawcall_accum_ns_global = 0;
+int    _drawcall_count_block = 0;     // counts wraps that fired (for avg)
+int    _drawcall_count_global = 0;
+Uint64 _flip_inner_accum_ns_block = 0;
+Uint64 _flip_inner_accum_ns_global = 0;
+Uint64 _inter_flip_accum_ms_block = 0;  // ms sum (12.3-D inter_flip is ms)
+Uint64 _inter_flip_accum_ms_global = 0;
+
+// RAII helper — captures SDL_GetTicksNS at construction, accumulates
+// elapsed ns to the file-scope counters at destruction. Place at top of
+// each drawcall method to cover all return paths cleanly.
+struct _DrawcallTimer
+{
+  Uint64 _t0;
+  _DrawcallTimer() : _t0(SDL_GetTicksNS()) {}
+  ~_DrawcallTimer()
+  {
+    const Uint64 dt = SDL_GetTicksNS() - _t0;
+    _drawcall_accum_ns_block += dt;
+    _drawcall_accum_ns_global += dt;
+    ++_drawcall_count_block;
+    ++_drawcall_count_global;
+  }
+};
+
+void _maybe_flush_phase_timing_audit()
+{
+  if ((_flip_total % _dc_tally_every_flips) != 0) return;
+  if (_drawcall_count_block == 0 && _flip_inner_accum_ns_block == 0
+      && _inter_flip_accum_ms_block == 0)
+    return;
+  // Convert ns totals to ms totals for the report. Per-flip averages are
+  // computed against _dc_tally_every_flips (block size = 100).
+  const Uint64 dc_total_ms       = _drawcall_accum_ns_block / 1000000ull;
+  const Uint64 flip_inner_total_ms = _flip_inner_accum_ns_block / 1000000ull;
+  const Uint64 inter_flip_total_ms = _inter_flip_accum_ms_block;
+  // Per-flip averages, x10 (one-decimal). avg_ms_x10 = (total_ns * 10) /
+  // (flips * 1_000_000).
+  const long long dc_avg_ms_x10 = _dc_tally_every_flips
+      ? (long long)((_drawcall_accum_ns_block * 10ull)
+                    / ((Uint64)_dc_tally_every_flips * 1000000ull))
+      : 0;
+  const long long fi_avg_ms_x10 = _dc_tally_every_flips
+      ? (long long)((_flip_inner_accum_ns_block * 10ull)
+                    / ((Uint64)_dc_tally_every_flips * 1000000ull))
+      : 0;
+  const long long if_avg_ms_x10 = _dc_tally_every_flips
+      ? (long long)((_inter_flip_accum_ms_block * 10ull)
+                    / (Uint64)_dc_tally_every_flips)
+      : 0;
+  // Derived: audio+engine_ms = inter_flip - flip_inner - drawcall.
+  // Signed math — if it goes negative on real HW, the timer wraps are
+  // mismeasuring something.
+  const long long audio_engine_ms_x10 = if_avg_ms_x10 - fi_avg_ms_x10 - dc_avg_ms_x10;
+  // Per-drawcall avg in microseconds (x10 = one-decimal).
+  // avg_us_x10 = (ns_total * 10) / (count * 1000)
+  const long long dc_avg_us_x10 = (_drawcall_count_block > 0)
+      ? (long long)((_drawcall_accum_ns_block * 10ull)
+                    / ((Uint64)_drawcall_count_block * 1000ull))
+      : 0;
+  LOG_INFO("phase timing block {}: drawcalls={} dc_total_ms={} "
+           "flip_inner_total_ms={} inter_flip_total_ms={} "
+           "(per-flip avg x10: dc_ms={} fi_ms={} if_ms={} derived audio+engine_ms={}; "
+           "per-drawcall avg us_x10={})",
+           _dc_block_idx, _drawcall_count_block,
+           (long long)dc_total_ms, (long long)flip_inner_total_ms,
+           (long long)inter_flip_total_ms,
+           dc_avg_ms_x10, fi_avg_ms_x10, if_avg_ms_x10,
+           audio_engine_ms_x10, dc_avg_us_x10);
+  _drawcall_accum_ns_block = 0;
+  _drawcall_count_block = 0;
+  _flip_inner_accum_ns_block = 0;
+  _inter_flip_accum_ms_block = 0;
+}
+
