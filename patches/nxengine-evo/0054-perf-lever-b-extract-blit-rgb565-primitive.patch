+// DOS-PORT (patch 0054, Phase 9 wave 12 Lever B): generic RGB565→RGB565
+// blit primitive. Extracted from _try_fast_blit_16x16's inner body so
+// future Lever B sub-phases (12.2 generalize-to-all-sizes, 12.3
+// mirrored, 12.5 color-mod / alpha-mod) can share the dst-clip + per-row
+// inner-loop core without duplicating it.
+//
+// Preconditions are the caller's responsibility: format match (both
+// surfaces RGB565), dst/src dim match, alpha=255, etc. This primitive
+// only does:
+//   1. Clip dstrect against dst surface bounds, with srcrect adjusted
+//      symmetrically (handles partly-off-screen sprite edges).
+//   2. Per-row blit: SDL_memcpy when has_colorkey is false, per-pixel
+//      colorkey skip when true.
+//
+// Returns true on success — including the wholly-off-screen case, which
+// produces no output but matches SDL_RenderTexture's clip semantics.
+//
+// Wave 12.1 is a pure refactor: behavior is identical to the inlined
+// body that lived in _try_fast_blit_16x16 at wave 10.
+static inline bool _blit_rgb565(SDL_Surface *dst, SDL_Surface *src,
+                                SDL_Rect srcrect, SDL_Rect dstrect,
+                                Uint16 colorkey, bool has_colorkey)
+{
+  // Compute clipped dst extents. dst may legitimately be slightly off-
+  // screen for sprites near the edges (player/enemies at the boundaries
+  // of the playfield). Clip to dst bounds before the inner loop.
+  int dst_x = dstrect.x;
+  int dst_y = dstrect.y;
+  int sx = srcrect.x;
+  int sy = srcrect.y;
+  int rows = srcrect.h;
+  int cols = srcrect.w;
+
+  if (dst_x < 0)
+  {
+    cols += dst_x; // dst_x is negative; cols shrinks by |dst_x|
+    sx -= dst_x;   // advance into source
+    dst_x = 0;
+  }
+  if (dst_y < 0)
+  {
+    rows += dst_y;
+    sy -= dst_y;
+    dst_y = 0;
+  }
+  if (dst_x + cols > dst->w)
+    cols = dst->w - dst_x;
+  if (dst_y + rows > dst->h)
+    rows = dst->h - dst_y;
+
+  if (rows <= 0 || cols <= 0)
+  {
+    // Wholly off-screen — succeed with no work. The SDL_RenderTexture
+    // path would have done the same.
+    return true;
+  }
+
+  // Pixel pitch in 16-bit elements.
+  const int src_pitch_pixels = src->pitch / 2;
+  const int dst_pitch_pixels = dst->pitch / 2;
+
+  const Uint16 *sp = (const Uint16 *)src->pixels + sy * src_pitch_pixels + sx;
+  Uint16 *dp = (Uint16 *)dst->pixels + dst_y * dst_pitch_pixels + dst_x;
+
+  if (has_colorkey)
+  {
+    for (int row = 0; row < rows; ++row)
+    {
+      for (int col = 0; col < cols; ++col)
+      {
+        const Uint16 px = sp[col];
+        if (px != colorkey) dp[col] = px;
+      }
+      sp += src_pitch_pixels;
+      dp += dst_pitch_pixels;
+    }
+  }
+  else
+  {
+    // No colorkey: a straight memcpy per row beats the inner branch.
+    const size_t bytes = (size_t)cols * 2;
+    for (int row = 0; row < rows; ++row)
+    {
+      SDL_memcpy(dp, sp, bytes);
+      sp += src_pitch_pixels;
+      dp += dst_pitch_pixels;
+    }
+  }
+
+  return true;
+}
+
