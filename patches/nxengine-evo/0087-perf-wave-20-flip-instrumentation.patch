+// DOS-PORT (patch 0087, Phase 9 wave 20 Lever A): per-phase flip()
+// timing samples + path-mix counters. Engaged only under
+// SDL_HINT_DOSKUTSU_FLIP_INSTR=1; default-OFF emits zero bytes / does
+// no work beyond the cached static-bool check.
+//
+// 100 raw uint64-ns samples per phase (~4 KB total static state). Each
+// flip() invocation adds one sample to each of {drain, dirty, present,
+// housekeeping, total}. _maybe_flush_phase_timing_audit fires every 100
+// flips, sorts a stack-local copy of each array, computes
+// {min, median, mean, p95, max} in ms (two-decimal), emits 5
+// `[flip-stat ...]` lines + 1 `[flip-counters ...]` line, then resets.
+//
+// The cadence (every 100 flips) aligns with _dc_tally_every_flips so
+// the existing audit-flush gate (_flip_total % _dc_tally_every_flips)
+// is the same trigger; our index always wraps cleanly at 100.
+//
+// Path-mix counters disambiguate which present primitive the engine
+// reached on each flip (per flush-instr's contract addendum):
+//   _present_path_dv_block      — SDL_DOSVesaDirectPresentFull
+//   _present_path_render_block  — SDL_RenderPresent (full-frame fallback)
+//   _present_path_partial_block — SDL_UpdateWindowSurfaceRects (dirty)
+//   _gen_bumps_block            — fb_state generation re-snapshot count
+//                                 (excludes first-call init; only
+//                                 mid-run re-inits — see
+//                                 Renderer::_direct_vesa_present)
+//   _housekeeping_skipped_block — DOSKUTSU_CACHE_WINSURF=1 ablation hits
+constexpr int _flip_phase_block_size = 100;
+Uint64 _flip_phase_samples_drain[_flip_phase_block_size]        = {};
+Uint64 _flip_phase_samples_dirty[_flip_phase_block_size]        = {};
+Uint64 _flip_phase_samples_present[_flip_phase_block_size]      = {};
+Uint64 _flip_phase_samples_housekeeping[_flip_phase_block_size] = {};
+Uint64 _flip_phase_samples_total[_flip_phase_block_size]        = {};
+int    _flip_phase_sample_idx = 0;
+Uint32 _present_path_dv_block        = 0;
+Uint32 _present_path_render_block    = 0;
+Uint32 _present_path_partial_block   = 0;
+Uint32 _gen_bumps_block              = 0;
+Uint32 _housekeeping_skipped_block   = 0;
+
+// DOS-PORT (patch 0087, Phase 9 wave 20 Lever A; contract extension
+// added per flush-instr DM 2026-04-30): per-helper brackets around the
+// SDL/0034 direct-VESA primitives that fire INSIDE _direct_vesa_present.
+// SDL/0035 shipped slow-path-only, so these engine-side brackets supply
+// the per-helper decomposition that fast-path bucketing would have.
+//
+//   program_palette  — SDL_DOSVesaDirectProgramPalette (palette DAC sync)
+//                      Fires only when master_palette->version drifts;
+//                      most flips this is a no-op (sample stays absent).
+//                      Sample compaction: store only ACTUAL firings;
+//                      block n = fires-this-block, may be < 100.
+//   get_generation   — SDL_DOSVesaDirectGetGeneration (cheap mode-change
+//                      probe). Fires once per _direct_vesa_present call,
+//                      i.e. once per flip while DV path engaged. Block n
+//                      tracks actual firings (= present_path_direct_vesa
+//                      in steady state).
+//
+// Both arrays sized at _flip_phase_block_size so they overflow-protect
+// the way the others do; in practice get_generation tops out at the DV
+// attempt count (≤ block size) and program_palette is even sparser.
+//
+// Skipped helpers per flush-instr's contract:
+//   - SDL_DOSVesaDirectGetState : only on gen bump → covered by gen_bumps
+//                                 counter; subsumed in housekeeping_ns.
+//   - SDL_DOSVesaDirectBankedFlush : engine doesn't call this directly.
+Uint64 _flip_phase_samples_program_palette[_flip_phase_block_size] = {};
+Uint64 _flip_phase_samples_get_generation[_flip_phase_block_size]  = {};
+int    _flip_phase_idx_pp = 0;
+int    _flip_phase_idx_gg = 0;
+
+// DOS-PORT (patch 0087, Phase 9 wave 20 Lever A): summarize a sample
+// array. n must be ≤ _flip_phase_block_size; copy is on-stack so total
+// stack pressure is ~4 KB across the 5 phases × invocation site (one
+// site, in _maybe_flush_phase_timing_audit). std::sort is O(n log n)
+// for n=100 → ~700 comparisons → << 1 ms on PODP83. Output ms with
+// nanosecond → millisecond conversion as a double; libfmt {:.2f}
+// gives two-decimal output for the LOG line per the contract.
+//
+// p95 index = floor(n * 0.95). For n=100 that's index 95 (the 96th
+// element of the sorted array, 0-indexed) — i.e. the value at the 95th
+// percentile boundary. min/max are positions 0 and n-1; median is n/2
+// (50 for n=100, the 51st element). mean is a sum-divided-by-n.
+struct _FlipPhaseStats
+{
+  double min_ms;
+  double med_ms;
+  double mean_ms;
+  double p95_ms;
+  double max_ms;
+};
+
+inline void _compute_flip_phase_stats(const Uint64 *samples, int n,
+                                       _FlipPhaseStats &out)
+{
+  Uint64 buf[_flip_phase_block_size];
+  for (int i = 0; i < n; i++) buf[i] = samples[i];
+  std::sort(buf, buf + n);
+  Uint64 sum = 0;
+  for (int i = 0; i < n; i++) sum += buf[i];
+  const Uint64 mean_ns = (n > 0) ? (sum / (Uint64)n) : 0;
+  const int p95_idx = (n > 0) ? ((int)((double)n * 0.95)) : 0;
+  out.min_ms  = (double)buf[0] / 1000000.0;
+  out.med_ms  = (double)buf[n / 2] / 1000000.0;
+  out.mean_ms = (double)mean_ns / 1000000.0;
+  out.p95_ms  = (double)buf[p95_idx >= n ? n - 1 : p95_idx] / 1000000.0;
+  out.max_ms  = (double)buf[n - 1] / 1000000.0;
+}
+
 // RAII helper — captures SDL_GetTicksNS at construction, accumulates
 // elapsed ns to the file-scope counters at destruction. Place at top of
 // each drawcall method to cover all return paths cleanly.
@@ -851,6 +972,73 @@ void _maybe_flush_phase_timing_audit()
            (unsigned long)doskutsu_kbd_first_irq_ticks,
            (unsigned long)doskutsu_kbd_irq_install_ticks,
            (unsigned long)doskutsu_kbd_irq_vector_at_install);
+  // DOS-PORT (patch 0087, Phase 9 wave 20 Lever A): emit per-phase flip
+  // statistics + path-mix counters when SDL_HINT_DOSKUTSU_FLIP_INSTR=1.
+  // Default OFF: skip the std::sort + 5 LOG_INFO emissions entirely.
+  // Sample arrays were filled by flip() at the cadence; here we
+  // summarize, emit, and reset. Format mirrors flush-instr's contract:
+  //   [flip-stat n=N phase=<name> min=X.XX med=Y.YY mean=Z.ZZ p95=P.PP max=M.MM ms]
+  //   [flip-counters present_path_direct_vesa=N ...]
+  // n echoes the sample-block size (always 100 in steady state; could
+  // be < 100 if the env var was flipped mid-run, but it's a static-
+  // const-bool so this never happens in practice).
+  if (_abl_flip_instr() && _flip_phase_sample_idx > 0)
+  {
+    const int n = _flip_phase_sample_idx;
+    const int n_pp = _flip_phase_idx_pp;
+    const int n_gg = _flip_phase_idx_gg;
+    _FlipPhaseStats st_drain, st_dirty, st_present, st_hk, st_total,
+                    st_pp, st_gg;
+    _compute_flip_phase_stats(_flip_phase_samples_drain,        n, st_drain);
+    _compute_flip_phase_stats(_flip_phase_samples_dirty,        n, st_dirty);
+    _compute_flip_phase_stats(_flip_phase_samples_present,      n, st_present);
+    _compute_flip_phase_stats(_flip_phase_samples_housekeeping, n, st_hk);
+    _compute_flip_phase_stats(_flip_phase_samples_total,        n, st_total);
+    // Order matches flush-instr's contract addendum: drain, dirty,
+    // present, program_palette, get_generation, housekeeping, total.
+    // program_palette and get_generation use their own n (firings, not
+    // total flips) per the contract — the reader infers fire frequency
+    // from `n=N` vs the other phases' `n=100`.
+    LOG_INFO("[flip-stat n={} phase=drain            min={:.2f} med={:.2f} mean={:.2f} p95={:.2f} max={:.2f} ms]",
+             n, st_drain.min_ms,   st_drain.med_ms,   st_drain.mean_ms,   st_drain.p95_ms,   st_drain.max_ms);
+    LOG_INFO("[flip-stat n={} phase=dirty            min={:.2f} med={:.2f} mean={:.2f} p95={:.2f} max={:.2f} ms]",
+             n, st_dirty.min_ms,   st_dirty.med_ms,   st_dirty.mean_ms,   st_dirty.p95_ms,   st_dirty.max_ms);
+    LOG_INFO("[flip-stat n={} phase=present          min={:.2f} med={:.2f} mean={:.2f} p95={:.2f} max={:.2f} ms]",
+             n, st_present.min_ms, st_present.med_ms, st_present.mean_ms, st_present.p95_ms, st_present.max_ms);
+    if (n_pp > 0)
+    {
+      _compute_flip_phase_stats(_flip_phase_samples_program_palette, n_pp, st_pp);
+      LOG_INFO("[flip-stat n={} phase=program_palette  min={:.2f} med={:.2f} mean={:.2f} p95={:.2f} max={:.2f} ms]",
+               n_pp, st_pp.min_ms,    st_pp.med_ms,    st_pp.mean_ms,    st_pp.p95_ms,    st_pp.max_ms);
+    }
+    else
+    {
+      // Zero-fire block: still emit a placeholder so the per-block log
+      // grep is uniform-shape regardless of palette-stability flips.
+      LOG_INFO("[flip-stat n=0 phase=program_palette  min=0.00 med=0.00 mean=0.00 p95=0.00 max=0.00 ms]");
+    }
+    if (n_gg > 0)
+    {
+      _compute_flip_phase_stats(_flip_phase_samples_get_generation, n_gg, st_gg);
+      LOG_INFO("[flip-stat n={} phase=get_generation   min={:.2f} med={:.2f} mean={:.2f} p95={:.2f} max={:.2f} ms]",
+               n_gg, st_gg.min_ms,    st_gg.med_ms,    st_gg.mean_ms,    st_gg.p95_ms,    st_gg.max_ms);
+    }
+    else
+    {
+      LOG_INFO("[flip-stat n=0 phase=get_generation   min=0.00 med=0.00 mean=0.00 p95=0.00 max=0.00 ms]");
+    }
+    LOG_INFO("[flip-stat n={} phase=housekeeping     min={:.2f} med={:.2f} mean={:.2f} p95={:.2f} max={:.2f} ms]",
+             n, st_hk.min_ms,      st_hk.med_ms,      st_hk.mean_ms,      st_hk.p95_ms,      st_hk.max_ms);
+    LOG_INFO("[flip-stat n={} phase=total            min={:.2f} med={:.2f} mean={:.2f} p95={:.2f} max={:.2f} ms]",
+             n, st_total.min_ms,   st_total.med_ms,   st_total.mean_ms,   st_total.p95_ms,   st_total.max_ms);
+    LOG_INFO("[flip-counters present_path_direct_vesa={} present_path_render={} "
+             "present_path_partial={} gen_bumps={} housekeeping_skipped={}]",
+             (unsigned long)_present_path_dv_block,
+             (unsigned long)_present_path_render_block,
+             (unsigned long)_present_path_partial_block,
+             (unsigned long)_gen_bumps_block,
+             (unsigned long)_housekeeping_skipped_block);
+  }
   _drawcall_accum_ns_block = 0;
   _drawcall_count_block = 0;
   _flip_inner_accum_ns_block = 0;
@@ -859,6 +1047,20 @@ void _maybe_flush_phase_timing_audit()
   _direct_vesa_presents_block = 0;
   _direct_vesa_present_accum_ns_block = 0;
   _direct_vesa_present_failed_block = 0;
+  // patch 0087 (wave 20 Lever A): reset per-phase sample buffers + path-
+  // mix counters. Sample contents are overwritten next flip; index reset
