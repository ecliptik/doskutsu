index 2a332ec..5f28cc2 100644
--- a/src/sound/Ogg.h
+++ b/src/sound/Ogg.h
@@ -4,11 +4,9 @@
 
 #include "../Singleton.h"
 
-#include <SDL_mixer.h>
+#include <SDL3_mixer/SDL_mixer.h>
 #include <string>
 
-typedef void (*music_finished_cb)(void);
-
 namespace NXE
 {
 namespace Sound
@@ -16,8 +14,8 @@ namespace Sound
 
 struct oggSong
 {
-  Mix_Music *intro = nullptr;
-  Mix_Music *loop  = nullptr;
+  MIX_Audio *intro = nullptr;
+  MIX_Audio *loop  = nullptr;
   bool playing     = false;
   int volume       = 75;
 
@@ -58,6 +56,13 @@ private:
   oggSong _song;
   bool _do_loop = false;
   bool _looped  = false;
+
+  // DOS-PORT: SDL3_mixer model: a single MIX_Track owns the music
+  // playback "slot" (no global Mix_PlayMusic equivalent). Lazy-created
+  // on first play from SoundManager's mixer; never explicitly destroyed
+  // — owned by the mixer, cleaned up when MIX_DestroyMixer runs in
+  // SoundManager::shutdown().
+  MIX_Track *_music_track = nullptr;
 };
 
 }; // namespace Sound
