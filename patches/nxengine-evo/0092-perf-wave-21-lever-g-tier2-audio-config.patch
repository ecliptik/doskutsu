@@ -46,6 +61,68 @@ bool SoundManager::init()
 {
   LOG_INFO("Sound system init");
 
+  // DOS-PORT (patch 0092, Phase 9 wave 21 Lever G): Tier-2 audio
+  // config selection. Read SDL_HINT_DOSKUTSU_AUDIO_TIER2 (strict-1
+  // match per CLAUDE.md convention); when set, flip global SAMPLE_RATE
+  // + AUDIO_CHANNELS to 11025 mono AND pin the SDL3 audio buffer size
+  // to 256 sample frames via SDL_HINT_AUDIO_DEVICE_SAMPLE_FRAMES.
+  //
+  // Buffer-pin reasoning (load-bearing for the lever's mechanism, per
+  // docs/PHASE9-LEVER-G-PLAN.md § 2.3): without explicit pin, SDL3's
+  // default heuristic preserves ~11.6 ms latency target → would pick
+  // 128 samples at 11025 mono → IRQ rate stays at ~86 Hz → the
+  // ~6.5 ms IRQ-rate-halving savings collapse. Pin to 256 explicitly:
+  //   11025 mono × 256 samples = 23.2 ms latency = ~43 Hz IRQ rate
+  // = halved IRQ rate = the actual lever gain. Latency goes 11.6 →
+  // 23.2 ms (one extra 30 fps frame); acceptable for non-rhythm games.
+  //
+  // Tier-1 path (env unset / not "1"): SAMPLE_RATE / AUDIO_CHANNELS
+  // stay at their initial values (22050 / 2); SDL3's existing buffer
+  // heuristic chooses 512 frames per the patch-0066 comment below.
+  // Behaviorally bit-identical to pre-0092.
+  //
+  // Order-of-operations note: this MUST run BEFORE MIX_CreateMixerDevice
+  // (which reads SAMPLE_RATE via the spec.freq assignment) AND before
+  // any Pixtone/Organya singleton construction (Pixtone.h:128's
+  // resampled_rate[0] = SAMPLE_RATE in-class-init evaluates at Pixtone
+  // object construction; deferred to post-init by lazy singleton
+  // semantics + SoundManager::init() driving the first construction
+  // chain).
+  {
+    const char *tier2 = SDL_GetHint("SDL_HINT_DOSKUTSU_AUDIO_TIER2");
+    const bool tier2_on = tier2 && tier2[0] == '1' && tier2[1] == 0;
+    if (tier2_on)
