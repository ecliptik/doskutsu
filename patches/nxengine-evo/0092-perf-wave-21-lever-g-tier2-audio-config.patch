+               "into Tier-2 (11025 Hz mono, 256-frame buffer) for fps "
+               "gain on Tier 2/3 hardware (per docs/HARDWARE.md hardware "
+               "tiers + docs/PHASE9-LEVER-G-PLAN.md mechanism).",
+               (unsigned long)::SAMPLE_RATE, (unsigned long)::AUDIO_CHANNELS);
+    }
+  }
+
   // DOS-PORT (patch 0066, Phase 9 wave 13.5/13.6): keep SDL3's default
   // sample_frames=512 (=2048 B chunks, =23 ms audio per chunk).
   // Wave 13.5 experiment (real-HW PODP 5V83) tested 512 vs 1024 vs 2048:
@@ -82,8 +159,12 @@ bool SoundManager::init()
