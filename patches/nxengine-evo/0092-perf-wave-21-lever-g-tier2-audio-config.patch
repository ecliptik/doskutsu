+      ::SAMPLE_RATE    = 11025;
+      ::AUDIO_CHANNELS = 1;
+      // Pin buffer size to 256 frames so the IRQ rate halves (43 Hz vs
+      // Tier-1's 86 Hz). SDL_SetHintWithPriority OVERRIDE so a user-
+      // set SDL_HINT_AUDIO_DEVICE_SAMPLE_FRAMES doesn't accidentally
+      // un-pin and collapse the lever's mechanism.
+      SDL_SetHintWithPriority(SDL_HINT_AUDIO_DEVICE_SAMPLE_FRAMES,
