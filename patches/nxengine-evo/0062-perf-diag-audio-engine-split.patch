+#ifndef NXE_DIAGNOSTIC_TIMERS_H
+#define NXE_DIAGNOSTIC_TIMERS_H
+
+// DOS-PORT (patch 0062, Phase 9 wave 13.1-D2 Lever B diagnostics): split
+// timing for the "audio+engine_ms" gap surfaced by 12.5-D's phase-timing
+// audit. 13.1's SAMPLE_RATE 44100->22050 reduction had near-zero impact
+// on that gap on real HW (predicted -50ms; measured +17ms within noise),
+// implying the audio mixer is NOT the dominant cost there. We split
+// audio_mixer (Organya synth callback) from engine_tick (Game::tick) so
+// the next pivot is data-driven instead of assumption-based.
+//
+// Storage variables are defined in Renderer.cpp alongside the wave-12.5-D
+// phase-timing infrastructure (single source of truth for the audit
+// flush). Other translation units (Organya.cpp, game.cpp) hit them via
+// the RAII helpers below — placing one timer at the top of a function
+// times that function's entire body, covering all return paths cleanly.
+
+#include <SDL3/SDL.h>
+#include <cstdint>
+
+namespace NXE
+{
+namespace Diag
+{
+
+// Counter storage lives in Renderer.cpp (extern decls below match
+// definitions there). Block stats reset every 100 flips; global stats
+// run for the whole process.
+extern std::uint64_t g_audio_mix_accum_ns_block;
+extern std::uint64_t g_audio_mix_accum_ns_global;
+extern int g_audio_mix_count_block;
+extern int g_audio_mix_count_global;
+extern std::uint64_t g_engine_tick_accum_ns_block;
+extern std::uint64_t g_engine_tick_accum_ns_global;
+extern int g_engine_tick_count_block;
+extern int g_engine_tick_count_global;
+
+// RAII helper for the Organya stream callback (called by SDL3 audio
+// thread when more samples are needed). Place at top of the callback.
+struct AudioMixerTimer
+{
+  std::uint64_t t0;
+  AudioMixerTimer() : t0(SDL_GetTicksNS()) {}
+  ~AudioMixerTimer()
+  {
+    const std::uint64_t dt = SDL_GetTicksNS() - t0;
+    g_audio_mix_accum_ns_block += dt;
+    g_audio_mix_accum_ns_global += dt;
+    ++g_audio_mix_count_block;
+    ++g_audio_mix_count_global;
+  }
+};
+
+// RAII helper for Game::tick() — the per-frame engine-logic entry point
+// invoked from main.cpp's run_tick(). Sibling costs in run_tick (input
+// poll, runFade) are NOT measured by this timer; they fall into the
+// "misc" remainder = (audio+engine_ms - audio_mixer_ms - engine_tick_ms).
+struct EngineTickTimer
+{
+  std::uint64_t t0;
+  EngineTickTimer() : t0(SDL_GetTicksNS()) {}
+  ~EngineTickTimer()
+  {
+    const std::uint64_t dt = SDL_GetTicksNS() - t0;
+    g_engine_tick_accum_ns_block += dt;
+    g_engine_tick_accum_ns_global += dt;
+    ++g_engine_tick_count_block;
+    ++g_engine_tick_count_global;
+  }
+};
+
+}  // namespace Diag
+}  // namespace NXE
+
+#endif  // NXE_DIAGNOSTIC_TIMERS_H
