+// DOS-PORT (patch 0062, Phase 9 wave 13.1-D2): audio-mixer / engine-tick
+// split audit. Reads counters bumped by AudioMixerTimer (Organya stream
+// callback) and EngineTickTimer (Game::tick) — see Utils/diagnostic_-
+// timers.h. The two new readings PLUS the 12.5-D derived audio+engine_ms
+// give us a 4-way decomposition of inter-flip:
+//   inter_flip = flip_inner + drawcall + (audio_mix + engine_tick + misc)
+// where misc = (12.5-D's audio+engine derived) - audio_mix - engine_tick.
+// "misc" captures DPMI overhead, file I/O, event pump, input poll,
+// runFade — anything in run_tick() outside Game::tick().
+void _maybe_flush_audio_engine_split_audit()
+{
+  if ((_flip_total % _dc_tally_every_flips) != 0) return;
+  if (NXE::Diag::g_audio_mix_count_block == 0
+      && NXE::Diag::g_engine_tick_count_block == 0)
+    return;
+
+  // Per-flip averages, x10 (one-decimal). Computed in ms by dividing
+  // ns_total by (flips * 1_000_000) then x10.
+  const long long am_avg_ms_x10 = _dc_tally_every_flips
+      ? (long long)((NXE::Diag::g_audio_mix_accum_ns_block * 10ull)
+                    / ((std::uint64_t)_dc_tally_every_flips * 1000000ull))
+      : 0;
+  const long long et_avg_ms_x10 = _dc_tally_every_flips
+      ? (long long)((NXE::Diag::g_engine_tick_accum_ns_block * 10ull)
+                    / ((std::uint64_t)_dc_tally_every_flips * 1000000ull))
+      : 0;
+  // Per-call averages in microseconds (x10 = one-decimal).
+  const long long am_per_call_us_x10 = (NXE::Diag::g_audio_mix_count_block > 0)
+      ? (long long)((NXE::Diag::g_audio_mix_accum_ns_block * 10ull)
+                    / ((std::uint64_t)NXE::Diag::g_audio_mix_count_block * 1000ull))
+      : 0;
+  const long long et_per_call_us_x10 = (NXE::Diag::g_engine_tick_count_block > 0)
+      ? (long long)((NXE::Diag::g_engine_tick_accum_ns_block * 10ull)
+                    / ((std::uint64_t)NXE::Diag::g_engine_tick_count_block * 1000ull))
+      : 0;
+
+  LOG_INFO("audio/engine split block {}: audio_mixer_calls={} "
+           "audio_mixer_ms_x10={} engine_tick_calls={} engine_tick_ms_x10={} "
+           "(per-flip avg; per-call us_x10: audio_mix={} engine_tick={}; "
+           "global ns: audio_mix={} engine_tick={})",
+           _dc_block_idx,
+           NXE::Diag::g_audio_mix_count_block, am_avg_ms_x10,
+           NXE::Diag::g_engine_tick_count_block, et_avg_ms_x10,
+           am_per_call_us_x10, et_per_call_us_x10,
+           (long long)NXE::Diag::g_audio_mix_accum_ns_global,
+           (long long)NXE::Diag::g_engine_tick_accum_ns_global);
+
+  NXE::Diag::g_audio_mix_accum_ns_block = 0;
+  NXE::Diag::g_audio_mix_count_block = 0;
+  NXE::Diag::g_engine_tick_accum_ns_block = 0;
+  NXE::Diag::g_engine_tick_count_block = 0;
+}
+
 // DOS-PORT (patch 0052, Phase 9 wave 9 Lever A): drawcall-fingerprint
