+// ============================================================================
+// DOSKUTSU patch 0034 (Phase 9 wave 18) — direct-VESA public API.
+//
+// Thin wrappers around the static fb_state cache + SwitchBank() +
+// BankedDosmemput() + ProgramVGADAC() primitives that engines can call to
+// bypass SDL_RenderPresent / SDL_UpdateWindowSurface. See
+// include/SDL3/SDL_dosvesa_directaccess.h for full documentation and
+// docs/PHASE9-WAVE-17-18-PLAN.md § 4 for the wave-18 plan.
+//
+// Workspace-local patch; never upstreamed (per project sdl_ai_policy memory).
+// ============================================================================
+
+bool SDL_DOSVesaDirectGetState(SDL_DOSVesaDirectState *out)
+{
+    if (!out) {
+        return false;
+    }
+    SDL_zerop(out);
+
+    // The fast path is engaged iff fb_state.direct_fb is true AND we have
+    // a usable VRAM access path (vram_ptr for LFB, vram_phys for banked).
+    // This mirrors the guard in DOSVESA_UpdateWindowFramebuffer's fast-path
+    // dispatch — same predicate keeps the two layers in sync.
+    if (!fb_state.direct_fb || (!fb_state.vram_ptr && !fb_state.vram_phys)) {
+        return false;
+    }
+
+    out->valid            = true;
+    out->use_dosmemput    = fb_state.use_dosmemput;
+    out->banked_multibank = fb_state.banked_multibank;
+    out->pitches_match    = fb_state.pitches_match;
+    out->vram_w           = fb_state.vram_w;
+    out->vram_h           = fb_state.vram_h;
+    out->vram_pitch       = fb_state.vram_pitch;
+    out->bpp              = fb_state.bpp;
+    out->fb_size          = fb_state.fb_size;
+    out->vram_ptr         = fb_state.vram_ptr;
+    out->vram_phys        = fb_state.vram_phys;
+    out->win_base         = fb_state.win_base;
+    out->win_gran_bytes   = fb_state.win_gran_bytes;
+    out->win_size_bytes   = fb_state.win_size_bytes;
+    out->win_func_ptr     = fb_state.win_func_ptr;
+    // Forward-compat for future page-flip revival (post-patch 0014 the
+    // LFB direct-FB path is single-buffered and vram_ptr already includes
+    // display_start_offset — page_offset is purely additive on top).
+    // Today we always emit 0; if double-buffering is ever rewired,
+    // populate_fb_state_for_direct_fb will start emitting the back-page
+    // byte offset and engine code that adds page_offset to its dst_offset
+    // becomes correct without any engine-side change.
+    out->page_offset      = 0;
+    return true;
+}
+
+Uint32 SDL_DOSVesaDirectGetGeneration(void)
+{
+    return _doskutsu_dvd_generation;
+}
+
+void SDL_DOSVesaDirectSwitchBank(int bank, int *current_bank, Uint32 win_func_ptr)
+{
+    // SwitchBank is SDL_FORCE_INLINE static — same TU, so the inline
+    // expansion lands here. Behavior is identical to the production
+    // BankedDosmemput's inner SwitchBank call (same bx=0 Window A
+    // selector, same PMI/INT 10h dispatch). Sentinel test in patch 0028
+    // proved this primitive's read/write parity, so direct-VESA callers
+    // get the same correctness guarantee.
+    if (!current_bank) {
+        return; // defensive: refuse without the memoization variable.
+    }
+    SwitchBank(bank, current_bank, win_func_ptr);
+}
+
+void SDL_DOSVesaDirectBankedFlush(const void *src, Uint32 nbytes,
+                                   Uint32 dst_offset,
+                                   const SDL_DOSVesaDirectState *st,
+                                   int *current_bank)
+{
+    if (!src || !nbytes || !st || !current_bank) {
+        return;
+    }
+    if (!st->valid || !st->use_dosmemput) {
+        // No-op for LFB-path snapshots — caller should use SDL_memcpy
+        // through st->vram_ptr instead. Documented in the header; we
+        // return silently rather than SDL_SetError since this is the
+        // hot path and the caller may have already branched on
+        // st->use_dosmemput.
+        return;
+    }
+    if (!st->win_gran_bytes || !st->win_size_bytes) {
+        // Defensive: a banked snapshot with zero window granularity is
+        // a corrupt populate (shouldn't happen — populate gates on
+        // win_a_segment + win_size > 0 before setting use_dosmemput).
+        return;
+    }
+
+    // BankedDosmemput is SDL_FORCE_INLINE static; same-TU expansion. We
+    // pass the snapshot's win_* metadata so the bank-walk math runs on
+    // the engine's intended frame, not whatever fb_state happens to be
+    // mid-mode-change. (In practice the snapshot fields mirror fb_state
+    // because the engine should re-snapshot on generation bump, but
+    // passing through is the conservative choice.)
+    BankedDosmemput((const Uint8 *)src, nbytes, dst_offset,
+                    st->win_gran_bytes, st->win_size_bytes,
+                    st->win_base, st->win_func_ptr, current_bank);
+}
+
+void SDL_DOSVesaDirectProgramPalette(const SDL_Palette *palette)
+{
+    if (!palette) {
+        return;
+    }
+    // ProgramVGADAC takes a non-const SDL_Palette * but only reads from
+    // it (writes to ports 0x3C8 / 0x3C9). The cast is safe; the
+    // const-correctness on the public API is just hygiene for callers
+    // who hold a const palette pointer (e.g. from SDL_GetSurfacePalette
+    // when iterating).
+    ProgramVGADAC((SDL_Palette *)palette);
+}
+
+bool SDL_DOSVesaDirectPresentFull(const SDL_DOSVesaDirectState *st,
+                                   const void *pixels)
+{
+    if (!st || !st->valid || !pixels) {
+        return false;
+    }
+    if (!st->pitches_match) {
+        // Convenience path requires pitches_match — the per-row case is
+        // an engine concern (different stride means the engine must
+        // walk rows itself). Documented in the header.
+        return false;
+    }
+    if (!st->use_dosmemput) {
+        // LFB nearptr — single SDL_memcpy. vram_ptr already includes
+        // display_start_offset; page_offset is the future-page-flip
+        // hook and is 0 in the current build.
+        if (!st->vram_ptr) {
+            return false;
+        }
+        SDL_memcpy(st->vram_ptr + st->page_offset, pixels, st->fb_size);
+        return true;
+    }
+    // Banked path: single dosmemput for single-bank, BankedDosmemput
+    // walk for multi-bank. dst_offset is page_offset (0 today; future
+    // page-flip back-page offset).
+    if (!st->banked_multibank) {
+        dosmemput(pixels, st->fb_size, st->vram_phys + st->page_offset);
+        return true;
+    }
+    int current_bank = -1;
+    BankedDosmemput((const Uint8 *)pixels, st->fb_size, st->page_offset,
+                    st->win_gran_bytes, st->win_size_bytes,
+                    st->win_base, st->win_func_ptr, &current_bank);
+    return true;
 }
 
