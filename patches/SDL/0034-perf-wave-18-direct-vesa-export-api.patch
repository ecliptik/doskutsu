+ * indicates an unsupported configuration. On false the caller should
+ * fall back to SDL_UpdateWindowSurface.
+ *
+ * \param st snapshot from SDL_DOSVesaDirectGetState().
+ * \param pixels source pixel buffer; must be at least `st->fb_size`
+ *               bytes and have pitch matching `st->vram_pitch` (check
+ *               `st->pitches_match` before calling).
+ * \returns true on success, false on invalid input.
+ *
+ * \threadsafety Single-threaded.
+ *
+ * \since This function is available since SDL 3.2.0 (DOSKUTSU patch 0034).
+ */
+extern SDL_DECLSPEC bool SDLCALL SDL_DOSVesaDirectPresentFull(const SDL_DOSVesaDirectState *st,
+                                                               const void *pixels);
