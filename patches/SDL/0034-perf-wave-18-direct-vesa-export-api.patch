+ *
+ * \since This function is available since SDL 3.2.0 (DOSKUTSU patch 0034).
+ */
+extern SDL_DECLSPEC void SDLCALL SDL_DOSVesaDirectProgramPalette(const SDL_Palette *palette);
+
+/**
+ * Convenience: present a full-screen frame via the cheapest path
+ * available in `st`.
+ *
+ * Picks LFB memcpy or banked dosmemput automatically based on
+ * `st->use_dosmemput` and `st->banked_multibank`. For the multi-bank
+ * banked path, allocates a per-call `current_bank=-1` and invokes
+ * SDL_DOSVesaDirectBankedFlush() under the hood.
+ *
+ * Suitable as a step-1 integration target — get the direct-VESA path
+ * working with one call before splitting into a per-rect loop. Once
+ * dirty-rect dispatch is implemented on the engine side, switch to
+ * SDL_DOSVesaDirectBankedFlush() / SDL_memcpy() per rect for finer
+ * control.
