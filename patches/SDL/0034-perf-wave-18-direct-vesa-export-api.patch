+                                                               Uint32 dst_offset,
+                                                               const SDL_DOSVesaDirectState *st,
+                                                               int *current_bank);
+
+/**
+ * Program the VGA DAC from an SDL_Palette, for INDEX8 modes.
+ *
+ * Wraps the SDL3-DOS internal ProgramVGADAC() primitive — writes 256
+ * RGB triples (R, G, B in sequence, 6-bit values) to ports 0x3C8 / 0x3C9.
+ *
+ * The direct-VESA path bypasses SDL_RenderPresent's automatic palette
+ * sync, so callers must invoke this themselves whenever their
+ * `SDL_Palette::version` changes. Compare your remembered version
+ * against `palette->version` and only call when they differ.
+ *
