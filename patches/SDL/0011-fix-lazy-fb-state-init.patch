@@ -323,50 +404,15 @@ bool DOSVESA_CreateWindowFramebuffer(SDL_VideoDevice *device, SDL_Window *window
 
             SDL_SetSurfaceProperty(SDL_GetWindowProperties(window), DOS_SURFACE, surface);
 
-            fb_state.surface = surface;
