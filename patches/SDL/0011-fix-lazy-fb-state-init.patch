 1 file changed, 147 insertions(+), 55 deletions(-)

diff --git a/src/video/dos/SDL_dosframebuffer.c b/src/video/dos/SDL_dosframebuffer.c
index ee69c3c95..418189449 100644
--- a/src/video/dos/SDL_dosframebuffer.c
+++ b/src/video/dos/SDL_dosframebuffer.c
@@ -273,6 +273,96 @@ static bool CreateNormalFramebuffer(SDL_VideoDevice *device, SDL_Window *window,
     return true;
 }
 
+// DOSKUTSU helper (patch 0011 — Phase 9 lever 1 lifecycle fix, Path B).
+//
+// Populate fb_state's "fast-path" fields (direct_fb=true plus all the
+// vram/win/pitch derived data) from the device's current_mode and an
+// already-allocated system-RAM surface. Used by:
+//
+//   - DOSVESA_CreateWindowFramebuffer (the original happy path; surface
+//     was just created by CreateSystemSurface), AND
+//
+//   - DOSVESA_UpdateWindowFramebuffer (the lazy re-init path; called
+//     when fb_state was invalidated by a mode-change but
+//     CreateWindowFramebuffer wasn't called again to re-populate it,
+//     leaving direct_fb=false / vram_ptr=NULL with a still-attached
+//     window->surface).
+//
+// On entry, fb_state.surface and fb_state.fb_size etc may or may not
+// already be set — the caller controls that. On exit, fb_state is
+// internally consistent: direct_fb=true, all derived fields match the
+// current mode + surface dimensions. Returns false if no usable VRAM
+// path is available (caller should fall back to the normal path).
+//
+// IMPORTANT: this function does NOT call SDL_zero(fb_state) — leaving
+// that to the caller. CreateWindowFramebuffer zeros first; the lazy
+// re-init in UpdateWindowFramebuffer must NOT zero, because doing so
+// would discard fb_state.surface that we want to preserve.
+static bool populate_fb_state_for_direct_fb(SDL_VideoDevice *device,
+                                            SDL_Surface *surface)
+{
+    SDL_VideoData *data = device->internal;
+    const SDL_DisplayMode *mode = &data->current_mode;
+    const SDL_DisplayModeData *mdata = mode->internal;
+
+    if (!mdata || !surface) {
+        return false;
+    }
+
+    int vram_pitch = mdata->pitch;
+
+    // Check if we have any usable VRAM access path (banked or LFB).
+    const bool banked_usable = mdata->win_a_segment && mdata->win_size > 0 &&
+                               (mdata->win_a_attributes & VBE_WINATTR_USABLE) == VBE_WINATTR_USABLE;
+    const bool lfb_usable = !data->banked_mode && data->mapping.size;
+
+    if (!banked_usable && !lfb_usable) {
+        return false;
+    }
+
+    // DOSKUTSU patch 0011: with SDL_HINT_DOS_PREFER_LFB set, prefer LFB
+    // nearptr over banked dosmemput when both are usable. The default
+    // ordering (banked-first) is what the SDL3-DOS PR #15377 author tuned
+    // for; on Mach64 + M64VBE the banked window is bandwidth-bound
+    // (~500 KB/s) and LFB is 5-10× faster. PREFER_LFB applies the same
+    // policy at this VRAM-path-selection layer that it applies at the
+    // mode-selection layer (SDL_dosmodes.c LFB-decision).
+    const bool prefer_lfb = SDL_GetHintBoolean(SDL_HINT_DOS_PREFER_LFB, false);
+    const bool use_lfb_path = lfb_usable && (prefer_lfb || !banked_usable);
+
+    fb_state.surface = surface;
+    fb_state.direct_fb = true;
+    fb_state.vram_pitch = vram_pitch;
+    fb_state.vram_w = mdata->w;
+    fb_state.vram_h = mdata->h;
+    fb_state.bpp = SDL_BYTESPERPIXEL(mode->format);
+    fb_state.pixels = (Uint8 *)surface->pixels;
+    fb_state.src_pitch = surface->pitch;
+    fb_state.fb_size = (Uint32)vram_pitch * mdata->h;
+    fb_state.pitches_match = (surface->pitch == vram_pitch);
+
+    if (use_lfb_path) {
+        // LFB nearptr — DPMI-mapped VRAM linear address.
+        int back_page = data->page_flip_available ? (1 - data->current_page) : 0;
+        fb_state.vram_ptr = (Uint8 *)DOS_PhysicalToLinear(data->mapping.address) + data->page_offset[back_page];
+        fb_state.vram_phys = 0;
+        fb_state.use_dosmemput = false;
+        fb_state.banked_multibank = false;
+    } else {
+        // Banked window via dosmemput (default fast path).
+        Uint32 win_bytes = (Uint32)mdata->win_size * 1024;
+        fb_state.use_dosmemput = true;
+        fb_state.vram_ptr = NULL;
+        fb_state.vram_phys = (Uint32)mdata->win_a_segment << 4;
+        fb_state.win_base = fb_state.vram_phys;
+        fb_state.win_gran_bytes = (Uint32)mdata->win_granularity * 1024;
+        fb_state.win_size_bytes = win_bytes;
+        fb_state.win_func_ptr = mdata->win_func_ptr;
+        fb_state.banked_multibank = (fb_state.fb_size > win_bytes);
+    }
+    return true;
+}
+
