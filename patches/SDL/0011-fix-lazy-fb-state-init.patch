             *pitch = surface->pitch;
@@ -559,7 +605,7 @@ bool DOSVESA_UpdateWindowFramebuffer(SDL_VideoDevice *device, SDL_Window *window
         if (lc_calls == 1 || (lc_calls % 100) == 0) {
             DOSKUTSU_LC_LOG("UpdateWindowFramebuffer #%d: window=%p direct_fb=%d "
                             "vram_ptr=%p surface=%p lfb_surface=%p fb_size=%lu "
-                            "vram_w=%d vram_h=%d window->surface=%p window->surface_valid=%d\n",
+                            "vram_w=%d vram_h=%d window->surface=%p window->surface_valid=%d",
                             lc_calls, (void *)window,
                             (int)fb_state.direct_fb, (void *)fb_state.vram_ptr,
                             (void *)fb_state.surface, (void *)fb_state.lfb_surface,
@@ -570,6 +616,52 @@ bool DOSVESA_UpdateWindowFramebuffer(SDL_VideoDevice *device, SDL_Window *window
         }
     }
 
+    // DOSKUTSU patch 0011 — Phase 9 lever 1, Path B: lazy re-init.
+    //
+    // The bug: when SDL3-DOS does a mode-change between
+    // CreateWindowFramebuffer and the next UpdateWindowFramebuffer,
+    // DOSVESA_InvalidateCachedFramebuffer clears fb_state.direct_fb,
+    // .vram_ptr, .vram_phys, .use_dosmemput, .lfb_surface — but
+    // CreateWindowFramebuffer is NOT called again to re-populate those
+    // fields with the new mode's values. The fast-path guard further
+    // down then evaluates false (direct_fb=false), and the call falls
+    // into the normal path. The normal path is broken on Mach64 (per
+    // Phase 7 wall) AND much slower than the fast path even when it
+    // works, so we lose the LFB perf win.
+    //
+    // The fix: detect the invalidated condition here, just before any
+    // logging or VRAM access, and call populate_fb_state_for_direct_fb
+    // to re-derive direct_fb / vram_ptr / vram_phys / win_* from
+    // device->internal->current_mode. The system-RAM surface is reused
+    // as-is from the existing window->surface (SDL_UpdateWindowSurfaceRects
+    // already validated window->surface_valid before calling us, so it
+    // points at a live surface).
+    //
+    // The condition: the hint is set (we want fast-path), the mode is
+    // set (current_mode.internal != NULL), but direct_fb is false (so
+    // either invalidate ran since the last create, or create itself
+    // never ran). Skip if we're in the normal path by intent (no hint).
+    if (window && window->surface && vdata->current_mode.internal &&
+        !fb_state.direct_fb &&
+        SDL_GetHintBoolean(SDL_HINT_DOS_ALLOW_DIRECT_FRAMEBUFFER, false)) {
+        // The previous fb_state.surface (if any) is from a stale mode
+        // and may already have been destroyed by SDL_GetWindowSurface's
+        // recreation path. We don't free it (SDL owns it through the
+        // window's surface property). Just overwrite the pointer.
+        bool ok = populate_fb_state_for_direct_fb(device, window->surface);
+        DOSKUTSU_LC_LOG("UpdateWindowFramebuffer: lazy-reinit ok=%d direct_fb=%d "
+                        "use_dosmemput=%d vram_ptr=%p vram_phys=0x%08lx fb_size=%lu "
+                        "vram_w=%d vram_h=%d (mode_id=0x%X)",
+                        (int)ok, (int)fb_state.direct_fb, (int)fb_state.use_dosmemput,
+                        (void *)fb_state.vram_ptr, (unsigned long)fb_state.vram_phys,
+                        (unsigned long)fb_state.fb_size,
+                        fb_state.vram_w, fb_state.vram_h,
+                        vdata->current_mode.internal->mode_id);
+        // If populate fails, fall through — the normal path (further
+        // down) will try its best (and probably also fail; that's the
+        // pre-patch behaviour).
+    }
+
     // DOSKUTSU diagnostic header (patches/SDL/0002, task #21; routed
     // through shared doskutsu_dbg_log by patch 0009).
     ++_doskutsu_dbg_call_total;
