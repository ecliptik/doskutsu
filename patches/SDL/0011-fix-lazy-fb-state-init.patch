+            // Patch 0011: factor populate-fb_state into helper so the lazy
+            // re-init in UpdateWindowFramebuffer can call the same code.
+            if (!populate_fb_state_for_direct_fb(device, surface)) {
+                // populate failed (shouldn't happen — we checked usability
