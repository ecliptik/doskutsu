From 8868fd14c81dcb2b0b7d6f6539c562747eb436a1 Mon Sep 17 00:00:00 2001
From: Micheal Waltz <micheal@ecliptik.com>
Date: Sat, 25 Apr 2026 14:05:06 -0700
Subject: [PATCH] [DOSKUTSU] dos: trace DOSVESA_UpdateWindowFramebuffer flush
 path
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Phase 7 black-screen diagnostic (task #21). NXEngine's diagnostic
patches 0030 + 0031 narrowed the bug to the framebuffer flush path:
- NXEngine queues hundreds of valid SDL_RenderTexture calls per flip.
- SDL_RenderPresent returns true 1000/1000 calls (zero failures).
- Renderer is the software backend (correct for DOS).
- Window size and framebuffer-pixel size both 320x240 (matching).
- Logical-presentation 320x240 LETTERBOX active.
- Yet the visible framebuffer stays pure black.

The chain SDL_RenderPresent -> SW_RenderPresent ->
SDL_UpdateWindowSurface -> DOSVESA_UpdateWindowFramebuffer reports
success at every layer, but pixels never reach the display.

This patch instruments DOSVESA_UpdateWindowFramebuffer to discriminate
between four failure modes:

  (a) The fast-path guard at line ~494 fails (direct_fb=false or
      vram_ptr==0 && vram_phys==0), so the function takes the normal
      path -- or returns true without writing. Fb_state init didn't
      establish a usable framebuffer.

  (b) Guard passes, but fb_state.pixels (the source backbuffer)
      contains all zeros, meaning SW_RenderPresent isn't actually
      drawing into the window surface despite reporting success.

  (c) Guard passes, source pixels have content, but VRAM readback
      after the dosmemput/memcpy doesn't match what was written.
      Bank-switching or address-calculation bug.

  (d) Source has content, VRAM matches after write, but display still
      black. VESA bank/page/palette/DAC state issue downstream of
      this function.

Output goes to /sdldbg.log on the staged C: drive (sibling of
NXEngine's /debug.log) instead of stdout/stderr -- by the time this
code runs, the DOS console has been switched to a VESA graphics mode
where text-mode prints are invisible.

Throttling: first call dumps the entire fb_state struct + a 16-byte
spot-check of fb_state.pixels and (post-write) of vram_phys. Every
100th call repeats the spot-checks. The log call rate at ~32 fps is
~0.32 entries/sec, easily readable.

Why DOS needs this: the bug is DOS-specific (and likely DOSBox-X-
specific given that PR #15377's author flagged "no real hardware
testing"). Diagnostic-only — once the failure mode is identified,
the actual fix lands as a separate patch.

The diagnostic file output is left always-on rather than gated by an
SDL hint. Removing the patch entirely is the correct path once the
fix is in; gating adds complexity without obvious benefit for
something we expect to revert.

Per workspace policy (memory note "SDL upstream — local patches only,
no upstream"): this patch is local-only and will never be PR'd
upstream, sidestepping vendor/SDL/CLAUDE.md's no-AI-PRs restriction.
---
 src/video/dos/SDL_dosframebuffer.c | 95 ++++++++++++++++++++++++++++++
 1 file changed, 95 insertions(+)

diff --git a/src/video/dos/SDL_dosframebuffer.c b/src/video/dos/SDL_dosframebuffer.c
index 2a707c952..616ed3de1 100644
--- a/src/video/dos/SDL_dosframebuffer.c
+++ b/src/video/dos/SDL_dosframebuffer.c
@@ -32,6 +32,7 @@
 
 #include <pc.h>           // for inportb, outportb
 #include <sys/movedata.h> // for dosmemput (banked framebuffer writes)
+#include <stdio.h>        // diagnostic file I/O (DOSKUTSU patches/SDL/0002)
 
 // note that DOS_SURFACE's value is the same string that the dummy driver uses.
 #define DOS_SURFACE "SDL.internal.window.surface"
@@ -476,10 +477,78 @@ static void ProgramVGADAC(SDL_Palette *palette)
     }
 }
 
+// DOSKUTSU diagnostic (patches/SDL/0002, task #21). Trace the framebuffer
+// flush path to discriminate between (a) early-return guard fails so no
+// VRAM write happens, (b) source backbuffer is empty when written, (c)
+// VRAM write succeeds but readback shows it didn't land, (d) write +
+// readback both succeed but display still black. Output to /sdldbg.log
+// (sibling of NXEngine's /debug.log) instead of stdout/stderr — by the
+// time we reach this code the DOS console is in a VESA graphics mode
+// and stdout/stderr would be invisible.
+static FILE *_doskutsu_dbg_log = NULL;
+static int _doskutsu_dbg_call_total = 0;
+
+static void _doskutsu_dbg_open(void)
+{
+    if (!_doskutsu_dbg_log) {
+        _doskutsu_dbg_log = fopen("/sdldbg.log", "ab");
+    }
+}
+
+static void _doskutsu_dbg_dump_first16(const char *tag, const Uint8 *src, int n)
+{
+    if (!_doskutsu_dbg_log) {
+        return;
+    }
+    fprintf(_doskutsu_dbg_log, "%s", tag);
+    for (int i = 0; i < n; i++) {
+        fprintf(_doskutsu_dbg_log, " %02x", src[i]);
+    }
+    fprintf(_doskutsu_dbg_log, "\n");
+}
+
 bool DOSVESA_UpdateWindowFramebuffer(SDL_VideoDevice *device, SDL_Window *window, const SDL_Rect *rects, int numrects)
 {
     SDL_VideoData *vdata = device->internal;
 
+    // DOSKUTSU diagnostic header (patches/SDL/0002, task #21).
+    _doskutsu_dbg_open();
+    ++_doskutsu_dbg_call_total;
+    if (_doskutsu_dbg_log && _doskutsu_dbg_call_total == 1) {
+        fprintf(_doskutsu_dbg_log,
+                "DOSVESA-FB-INIT: direct_fb=%d use_dosmemput=%d banked_multibank=%d "
+                "pitches_match=%d fb_size=%lu bpp=%d src_pitch=%d vram_pitch=%d "
+                "vram_w=%d vram_h=%d vram_phys=0x%08lx vram_ptr=0x%08lx "
+                "win_base=0x%08lx win_gran=%lu win_size=%lu pixels=0x%08lx\n",
+                (int)fb_state.direct_fb, (int)fb_state.use_dosmemput,
+                (int)fb_state.banked_multibank, (int)fb_state.pitches_match,
+                (unsigned long)fb_state.fb_size, fb_state.bpp,
+                fb_state.src_pitch, fb_state.vram_pitch,
+                fb_state.vram_w, fb_state.vram_h,
+                (unsigned long)fb_state.vram_phys,
+                (unsigned long)(uintptr_t)fb_state.vram_ptr,
+                (unsigned long)fb_state.win_base,
+                (unsigned long)fb_state.win_gran_bytes,
+                (unsigned long)fb_state.win_size_bytes,
+                (unsigned long)(uintptr_t)fb_state.pixels);
+        fflush(_doskutsu_dbg_log);
+    }
+    {
+        bool guard = (fb_state.direct_fb && (fb_state.vram_ptr || fb_state.vram_phys));
+        if (_doskutsu_dbg_log &&
+            (_doskutsu_dbg_call_total == 1 || (_doskutsu_dbg_call_total % 100) == 0)) {
+            fprintf(_doskutsu_dbg_log,
+                    "DOSVESA-FB-CALL #%d: guard=%d numrects=%d ",
+                    _doskutsu_dbg_call_total, (int)guard, numrects);
+            if (fb_state.pixels) {
+                _doskutsu_dbg_dump_first16("src[0..15]=", fb_state.pixels, 16);
+            } else {
+                fprintf(_doskutsu_dbg_log, "src=NULL\n");
+            }
+            fflush(_doskutsu_dbg_log);
+        }
+    }
+
     // ===================================================================
     //  Direct-FB fast path: copy system-RAM to VRAM, program palette,
     //  optionally page-flip. No cursor compositing, no SDL_BlitSurface.
@@ -633,6 +702,23 @@ bool DOSVESA_UpdateWindowFramebuffer(SDL_VideoDevice *device, SDL_Window *window
             }
         }
 
+        // DOSKUTSU diagnostic (patches/SDL/0002): post-write VRAM readback.
+        // For dosmemput path, dosmemget the first 16 bytes of vram_phys; for
+        // nearptr LFB path, read directly from vram_ptr. If these differ
+        // from src[0..15] logged above, the write didn't land or landed
+        // somewhere wrong (bank-switch / address calc bug).
+        if (_doskutsu_dbg_log &&
+            (_doskutsu_dbg_call_total == 1 || (_doskutsu_dbg_call_total % 100) == 0)) {
+            Uint8 vram_first[16] = { 0 };
+            if (fb_state.use_dosmemput) {
+                dosmemget(fb_state.vram_phys, 16, vram_first);
+            } else if (fb_state.vram_ptr) {
+                SDL_memcpy(vram_first, fb_state.vram_ptr, 16);
+            }
+            _doskutsu_dbg_dump_first16("DOSVESA-FB-VRAM ", vram_first, 16);
+            fflush(_doskutsu_dbg_log);
+        }
+
         // Page flipping is only used with the nearptr LFB path. The banked
         // dosmemput path always writes to page 0 (the visible page) and
         // accepts tearing, avoiding a BIOS call.
@@ -663,6 +749,15 @@ bool DOSVESA_UpdateWindowFramebuffer(SDL_VideoDevice *device, SDL_Window *window
     //  with cursor compositing, palette sync, vsync, and page-flipping.
     // ===================================================================
 
+    // DOSKUTSU diagnostic: log entry into the normal (non-fast) path.
+    if (_doskutsu_dbg_log &&
+        (_doskutsu_dbg_call_total == 1 || (_doskutsu_dbg_call_total % 100) == 0)) {
+        fprintf(_doskutsu_dbg_log,
+                "DOSVESA-FB-NORMAL #%d: entered normal-path (fast-path guard failed)\n",
+                _doskutsu_dbg_call_total);
+        fflush(_doskutsu_dbg_log);
+    }
+
     SDL_Surface *src = fb_state.surface;
     if (!src) {
         src = (SDL_Surface *)SDL_GetPointerProperty(SDL_GetWindowProperties(window), DOS_SURFACE, NULL);
-- 
2.47.3

