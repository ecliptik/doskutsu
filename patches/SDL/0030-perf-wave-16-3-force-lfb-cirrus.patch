 include/SDL3/SDL_hints.h           | 56 ++++++++++++++++++++++++++++++
 src/video/dos/SDL_dosframebuffer.c | 13 ++++++-
 src/video/dos/SDL_dosmodes.c       | 27 +++++++++++++-
 3 files changed, 94 insertions(+), 2 deletions(-)

diff --git a/include/SDL3/SDL_hints.h b/include/SDL3/SDL_hints.h
index d6d9cda0f..2e0bd0f96 100644
--- a/include/SDL3/SDL_hints.h
+++ b/include/SDL3/SDL_hints.h
@@ -921,6 +921,62 @@ extern "C" {
  */
 #define SDL_HINT_DOS_DISABLE_LFB "SDL_DOS_DISABLE_LFB"
 
+/**
+ * A variable that, when set to "1", overrides the SDL/0019 Cirrus
+ * auto-disable AND the SDL_HINT_DOS_DISABLE_LFB manual disable, forcing
+ * the LFB path to be selected at both mode-set and FB-state-populate
+ * layers even on Cirrus chips. Strict-match: only the literal string "1"
+ * activates; any other value (including "0", empty, unset) is treated as
+ * "off" and the existing auto-disable / manual-disable behaviour applies
+ * unchanged.
+ *
+ * Background: the SDL/0019 fingerprint pattern was authored against the
+ * cirrus5 wave-5 evidence (Cirrus CL-GD5434 + UNIVBE 6.7) where the LFB
+ * aperture and the displayed VRAM region appeared decoupled. Subsequent
+ * waves on different Cirrus chips have shown a working LFB aperture, so
+ * the auto-disable is too aggressive for those configurations. Phase 9
+ * wave 16.3 introduces this hint as the experimental escape hatch:
+ * setting it skips the Cirrus heuristic and tries LFB on real hardware,
+ * letting us correlate the modeset log against the resulting on-screen
+ * behaviour.
+ *
+ * The override applies in two places, kept in sync per patch 0020:
+ *
+ *  - **SDL_dosmodes.c (mode-set)**: when this hint is "1", `force_banked`
+ *    is cleared so VBE 0x4F02 is called with VBE_SETMODE_LFB on
+ *    fingerprinted Cirrus cards.
+ *  - **SDL_dosframebuffer.c (FB-state-populate)**: same. The LFB nearptr
+ *    write path is selected when otherwise force_banked would have
+ *    routed writes through the banked window.
+ *
+ * The variable can be set to the following values:
+ *
+ *  - "0" (or unset, or empty): SDL/0019 auto-disable + manual disable
+ *    behaviour applies. (default)
+ *  - "1": LFB is forced on regardless of Cirrus auto-detect or manual
+ *    disable. Mode-set engages VBE_SETMODE_LFB; FB writes go through
+ *    the LFB nearptr path.
+ *
+ * Strict-match per CLAUDE.md DOSKUTSU env-var convention: only `e[0]=='1'
+ * && e[1]==0` activates. Anything else (including "0", empty string, or
+ * the variable being unset) leaves the existing behaviour intact.
+ *
+ * One diagnostic line lands in SDLDBG.LOG at modeset time:
+ *   `WAVE16-3-LFB-FORCE: hint=<unset|set> use_lfb=<0|1>
+ *   lfb_addr=0x%08lx fb_size=%lu`
+ * so each iter capture can confirm which path was taken.
+ *
+ * This hint must be set before the first call to SDL_GetWindowSurface()
+ * (or any function that triggers VBE mode-set). It is read at each
+ * mode-set and each populate_fb_state_for_direct_fb call (cheap, no
+ * caching).
+ *
+ * Added by patches/SDL/0030 (DOSKUTSU local patch, never upstreamed).
+ * See docs/PHASE9-WAVE-17-18-PLAN.md / the wave 16.3 LFB experiment for
+ * context.
+ */
+#define SDL_HINT_DOSKUTSU_FORCE_LFB "SDL_HINT_DOSKUTSU_FORCE_LFB"
+
 /**
  * Set the level of checking for invalid parameters passed to SDL functions.
  *
diff --git a/src/video/dos/SDL_dosframebuffer.c b/src/video/dos/SDL_dosframebuffer.c
index 85d4e3d28..6c34ad55d 100644
--- a/src/video/dos/SDL_dosframebuffer.c
+++ b/src/video/dos/SDL_dosframebuffer.c
@@ -364,7 +364,18 @@ static bool populate_fb_state_for_direct_fb(SDL_VideoDevice *device,
     // when the mode was technically opened with the LFB attribute on
     // hardware where banked_usable is true (every card we care about).
     const bool hint_disable_lfb = SDL_GetHintBoolean(SDL_HINT_DOS_DISABLE_LFB, false);
-    const bool force_banked = data->force_banked_path || hint_disable_lfb;
+
+    // DOSKUTSU patch 0030 (Phase 9 wave 16.3) — LFB-force override. When
+    // SDL_HINT_DOSKUTSU_FORCE_LFB is strict-match "1", clear the
+    // Cirrus auto-disable + manual-disable so the LFB nearptr write path
+    // is selected here even when force_banked would otherwise route writes
+    // through the banked window. Mirrors the same override at the
+    // mode-set layer in SDL_dosmodes.c so both layers stay in sync per
+    // patch 0020's policy. Strict env-var match per CLAUDE.md convention.
+    const char *force_lfb_env = SDL_getenv("SDL_HINT_DOSKUTSU_FORCE_LFB");
+    const bool hint_force_lfb = (force_lfb_env && force_lfb_env[0] == '1' && force_lfb_env[1] == 0);
+    const bool force_banked = !hint_force_lfb &&
+                              (data->force_banked_path || hint_disable_lfb);
     const bool use_lfb_path = lfb_usable && !force_banked &&
                               (prefer_lfb || !banked_usable);
 
diff --git a/src/video/dos/SDL_dosmodes.c b/src/video/dos/SDL_dosmodes.c
index 20543df1b..861470cb3 100644
--- a/src/video/dos/SDL_dosmodes.c
+++ b/src/video/dos/SDL_dosmodes.c
@@ -835,7 +835,20 @@ bool DOSVESA_SetDisplayMode(SDL_VideoDevice *device, SDL_VideoDisplay *sdl_displ
     // real Cirrus (cirrus6 capture symptom). Gating use_lfb on
     // !force_banked here keeps both layers in sync.
     const bool hint_disable_lfb = SDL_GetHintBoolean(SDL_HINT_DOS_DISABLE_LFB, false);
-    const bool force_banked = (data->force_banked_path || hint_disable_lfb) && is_banked_usable;
+
+    // DOSKUTSU patch 0030 (Phase 9 wave 16.3) — LFB-force override. When
+    // SDL_HINT_DOSKUTSU_FORCE_LFB is strict-match "1", clear the
+    // Cirrus auto-disable + manual-disable so LFB is engaged anyway. The
+    // wave 16.2 banked-flush bottom-strip bug on real Cirrus banked is the
+    // motivating case: if LFB happens to work on this chip, we retire the
+    // entire banked-mode bug class AND gain bandwidth (LFB is direct memcpy,
+    // no banked overhead). Strict env-var match per CLAUDE.md convention so
+    // SET FORCE_LFB=0 / SET FORCE_LFB= keep the auto-disable active.
+    const char *force_lfb_env = SDL_getenv("SDL_HINT_DOSKUTSU_FORCE_LFB");
+    const bool hint_force_lfb = (force_lfb_env && force_lfb_env[0] == '1' && force_lfb_env[1] == 0);
+    const bool force_banked = !hint_force_lfb &&
+                              (data->force_banked_path || hint_disable_lfb) &&
+                              is_banked_usable;
     const bool use_lfb = modedata->has_lfb &&
                          !force_banked &&
                          (hint_prefer_lfb ||
@@ -880,6 +893,18 @@ bool DOSVESA_SetDisplayMode(SDL_VideoDevice *device, SDL_VideoDisplay *sdl_displ
                        (unsigned long)modedata->win_func_ptr,
                        (int)hint_allow_direct, (int)hint_prefer_lfb);
 
+    // DOSKUTSU patch 0030 (Phase 9 wave 16.3) — single-line LFB-force diag.
+    // Reports whether SDL_DOSKUTSU_FORCE_LFB was set this modeset and the
+    // resulting use_lfb / lfb_addr / fb_size, so each iter capture has one
+    // grep'able token (`WAVE16-3-LFB-FORCE`) showing which path was taken.
+    // The fb_size value is what the FB-state-populate layer will use for
+    // size-based audits (matches padded_bytes_per_frame on the previous line).
+    DOSKUTSU_MODES_LOG("WAVE16-3-LFB-FORCE: hint=%s use_lfb=%d lfb_addr=0x%08lX fb_size=%lu",
+                       hint_force_lfb ? "set" : "unset",
+                       (int)use_lfb,
+                       (unsigned long)modedata->physical_base_addr,
+                       (unsigned long)((Uint32)modedata->h * (Uint32)modedata->pitch));
+
     // DOSKUTSU patch 0026 (Phase 9 wave 16 — 8bpp mode-pick diagnostic):
     // single grep'able line summarising what SDL_HINT_DOS_MAX_BPP did to the
     // mode pick. Pairs with WAVE16-FB-FIRSTFLUSH in SDL_dosframebuffer.c so
