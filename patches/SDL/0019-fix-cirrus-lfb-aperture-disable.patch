--- a/src/video/dos/SDL_dosmodes.h
+++ b/src/video/dos/SDL_dosmodes.h
@@ -31,6 +31,17 @@ extern void DOSVESA_FreeVESAInfo(void);
 extern Uint32 DOSVESA_GetVESATotalMemory(void);
 extern const char *DOSVESA_GetGPUName(void);
 
+// DOSKUTSU patch 0019 (Phase 9 wave 6) — return true if the active VBE
+// controller matches a known-broken combination where the LFB aperture
+// and the displayed VRAM region are decoupled (writes to LFB offset 0
+// don't appear on screen even with display-start at (0,0)). Currently
+// fingerprints UNIVBE-on-Cirrus 1MB cards. The caller (DOSVESA_VideoInit)
+// stores the result in SDL_VideoData::force_banked_path which suppresses
+// LFB engagement in populate_fb_state_for_direct_fb. Logs the decision
+// with the matched fingerprint reason. Safe to call any time after VBE
+// controller info has been queried (i.e. after DOSVESA_SupportsVESA()).
+extern bool DOSVESA_DetectLFBApertureBug(void);
+
 // VGA DAC (Digital-to-Analog Converter) ports for palette programming
 #define VGA_DAC_PIXEL_MASK  0x3C6 // pixel mask register (read/write, VGA-only)
 #define VGA_DAC_WRITE_INDEX 0x3C8 // write index register (set starting color index)
diff --git a/src/video/dos/SDL_dosvideo.c b/src/video/dos/SDL_dosvideo.c
index 59043bb76..90428e4a5 100644
--- a/src/video/dos/SDL_dosvideo.c
+++ b/src/video/dos/SDL_dosvideo.c
@@ -156,6 +156,16 @@ static bool DOSVESA_VideoInit(SDL_VideoDevice *device)
 
     SDL_zero(data->current_mode);
 
+    // DOSKUTSU patch 0019 (Phase 9 wave 6) — auto-detect the Cirrus
+    // LFB-aperture-decoupling bug and pre-emptively force the banked
+    // path. Detection is one log line + zero or one bool flip; safe to
+    // run unconditionally on every video-init. The flag is read in
+    // populate_fb_state_for_direct_fb (SDL_dosframebuffer.c) where the
+    // LFB-vs-banked path is selected per-CreateWindowFramebuffer; the
+    // SDL_HINT_DOS_DISABLE_LFB hint is also OR-checked there so the
+    // user can override even on cards we haven't fingerprinted.
+    data->force_banked_path = DOSVESA_DetectLFBApertureBug();
+
     SDL_VideoDisplay *display = SDL_GetVideoDisplay(display_id);
     if (!display || !DOSVESA_GetDisplayModes(device, display)) {
         return false;
diff --git a/src/video/dos/SDL_dosvideo.h b/src/video/dos/SDL_dosvideo.h
index ad27e3018..1695d746f 100644
--- a/src/video/dos/SDL_dosvideo.h
+++ b/src/video/dos/SDL_dosvideo.h
@@ -87,6 +87,21 @@ struct SDL_VideoData
     Uint32 display_start_offset; // byte offset (Y*pitch + X*bpp) of the
                                  // displayed origin, queried via VBE 0x4F07
                                  // sub 1. 0 if unknown / pre-LFB-set.
+
+    // DOSKUTSU patch 0019 (Phase 9 wave 6) — auto-disable LFB on cards
+    // where the LFB aperture and the displayed VRAM region are decoupled.
+    // The cirrus5 wave-5 capture (Cirrus CL-GD5434 + UNIVBE 6.7) showed
+    // writes to LFB offset 0 invisible on screen even with patch 0018's
+    // queried display-start offset (BIOS reports (0,0) but the display
+    // generator reads from a different VRAM region than the aperture
+    // maps to). The banked window at A000:0 still reaches the displayed
+    // page on the same card. populate_fb_state_for_direct_fb honours
+    // this flag by skipping the LFB path even when use_lfb_path would
+    // otherwise be selected. Set by GetVESAInfo when an OEM-string
+    // fingerprint matches the Cirrus + UNIVBE pattern, or by the manual
+    // SDL_HINT_DOS_DISABLE_LFB hint at populate_fb_state_for_direct_fb
+    // call time.
+    bool force_banked_path;      // detected/forced "do not engage LFB"
 };
 
 struct SDL_DisplayData
