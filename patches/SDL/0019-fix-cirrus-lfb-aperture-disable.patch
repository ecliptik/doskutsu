diff --git a/include/SDL3/SDL_hints.h b/include/SDL3/SDL_hints.h
index d1187e41a..d6d9cda0f 100644
--- a/include/SDL3/SDL_hints.h
+++ b/include/SDL3/SDL_hints.h
@@ -857,6 +857,70 @@ extern "C" {
  */
 #define SDL_HINT_DOS_PIN_WINDOW_TO_NATIVE_MODE "SDL_DOS_PIN_WINDOW_TO_NATIVE_MODE"
 
+/**
+ * A variable that disables the Linear Framebuffer (LFB) path on the DOS VBE
+ * backend, forcing the banked-window (real-mode A000:0 + bank-switching)
+ * path even when the BIOS reports an LFB available and the mode supports it.
+ *
+ * Background: on at least one combination of card + BIOS we test against —
+ * Cirrus Logic CL-GD5434 with SciTech UNIVBE 6.7 ("Display Doctor") — the
+ * LFB aperture (typically `0x78000000`) and the displayed VRAM region are
+ * effectively decoupled. Writes to LFB offset 0 update the aperture, but
+ * the display generator reads from a different region of VRAM than the
+ * aperture maps to, so on-screen output never changes despite successful
+ * VBE 0x4F02 mode-set, successful LFB DPMI mapping, and successful 0x4F07
+ * SET (which is itself a silent no-op on this BIOS — patch 0018 traces
+ * the GET-SET-GET sequence). Banked-mode writes via the `0xA000:0` window
+ * do reach the displayed page on the same card, so the banked path remains
+ * the working route on this BIOS even when the mode advertises LFB.
+ *
+ * Patches 0011/0014/0016/0018 each tried to fix LFB display-page selection
+ * on this card; patch 0018 confirmed the BIOS reports display-start at
+ * (0,0) but writes to LFB offset 0 still don't appear. The conclusion is
+ * that no LFB-side fix is reachable from VBE — the aperture-vs-display
+ * decoupling is below the BIOS interface.
+ *
+ * Two activation paths:
+ *
+ *  - **Auto-detection**: on every VBE controller-info read,
+ *    DOSVESA_GetVBEControllerInfo examines the OEM strings against the
+ *    Cirrus + UNIVBE fingerprint (vendor "SciTech Software, Inc.",
+ *    product containing "Display Doctor", total VRAM 1024 KB) and a
+ *    looser substring match for "Cirrus" / "CL-GD" anywhere in the OEM
+ *    strings. A match sets an internal `force_banked_path` flag,
+ *    suppressing LFB engagement.
+ *
+ *  - **Manual override**: setting this hint to "1" forces banked-only
+ *    regardless of detection. Useful for diagnostics or for cards we
+ *    haven't fingerprinted yet that exhibit the same aperture-decoupling
+ *    behaviour.
+ *
+ * The variable can be set to the following values:
+ *
+ *  - "0" (or unset): Use auto-detection. LFB is engaged when supported by
+ *    the mode AND the card isn't fingerprinted as Cirrus + UNIVBE. (default)
+ *  - "1": Force the banked path always. LFB is never engaged. The mode
+ *    will still be set with the LFB attribute when the BIOS reports it,
+ *    but `populate_fb_state_for_direct_fb` will treat the mode as banked
+ *    for the purpose of choosing the VRAM access path.
+ *
+ * On hardware where LFB is faster than banked (notably ATI Mach64 with
+ * M64VBE on the g2k Pentium OverDrive reference machine, where banked is
+ * bandwidth-bound at ~500 KB/s and LFB is 5-10× faster), do not set this
+ * hint — the auto-detection path will leave LFB enabled and you keep the
+ * Mach64 perf win. This hint is a per-card escape hatch, not a
+ * recommendation.
+ *
+ * This hint must be set before the first call to SDL_GetWindowSurface()
+ * (or any function that triggers VBE mode-set). Reading the hint at each
+ * mode-set is cheap; it is not cached.
+ *
+ * Added by patches/SDL/0019 (DOSKUTSU local patch, never upstreamed).
+ * See docs/PHASE9-15FPS-PLAN.md and the wave-5 cirrus5 capture
+ * (`/tmp/cirrus5/SDLDBG.LOG` lines 38-79) for the discovery context.
+ */
+#define SDL_HINT_DOS_DISABLE_LFB "SDL_DOS_DISABLE_LFB"
+
 /**
  * Set the level of checking for invalid parameters passed to SDL functions.
  *
diff --git a/src/video/dos/SDL_dosframebuffer.c b/src/video/dos/SDL_dosframebuffer.c
index 62a525f34..d19ae2844 100644
--- a/src/video/dos/SDL_dosframebuffer.c
+++ b/src/video/dos/SDL_dosframebuffer.c
@@ -328,7 +328,42 @@ static bool populate_fb_state_for_direct_fb(SDL_VideoDevice *device,
     // policy at this VRAM-path-selection layer that it applies at the
     // mode-selection layer (SDL_dosmodes.c LFB-decision).
     const bool prefer_lfb = SDL_GetHintBoolean(SDL_HINT_DOS_PREFER_LFB, false);
-    const bool use_lfb_path = lfb_usable && (prefer_lfb || !banked_usable);
+
+    // DOSKUTSU patch 0019 (Phase 9 wave 6) — disable LFB engagement on
+    // cards where the LFB aperture and the displayed VRAM region are
+    // decoupled. Two activation paths feed `force_banked`:
+    //
+    //   1. Auto-detection: data->force_banked_path was set by
+    //      DOSVESA_DetectLFBApertureBug at video-init when the OEM
+    //      strings matched the Cirrus + UNIVBE fingerprint (cirrus5
+    //      wave-5 evidence: writes to LFB offset 0 invisible despite
+    //      successful mode-set + DPMI mapping + display-start at (0,0)).
+    //
+    //   2. Manual hint: SDL_HINT_DOS_DISABLE_LFB=1 forces the banked
+    //      path regardless of detection. Useful for diagnostics or for
+    //      cards exhibiting the same bug we haven't fingerprinted yet.
+    //
+    // Note: this gate operates on the PATH SELECTION at this helper
+    // (LFB nearptr vs banked dosmemput), not on whether VBE 0x4F02 was
+    // called with VBE_SETMODE_LFB (DOSVESA_SetDisplayMode still does
+    // that based on the original use_lfb decision). The DPMI mapping
+    // exists; we just don't write to it. Banked is reachable even
+    // when the mode was technically opened with the LFB attribute on
+    // hardware where banked_usable is true (every card we care about).
+    const bool hint_disable_lfb = SDL_GetHintBoolean(SDL_HINT_DOS_DISABLE_LFB, false);
+    const bool force_banked = data->force_banked_path || hint_disable_lfb;
+    const bool use_lfb_path = lfb_usable && !force_banked &&
+                              (prefer_lfb || !banked_usable);
+
+    if (force_banked && lfb_usable && banked_usable) {
+        // One log line per CreateWindowFramebuffer when the override
+        // actually changes the path. Silent when banked was going to
+        // win anyway (would be redundant noise on every flush-equiv).
+        DOSKUTSU_LC_LOG("DISABLE_LFB engaged: auto=%d hint=%d -> banked path "
+                        "(would have used LFB otherwise: prefer_lfb=%d banked_usable=1)",
+                        (int)data->force_banked_path, (int)hint_disable_lfb,
+                        (int)prefer_lfb);
+    }
 
     fb_state.surface = surface;
     fb_state.direct_fb = true;
diff --git a/src/video/dos/SDL_dosmodes.c b/src/video/dos/SDL_dosmodes.c
index 9a68dd3c9..00b34a2e1 100644
--- a/src/video/dos/SDL_dosmodes.c
+++ b/src/video/dos/SDL_dosmodes.c
@@ -277,6 +277,65 @@ static const SDL_VESAInfo *GetVESAInfo(void)
     return vesa_info;
 }
 
+// DOSKUTSU patch 0019 (Phase 9 wave 6) — Cirrus aperture-decoupling
+// fingerprint. Examines OEM strings against known-broken combinations
+// where the LFB aperture and the displayed VRAM region are decoupled.
+// Returns true if the active VBE controller matches the broken pattern;
+// the caller (DOSVESA_VideoInit via DOSVESA_DetectLFBApertureBug) sets
+// SDL_VideoData::force_banked_path which suppresses LFB engagement in
+// populate_fb_state_for_direct_fb regardless of mode capabilities.
+//
+// Two match strategies:
+//
+//   1. Exact fingerprint: vendor "SciTech Software, Inc." +
+//      product containing "Display Doctor" + total VRAM 1024 KB.
+//      This is the cirrus5 wave-5 capture exactly. UNIVBE 6.7
+//      replaces the card's native VBE with its own ROM emulation
+//      and rewrites all OEM strings, so the underlying chip identity
+//      is hidden behind UNIVBE's strings unless we look at VRAM size
+//      as a proxy (CL-GD5434's 1 MB is the typical Cirrus config).
+//
+//   2. Loose substring: "Cirrus" or "CL-GD" anywhere in any OEM string.
+//      Catches cards running Cirrus's own native VBE (uncommon — Cirrus
+//      cards usually need UNIVBE — but possible).
+//
+// Diagnostic-only when not matched; one log line on each path so we
+// always see WHY the path was or wasn't taken.
+static bool DOSVESA_FingerprintCirrusLFBApertureBug(const SDL_VESAInfo *info, const char **out_reason)
+{
+    if (!info) {
+        if (out_reason) *out_reason = "no VESA info";
+        return false;
+    }
+
+    const char *vendor = info->oem_vendor ? info->oem_vendor : "";
+    const char *product = info->oem_product ? info->oem_product : "";
+    const char *string = info->oem_string ? info->oem_string : "";
+    const Uint32 vram_kb = info->total_memory / 1024;
+
+    // (1) Exact UNIVBE-on-Cirrus fingerprint. cirrus5 wave-5 evidence:
+    //     vendor='SciTech Software, Inc.'  product='SciTech Display Doctor(tm)'
+    //     total_vram=1024 KB
+    if (SDL_strstr(vendor, "SciTech Software") &&
+        SDL_strstr(product, "Display Doctor") &&
+        vram_kb == 1024) {
+        if (out_reason) *out_reason = "UNIVBE on 1MB card (matches CL-GD5434 + UNIVBE 6.7)";
+        return true;
+    }
+
+    // (2) Loose Cirrus substring match in any OEM string (catches native
+    //     Cirrus VBE without UNIVBE, if such a thing exists in the wild).
+    if (SDL_strstr(vendor, "Cirrus") || SDL_strstr(vendor, "CL-GD") ||
+        SDL_strstr(product, "Cirrus") || SDL_strstr(product, "CL-GD") ||
+        SDL_strstr(string, "Cirrus") || SDL_strstr(string, "CL-GD")) {
+        if (out_reason) *out_reason = "Cirrus/CL-GD substring in OEM strings";
+        return true;
+    }
+
+    if (out_reason) *out_reason = "no fingerprint match";
+    return false;
+}
+
 // Test by writing and reading back the DAC Pixel Mask register
 // On VGA this is a read/write register, on EGA/CGA the port either
 // doesn't exist (reads 0xFF) or isn't writable.
@@ -331,6 +390,37 @@ Uint32 DOSVESA_GetVESATotalMemory(void)
     return info ? info->total_memory : 0;
 }
 
+bool DOSVESA_DetectLFBApertureBug(void)
+{
+    const SDL_VESAInfo *info = GetVESAInfo();
+    const char *reason = "no VESA info";
+    const bool match = DOSVESA_FingerprintCirrusLFBApertureBug(info, &reason);
+    if (match) {
+        // Match: log the decisive line in the same format the report
+        // describes. The reason string carries the "what matched" detail
+        // (UNIVBE+1MB exact vs. Cirrus substring) without exposing the
+        // raw fingerprint logic to consumers.
+        DOSKUTSU_MODES_LOG("cirrus-lfb-aperture-bug: detected (oem='%s' product='%s' vram=%luKB) "
+                           "-> forcing banked path (reason: %s)",
+                           info && info->oem_vendor ? info->oem_vendor : "(empty)",
+                           info && info->oem_product ? info->oem_product : "(empty)",
+                           info ? (unsigned long)(info->total_memory / 1024) : 0UL,
+                           reason);
+    } else {
+        // No match: still log it so SDLDBG.LOG always carries the
+        // detection outcome (negative result is just as useful as
+        // positive when investigating a "should this hardware have
+        // forced banked?" question).
+        DOSKUTSU_MODES_LOG("cirrus-lfb-aperture-bug: NOT detected (oem='%s' product='%s' vram=%luKB) "
+                           "-> LFB path remains enabled (reason: %s)",
+                           info && info->oem_vendor ? info->oem_vendor : "(empty)",
+                           info && info->oem_product ? info->oem_product : "(empty)",
+                           info ? (unsigned long)(info->total_memory / 1024) : 0UL,
+                           reason);
+    }
+    return match;
+}
+
 static bool GetVESAModeInfo(Uint16 mode_id, SDL_DisplayModeData *info)
 {
     _go32_dpmi_seginfo hwinfo_seginfo;
diff --git a/src/video/dos/SDL_dosmodes.h b/src/video/dos/SDL_dosmodes.h
