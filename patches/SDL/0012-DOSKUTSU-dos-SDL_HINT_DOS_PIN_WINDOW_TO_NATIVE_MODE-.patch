---
 include/SDL3/SDL_hints.h     | 52 ++++++++++++++++++++++++++++++++++++
 src/video/dos/SDL_dosmodes.c | 40 +++++++++++++++++++++++++++
 2 files changed, 92 insertions(+)

diff --git a/include/SDL3/SDL_hints.h b/include/SDL3/SDL_hints.h
index 486a0d3ab..d1187e41a 100644
--- a/include/SDL3/SDL_hints.h
+++ b/include/SDL3/SDL_hints.h
@@ -805,6 +805,58 @@ extern "C" {
  */
 #define SDL_HINT_DOS_MAX_BPP "SDL_DOS_MAX_BPP"
 
+/**
+ * A variable that pins the DOS VBE mode to whatever was set first and
+ * suppresses any subsequent SDL3 internal mode-change request whose
+ * dimensions differ from the active mode.
+ *
+ * Background: SDL3's window/fullscreen/renderer reconciliation flow can
+ * fire multiple SDL_SetDisplayModeForDisplay calls during window setup —
+ * one for the dimensions the app passed to SDL_CreateWindow, then a
+ * second one to the display's "desktop mode" (which on the SDL3-DOS
+ * backend is hard-coded to 640×480 in DOSVESA_VideoInit). The second
+ * mode-set is always called WITH the app's renderer already configured
+ * for the FIRST mode's dimensions; the renderer's logical-presentation
+ * scaler does NOT re-evaluate after the mode-change, so it keeps blitting
+ * its old-dimension backbuffer into the upper-left of the new larger
+ * framebuffer. The visible result is "game renders only in a small box
+ * in the corner of the screen, surrounded by garbage".
+ *
+ * On hardware where the FIRST mode (the app-requested one) is what we
+ * actually want to keep — for example a Cirrus card via UNIVBE that
+ * exposes 320×240 modes natively, where a small 320×240 backbuffer is
+ * faster to flush than a 640×480 letterboxed render — this hint tells
+ * the SDL3-DOS backend to refuse the second mode-set.
+ *
+ * The variable can be set to the following values:
+ *
+ * - "0": Honour every mode-change request (default, original behaviour).
+ * - "1": After the first successful mode-set, suppress any subsequent
+ *        DOSVESA_SetDisplayMode call whose width or height differs from
+ *        the active mode. The call returns success without touching the
+ *        VBE state, the DPMI mapping, or fb_state. Same-dimension /
+ *        same-mode-id calls always pass through (handled by the existing
+ *        no-op-when-mode-id-matches early return).
+ *
+ * On hardware that has no mode matching the app-requested dimensions
+ * (e.g. ATI Mach64 + M64VBE which doesn't expose any 320×240 modes
+ * because the Mach64-CT chip lacks line-doubling circuitry), the FIRST
+ * mode-set will already have been the 640×480 fallback chosen by
+ * SDL_GetClosestFullscreenDisplayMode, and the second mode-set is a
+ * no-op anyway — so this hint is harmless on those targets.
+ *
+ * This hint must be set before the first call to SDL_CreateWindow (or
+ * any function that triggers VBE mode-set). Reading the hint each time
+ * SetDisplayMode runs is cheap; we do not cache it.
+ *
+ * Added by patches/SDL/0012 (DOSKUTSU local patch, never upstreamed).
+ * See docs/PHASE9-15FPS-PLAN.md §3 Lever 0b for the discovery context
+ * (Cirrus + UNIVBE smoke 2026-04-26 showing the upper-left rendering
+ * bug after Lever 1's lazy-fb_state-init started honouring 640×480
+ * mode-set #3).
+ */
+#define SDL_HINT_DOS_PIN_WINDOW_TO_NATIVE_MODE "SDL_DOS_PIN_WINDOW_TO_NATIVE_MODE"
+
 /**
  * Set the level of checking for invalid parameters passed to SDL functions.
  *
diff --git a/src/video/dos/SDL_dosmodes.c b/src/video/dos/SDL_dosmodes.c
index 732061960..8cdbf34bc 100644
--- a/src/video/dos/SDL_dosmodes.c
+++ b/src/video/dos/SDL_dosmodes.c
@@ -630,6 +630,46 @@ bool DOSVESA_SetDisplayMode(SDL_VideoDevice *device, SDL_VideoDisplay *sdl_displ
         return true;
     }
 
+    // DOSKUTSU patch 0012 — Phase 9 lever 0b (Cirrus + UNIVBE pin):
+    // SDL_HINT_DOS_PIN_WINDOW_TO_NATIVE_MODE suppresses any subsequent
+    // mode-change request whose dimensions differ from the active mode.
+    // Suppression is by-dimension, not by-mode-id, so a same-dimension
+    // alternative-id mode (e.g. a 320×240 mode at a different bpp the
+    // display hash maps to) would still be rejected — that's intentional:
+    // changing pitch/bpp under a live renderer is the same kind of
+    // upper-left-rendering breakage as changing dimensions outright.
+    //
+    // The above no-op-when-mode-id-matches early return handles the
+    // common "internal reconciliation calls SetDisplayMode with the same
+    // mode SDL just set" case without ever reaching here. This pin gate
+    // catches the OTHER case: SDL3 internal flow asks for the display's
+    // desktop mode (which DOSVESA_VideoInit hard-codes to 640×480) after
+    // the app's CreateWindow has already negotiated a smaller native mode.
+    //
+    // Why returning success rather than failing: SDL3 callers downstream
+    // assume mode-set either succeeded or the whole window is broken; a
+    // failure return propagates as "couldn't enter fullscreen" and breaks
+    // window setup. We want the FIRST mode to keep being the active one,
+    // so claiming success keeps the rest of the window/renderer setup
+    // happy without doing any actual hardware mode change.
+    //
+    // See docs/PHASE9-15FPS-PLAN.md §3 Lever 0b and the Cirrus + UNIVBE
+    // wave-2 capture (2026-04-26) showing the upper-left rendering bug
+    // after Lever 1's lazy-fb_state-init started honouring 640×480
+    // mode-set #3.
+    if (data->current_mode.internal &&
+        SDL_GetHintBoolean(SDL_HINT_DOS_PIN_WINDOW_TO_NATIVE_MODE, false) &&
+        (data->current_mode.internal->w != modedata->w ||
+         data->current_mode.internal->h != modedata->h)) {
+        DOSKUTSU_MODES_LOG("mode-set #%d (suppressed by PIN_WINDOW_TO_NATIVE_MODE hint): "
+                           "requested %dx%d differs from active %dx%d (current id=0x%X) "
+                           "-> returning true without VBE mode-set",
+                           ms_calls, modedata->w, modedata->h,
+                           data->current_mode.internal->w, data->current_mode.internal->h,
+                           data->current_mode.internal->mode_id);
+        return true;
+    }
+
     DOSVESA_InvalidateCachedFramebuffer();
 
     if (data->mapping.size) {
