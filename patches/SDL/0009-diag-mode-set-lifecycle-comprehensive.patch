+// DOSKUTSU shared diagnostic logger (patches/SDL/0009 — Phase 9 lever 1).
+//
+// All DOS-backend diagnostic log writers (DOSVESA-MODESET, DOSVESA-MODELIST,
+// DOSVESA-FB-INIT/CALL, [lifecycle], LFB-decision, mode-set) used to each
+// hold their own static FILE* opened on /sdldbg.log with independent libc
+// buffers. On real HW (gateway4 wave 1, 2026-04-26), two writers raced and
+// produced a truncated/interleaved log line:
+//
+//   "DOSVESA-MODESET: ... lfb_[lifecycle] CreateWindowFramebuffer:"
+//
+// fsync-per-write doesn't help: each FILE* still has its own buffer, so
+// lines from one writer can land mid-line of another. The shared writer
+// below funnels every log site through one FILE* + one fprintf+fflush+
+// fsync, eliminating the race.
+//
+// Per-line prefix tags are kept so existing greps (DOSVESA-MODESET,
+// [lifecycle], LFB-decision, etc.) still pull the relevant slices.
+//
+// Local-only patch per workspace policy (memory note "SDL upstream —
+// local patches only"): never PR'd upstream.
+#ifndef SDL_dosdbg_h_
+#define SDL_dosdbg_h_
+
+#ifdef SDL_VIDEO_DRIVER_DOSVESA
+
+#include <stdarg.h>
+
+// Lazy-open the shared /sdldbg.log on first use. Returns the FILE* or NULL.
+extern void doskutsu_dbg_open(void);
+
+// Write one fully-formatted log line (caller adds the prefix tag, e.g.
+// "[lifecycle]" or "DOSVESA-MODESET:"). Internally appends a newline if the
+// caller's fmt doesn't end in one. Atomic per call: fprintf + fflush +
+// fsync run sequentially with no interleaving from other doskutsu_dbg_*
+// callers, since they all share one FILE*.
+extern void doskutsu_dbg_log(const char *fmt, ...);
+
+// Variadic-args version for forwarding from variadic macros.
+extern void doskutsu_dbg_vlog(const char *fmt, va_list ap);
+
+#else
+#define doskutsu_dbg_open() ((void)0)
+#define doskutsu_dbg_log(...) ((void)0)
+#endif // SDL_VIDEO_DRIVER_DOSVESA
+
+#endif // SDL_dosdbg_h_
