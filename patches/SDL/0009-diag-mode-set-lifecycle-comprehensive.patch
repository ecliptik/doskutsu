+#include "SDL_internal.h"
+
+#ifdef SDL_VIDEO_DRIVER_DOSVESA
+
+#include "SDL_dosdbg.h"
+
+#include <stdio.h>
+#include <stdarg.h>
+#include <unistd.h>
+
+// DOSKUTSU shared diagnostic logger (patches/SDL/0009).
+//
+// Single shared FILE* on /sdldbg.log so concurrent log writers from
+// SDL_dosmodes.c, SDL_dosframebuffer.c, and SDL_video.c can't interleave
+// mid-line. fsync after every line so the trace survives a hard reset
+// (matches patch 0004's per-line fsync pattern).
+//
+// See SDL_dosdbg.h for rationale (gateway4 wave 1 log-race postmortem,
+// docs/PHASE9-15FPS-PLAN.md §3 Lever 1 wave 2 plan).
+static FILE *g_dbg_log = NULL;
+
+void doskutsu_dbg_open(void)
+{
+    if (!g_dbg_log) {
+        g_dbg_log = fopen("/sdldbg.log", "ab");
+    }
+}
+
+void doskutsu_dbg_vlog(const char *fmt, va_list ap)
+{
+    doskutsu_dbg_open();
+    if (!g_dbg_log) {
+        return;
+    }
+    vfprintf(g_dbg_log, fmt, ap);
+    // Append newline if the caller didn't include one.
+    size_t len = strlen(fmt);
+    if (len == 0 || fmt[len - 1] != '\n') {
+        fputc('\n', g_dbg_log);
+    }
+    fflush(g_dbg_log);
+    fsync(fileno(g_dbg_log));
+}
+
+void doskutsu_dbg_log(const char *fmt, ...)
+{
+    va_list ap;
+    va_start(ap, fmt);
+    doskutsu_dbg_vlog(fmt, ap);
+    va_end(ap);
+}
+
+#endif // SDL_VIDEO_DRIVER_DOSVESA
