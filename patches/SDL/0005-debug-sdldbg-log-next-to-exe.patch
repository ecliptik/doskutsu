From c1ce848808035beab3da290ba44e8dfb9bee6c96 Mon Sep 17 00:00:00 2001
From: Micheal Waltz <micheal@ecliptik.com>
Date: Sun, 26 Apr 2026 13:06:34 -0700
Subject: [PATCH] [DOSKUTSU] dos: write sdldbg.log next to the EXE instead of
 C:\
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Phase 8 ergonomic follow-up. Patches 0002 + 0003 wrote the diagnostic
log to fopen("/sdldbg.log") which on DOS resolves to root-of-current-
drive (C:\SDLDBG.LOG). NXEngine's DEBUG.LOG goes to the EXE's directory
(C:\DOSKUTSU\) via SDL_GetPrefPath. Putting the two log files in the
same place is operator-friendly: one DIR after a real-HW run shows both.

Use SDL_GetBasePath() (which returns the EXE's directory with trailing
separator) and fall back to a relative path if it isn't ready yet
(shouldn't happen — both log paths run after SDL_Init — but safe).

Local-only patch per workspace policy. No upstream PR.
---
 src/video/dos/SDL_dosframebuffer.c | 11 ++++++++++-
 src/video/dos/SDL_dosmodes.c       | 14 +++++++++++++-
 2 files changed, 23 insertions(+), 2 deletions(-)

diff --git a/src/video/dos/SDL_dosframebuffer.c b/src/video/dos/SDL_dosframebuffer.c
index e8bc847b4..de48ec877 100644
--- a/src/video/dos/SDL_dosframebuffer.c
+++ b/src/video/dos/SDL_dosframebuffer.c
@@ -492,7 +492,16 @@ static int _doskutsu_dbg_call_total = 0;
 static void _doskutsu_dbg_open(void)
 {
     if (!_doskutsu_dbg_log) {
-        _doskutsu_dbg_log = fopen("/sdldbg.log", "ab");
+        // Patch 0005: write the diagnostic log alongside the running EXE
+        // (next to NXEngine's DEBUG.LOG) instead of the C: root.
+        char path[260];
+        const char *base = SDL_GetBasePath();
+        if (base && *base) {
+            SDL_snprintf(path, sizeof(path), "%ssdldbg.log", base);
+        } else {
+            SDL_strlcpy(path, "sdldbg.log", sizeof(path));
+        }
+        _doskutsu_dbg_log = fopen(path, "ab");
     }
 }
 
diff --git a/src/video/dos/SDL_dosmodes.c b/src/video/dos/SDL_dosmodes.c
index 02abd46a3..01352b483 100644
--- a/src/video/dos/SDL_dosmodes.c
+++ b/src/video/dos/SDL_dosmodes.c
@@ -45,7 +45,19 @@ static FILE *_doskutsu_modes_dbg_log = NULL;
 static void _doskutsu_modes_dbg_open(void)
 {
     if (!_doskutsu_modes_dbg_log) {
-        _doskutsu_modes_dbg_log = fopen("/sdldbg.log", "ab");
+        // Patch 0005: write the diagnostic log alongside the running EXE
+        // (next to NXEngine's DEBUG.LOG) instead of the C: root, so the
+        // operator can find both files in one place after a real-HW run.
+        // SDL_GetBasePath returns a path with a trailing separator; falls
+        // back to relative if it isn't ready yet (very-early-init case).
+        char path[260];
+        const char *base = SDL_GetBasePath();
+        if (base && *base) {
+            SDL_snprintf(path, sizeof(path), "%ssdldbg.log", base);
+        } else {
+            SDL_strlcpy(path, "sdldbg.log", sizeof(path));
+        }
+        _doskutsu_modes_dbg_log = fopen(path, "ab");
     }
 }
 
