# vendor/sources.manifest — pinned upstream sources for the five-stage build.
#
# Format (whitespace-separated, one entry per line, '#' for comments):
#
#     <name>  <url>  <ref>  <sha>
#
# <name>  directory name under vendor/ that fetch-sources.sh clones into
# <url>   git clone URL
# <ref>   branch or tag to track (used when sha == PIN_ME to resolve, and
#         for documentation purposes once a concrete SHA is pinned)
# <sha>   40-char commit SHA to check out, or PIN_ME to fetch the tip of <ref>
#
# Run `./scripts/fetch-sources.sh --resolve` to resolve any PIN_ME entries;
# copy the printed SHAs back into this file to pin.

# SDL3 must be a post-PR-#15377 main commit — that PR added the DOS backend.
# The build-scripts/i586-pc-msdosdjgpp.cmake toolchain file ships in that PR;
# fetch-sources.sh checks for it after clone.
SDL            https://github.com/libsdl-org/SDL.git             main             74a746281f2208e07a7680560fcb7ec57565228e

# sdl2-compat main — the zlib-licensed SDL2-API shim that forwards to SDL3.
# No prior DJGPP build known; Phase 3 is the highest-risk phase.
sdl2-compat    https://github.com/libsdl-org/sdl2-compat.git     main             91d36b8d9d06958e2663623d100d12b596675120

# SDL_mixer release-3.2.x — SDL3-API release branch. WAV + OGG (via stb_vorbis)
# only, per Phase 4 CMake opts. Switched from release-2.8.x (SDL2 branch) when
# Phase 3 went the direct-SDL3-migration route — sdl2-compat-on-DJGPP turned
# out to be structurally incompatible (symbol collision; see #19/#24 + the
# Phase 3 architecture decision). SDL3_mixer is the equivalent for the SDL3
# stack on DOS.
SDL_mixer      https://github.com/libsdl-org/SDL_mixer.git       release-3.2.x    e69654e9eac6d07ec5dfb9d9db022e836d3d1e11

# SDL_image release-3.2.x — SDL3-API release branch, mirrors SDL_mixer's
# choice. PNG only via stb_image, per Phase 4 CMake opts. Switched from
# release-2.8.x (SDL2 branch) when Phase 3 went the direct-SDL3-migration
# route — see PLAN.md § Plan Amendments § 2026-04-24 for the decision.
SDL_image      https://github.com/libsdl-org/SDL_image.git       release-3.2.x    90a06b5d1d6bdc1bea7fb5fe60ce21e224070dca

# NXEngine-evo master — the Cave Story engine re-implementation (GPLv3).
# Upstream's default branch is `master`, not `main`.
nxengine-evo   https://github.com/nxengine/nxengine-evo.git      master           1f093d1423cc395eb199230cd609b806ef1daa36
