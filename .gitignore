# Build artifacts
/build/
/dist/
*.o
*.obj
*.exe
*.EXE

# Vendored DOS binaries are fetched on demand by scripts/fetch-vendor-binaries.sh
# (URLs + sha256 pins in vendor/binaries.manifest). The .doc / .lsm / COPYING /
# .txt files that legally must accompany each binary stay tracked via the
# negations below.
/vendor/cwsdpmi/cwsdpmi.exe
!vendor/cwsdpmi/cwsdpmi.doc

/vendor/lfndos/lfndos.exe
!vendor/lfndos/lfndos.doc
!vendor/lfndos/lfndos.lsm
!vendor/lfndos/COPYING

/vendor/doslfn/doslfn.com
/vendor/doslfn/doslfnms.com
!vendor/doslfn/doslfn.txt
!vendor/doslfn/doslfn.lsm

# Vendored upstreams — cloned by scripts/fetch-sources.sh, gitignored entirely.
# Only vendor/sources.manifest and vendor/cwsdpmi/ are tracked.
/vendor/SDL/
/vendor/sdl2-compat/
/vendor/SDL_mixer/
/vendor/SDL_image/
/vendor/nxengine-evo/

# Cave Story game assets — freeware but not redistributed from this repo.
# See docs/ASSETS.md for how to obtain and extract.
/data/

# Symlinks to the ~/emulators/ hub (recreated by scripts/setup-symlinks.sh)
/tools/djgpp

# DOSBox-X runtime artifacts
dosbox-x.log
mapper-*.map
capture/
*.ips

# CMake generated files that might end up at the root (belt-and-suspenders;
# real CMake output is confined to /build/)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# Python caches (in case tooling grows any)
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/

# Editor / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Claude Code local session state (.claude/settings.local.json is tracked)
.claude/projects/
.claude/todos/
.claude/shell-snapshots/

# Scratch / draft area — agent working files, draft reports awaiting human-in-the-loop
# action (e.g. upstream bug-report drafts before they're filed). Never committed.
/.tmp/

# Internal-only docs. Kept on disk for ongoing development; not part of the
# public face of the repo. Pattern-based to catch the PHASE-* family
# (PLAN/FINDINGS/CHECKLIST/AUDIT/DECISION/COLD-PICKUP) without per-file
# maintenance.
/PLAN.md
/TODO.md
/CLAUDE.md
/DOSKUTSU.md
/docs/PHASE*-PLAN.md
/docs/PHASE*-FINDINGS.md
/docs/PHASE*-CHECKLIST.md
/docs/PHASE*-AUDIT.md
/docs/PHASE*-DECISION.md
/docs/PHASE*-COLD-PICKUP.md
/docs/PHASE9.md
/docs/SDL3-MIGRATION.md
/docs/HARDWARE.md
/docs/BOOT.md
/docs/ports/
/patches/nxengine-evo/README.md
/patches/sdl2-compat/README.md

# Tests — keep public smoke gates tracked, exclude dev-only run captures.
# JPEGs under tests/ are blocked by policy (test fixtures should be the
# probe sources + .dat files, not phone photos of run output). PNGs under
# docs/screenshots/ remain tracked because they're embedded in README.md.
/tests/GAMEPLAY-SMOKE.md
/tests/phase8-runs/
/tests/**/*.jpeg
/tests/**/*.jpg

# Lever 3 audit working data — derived from Cave Story sprite extraction.
# Tool tools/audit-palettes.py is committed; per-run output CSVs are not.
/tools/audit-palettes-clusters.csv
/tools/audit-palettes.csv

# Local DOSBox-X / runtime test artifacts (never commit)
.claude/
*.SWP
DEBUG.LOG
SETTINGS.DAT
